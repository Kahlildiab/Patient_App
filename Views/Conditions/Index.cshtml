@model IEnumerable<DentalCollegeManagementSystem_AAU.Models.Condition>
@{
    ViewData["Title"] = "Conditions";
}

<table class="table">
    <thead>
        <tr>
            <th>Condition</th>
            <th>Year of Diagnosis</th>
            <th>Status</th>
            <th>Red Flag</th>
            <th>Notes</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ConditionName</td>
                <td>@(item.YearOfDiagnosis?.ToString() ?? "—")</td>
                <td>@(item.IsCurrentlyActive ? "Active" : "Inactive")</td>
                <td>
                    @if (item.IsFlagged)
                    {
                        <span style="color:#c0392b; font-weight:700;">🚩 Yes</span>
                    }
                    else
                    {

                        <span style="color:#aaa;">No</span>
                    }
                </td>
                <td>@(item.Notes ?? "—")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ConditionID">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.ConditionID">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>