@model DentalCollegeManagementSystem_AAU.Models.CreateConditionsViewModel

@{
    ViewData["Title"] = "Add Conditions";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .conditions-wrapper { max-width: 860px; margin: 32px auto; font-family: 'Segoe UI', sans-serif; }
    .conditions-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .conditions-header h2 { font-size: 18px; font-weight: 700; color: #252468; margin: 0; }
    .btn-add-row { background: #252468; color: white; border: none; padding: 8px 18px; font-size: 13px; font-weight: 600; border-radius: 5px; cursor: pointer; }
    .btn-add-row:hover { background: #1a1a4e; }
    .condition-row { border: 1px solid #e0e0e0; border-radius: 8px; padding: 18px 20px 14px; margin-bottom: 14px; background: #fafafa; }
    .condition-row-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 12px; }
    .field-label { font-size: 12px; font-weight: 600; color: #555; margin-bottom: 5px; display: block; }
    .field-input { width: 100%; border: 1px solid #ddd; border-radius: 5px; padding: 8px 12px; font-size: 13px; background: white; box-sizing: border-box; }
    .field-input:focus { outline: none; border-color: #252468; }
    .field-textarea { width: 100%; border: 1px solid #ddd; border-radius: 5px; padding: 8px 12px; font-size: 13px; background: white; box-sizing: border-box; resize: vertical; min-height: 70px; }
    .field-textarea:focus { outline: none; border-color: #252468; }
    .checkbox-row { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; font-size: 13px; color: #333; }
    .checkbox-row input[type="checkbox"] { width: 16px; height: 16px; accent-color: #252468; cursor: pointer; }
    .flag-row { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; font-size: 13px; font-weight: 600; color: #856404; background: #fff8e1; border: 1px solid #daa328; border-radius: 5px; padding: 8px 12px; }
    .flag-row input[type="checkbox"] { width: 16px; height: 16px; accent-color: #c0392b; cursor: pointer; }
    .btn-remove { background: none; border: none; color: #c0392b; font-size: 13px; cursor: pointer; padding: 0; display: flex; align-items: center; gap: 5px; font-weight: 500; }
    .btn-remove:hover { text-decoration: underline; }
    .form-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; }
    .btn-save { background: #252468; color: white; border: none; padding: 10px 28px; font-size: 14px; font-weight: 600; border-radius: 5px; cursor: pointer; }
    .btn-save:hover { background: #1a1a4e; }
    .btn-cancel { background: white; color: #555; border: 1px solid #ddd; padding: 10px 24px; font-size: 14px; font-weight: 500; border-radius: 5px; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; }
    .btn-cancel:hover { background: #f5f5f5; }
</style>

<div class="conditions-wrapper">
    <div class="conditions-header">
        <h2>Diagnosed Medical Conditions</h2>
        <button type="button" class="btn-add-row" onclick="addRow()">+ Add Condition</button>
    </div>

    <form asp-action="Create" method="post">
        <input type="hidden" name="PatientID" value="@Model.PatientID" />

        <div id="conditions-list">
            @for (int i = 0; i < Model.Conditions.Count; i++)
            {
                <div class="condition-row" id="row-@i">
                    <div class="condition-row-grid">
                        <div>
                            <label class="field-label">Condition</label>
                            <input type="text" name="Conditions[@i].ConditionName"
                                   class="field-input" placeholder="e.g. Hypertension" />
                        </div>
                        <div>
                            <label class="field-label">Year of Diagnosis</label>
                            <input type="number" name="Conditions[@i].YearOfDiagnosis"
                                   class="field-input" placeholder="e.g. 2020" min="1900" max="2100" />
                        </div>
                    </div>
                    <div class="checkbox-row">
                        <input type="checkbox" name="Conditions[@i].IsCurrentlyActive" value="true" checked />
                        Currently Active
                    </div>
                    <!-- ✅ Flag -->
                    <div class="flag-row">
                        <input type="checkbox" name="Conditions[@i].IsFlagged" value="true" id="flag_@i" />
                        <label for="flag_@i" style="cursor:pointer;">⚑ Flag this condition (will appear as alert in patient info bar)</label>
                    </div>
                    <div>
                        <label class="field-label">Notes</label>
                        <textarea name="Conditions[@i].Notes"
                                  class="field-textarea" placeholder="Any additional notes..."></textarea>
                    </div>
                    <button type="button" class="btn-remove" onclick="removeRow(this)">🗑 Remove</button>
                </div>
            }
        </div>

        <div class="form-actions">
            <a href="@Url.Action("Details", "Patient", new { id = Model.PatientID })" class="btn-cancel">Cancel</a>
            <button type="submit" class="btn-save">Save Conditions</button>
        </div>
    </form>
</div>

<script>
    let rowIndex = @Model.Conditions.Count;

    function addRow() {
        const i = rowIndex++;
        const html = `
            <div class="condition-row" id="row-${i}">
                <div class="condition-row-grid">
                    <div>
                        <label class="field-label">Condition</label>
                        <input type="text" name="Conditions[${i}].ConditionName"
                               class="field-input" placeholder="e.g. Hypertension" />
                    </div>
                    <div>
                        <label class="field-label">Year of Diagnosis</label>
                        <input type="number" name="Conditions[${i}].YearOfDiagnosis"
                               class="field-input" placeholder="e.g. 2020" min="1900" max="2100" />
                    </div>
                </div>
                <div class="checkbox-row">
                    <input type="checkbox" name="Conditions[${i}].IsCurrentlyActive" value="true" checked />
                    Currently Active
                </div>
                <div class="flag-row">
                    <input type="checkbox" name="Conditions[${i}].IsFlagged" value="true" id="flag_${i}" />
                    <label for="flag_${i}" style="cursor:pointer;">⚑ Flag this condition (will appear as alert in patient info bar)</label>
                </div>
                <div>
                    <label class="field-label">Notes</label>
                    <textarea name="Conditions[${i}].Notes"
                              class="field-textarea" placeholder="Any additional notes..."></textarea>
                </div>
                <button type="button" class="btn-remove" onclick="removeRow(this)">🗑 Remove</button>
            </div>`;
        document.getElementById('conditions-list').insertAdjacentHTML('beforeend', html);
    }

    function removeRow(btn) {
        const row = btn.closest('.condition-row');
        if (document.querySelectorAll('.condition-row').length > 1) row.remove();
    }
</script>