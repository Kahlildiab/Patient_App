@model DentalCollegeManagementSystem_AAU.Models.Condition
@{
    ViewData["Title"] = "Delete Condition";
}

<h3>Are you sure you want to delete this condition?</h3>
<div>
    <dl class="row">
        <dt class="col-sm-3">Condition</dt>
        <dd class="col-sm-9">@Model.ConditionName</dd>

        <dt class="col-sm-3">Year of Diagnosis</dt>
        <dd class="col-sm-9">@(Model.YearOfDiagnosis?.ToString() ?? "—")</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@(Model.IsCurrentlyActive ? "Active" : "Inactive")</dd>

        <dt class="col-sm-3">Red Flag</dt>
        <dd class="col-sm-9">
            @if (Model.IsFlagged)
            {
                <span style="color:#c0392b; font-weight:700;">🚩 Yes</span>
            }
            else
            {
                <span style="color:#aaa;">No</span>
            }
        </dd>

        <dt class="col-sm-3">Notes</dt>
        <dd class="col-sm-9">@(Model.Notes ?? "—")</dd>
    </dl>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="ConditionID" value="@Model.ConditionID" /> @* ✅ الحل *@
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>