@{
    var conditions = ViewBag.Conditions as List<DentalCollegeManagementSystem_AAU.Models.Condition>;
}

<div style="border:1px solid #ddd; border-radius:4px; padding:16px 20px; margin-bottom:12px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:14px;">
        <div style="font-weight:700; font-size:13px; color:#252468;">5. Diagnosed Medical Conditions</div>
        <a asp-controller="Conditions" asp-action="Create" asp-route-patientId="@Model.PatientID"
               style="background:#252468; color:white; padding:5px 14px; font-size:12px; font-weight:600; border-radius:4px; text-decoration:none;">
            + Add Condition
        </a>
    </div>

    @if (conditions != null && conditions.Any())
    {
        <table style="width:100%; border-collapse:collapse; font-size:12px;">
            <thead>
                <tr style="background:#f5f5f5;">
                    <th style="padding:8px 12px; text-align:left; color:#555; font-weight:600; border-bottom:1px solid #e0e0e0;">Condition</th>
                    <th style="padding:8px 12px; text-align:left; color:#555; font-weight:600; border-bottom:1px solid #e0e0e0;">Year</th>
                    <th style="padding:8px 12px; text-align:center; color:#555; font-weight:600; border-bottom:1px solid #e0e0e0;">Status</th>
                    <th style="padding:8px 12px; text-align:left; color:#555; font-weight:600; border-bottom:1px solid #e0e0e0;">Notes</th>
                    <th style="padding:8px 12px; text-align:left; color:#555; font-weight:600; border-bottom:1px solid #e0e0e0;">Flag</th>
                    <th style="padding:8px 12px; text-align:center; color:#555; font-weight:600; border-bottom:1px solid #e0e0e0;">Action</th>
                </tr>
            </thead>
            <tbody id="conditions-tbody">
                @foreach (var c in conditions)
                {
                    <tr style="border-bottom:1px solid #f0f0f0;">

                        {{/* Condition */}}
                        <td style="padding:8px 12px; font-weight:600; color:#252468;">@c.ConditionName</td>

                        {{/* Year */}}
                        <td style="padding:8px 12px; color:#555;">
                            @(c.YearOfDiagnosis.HasValue? c.YearOfDiagnosis.ToString() : "—")
                        </td>

                        {{/* Status */}}
                        <td style="padding:8px 12px; text-align:center;">
                            @if (c.IsCurrentlyActive)
                            {
                                <span style="background:#e8f5e9; color:#2e7d32; padding:3px 10px; border-radius:12px; font-size:11px; font-weight:600;">Active</span>
                            }
                            else
                            {
                                <span style="background:#f5f5f5; color:#888; padding:3px 10px; border-radius:12px; font-size:11px; font-weight:600;">Inactive</span>
                            }
                        </td>

                        {{/* Notes */}}
                        <td style="padding:8px 12px; color:#666;">
                            @(string.IsNullOrEmpty(c.Notes) ? "—" : c.Notes)
                        </td>

                        {{/* Flag */}}
                        <td style="padding:8px 12px;">
                            @if (c.IsFlagged)
                            {
                                <span style="display:inline-block; background:#fff3cd; color:#856404; border:1px solid #daa328;
                                font-size:11px; font-weight:600; padding:2px 8px; border-radius:20px;">⚑ Flagged</span>
                            }
                            else
                            {
                                <span style="color:#aaa; font-size:11px;">—</span>
                            }
                        </td>

                        {{/* Action */}}
                        <td style="padding:8px 12px; text-align:center; white-space:nowrap;">
                            <button type="button"
                                    onclick="openEditConditionModal(@c.ConditionID, '@Html.Raw(c.ConditionName.Replace("'", "\\'"))', @(c.YearOfDiagnosis.HasValue? c.YearOfDiagnosis.ToString() : "null"), @(c.IsCurrentlyActive ? "true" : "false"), '@Html.Raw((c.Notes ?? "").Replace("'", "\\'"))', @(c.IsFlagged ? "true" : "false"))"
                                    style="background:none; border:none; color:#252468; cursor:pointer; margin-right:8px;"
                                    title="Edit">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </button>
                            <button type="button"
                                    onclick="deleteCondition(this, @c.ConditionID)"
                                    style="background:none; border:none; color:#c0392b; cursor:pointer;"
                                    title="Delete">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="font-size:12px; color:#888;">No conditions recorded yet.</div>
    }
</div>