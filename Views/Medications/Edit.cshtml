@model DentalCollegeManagementSystem_AAU.Models.Medication

@{
    ViewData["Title"] = "Edit Medication";
}

<link rel="stylesheet" href="~/css/Site.css" />
<link rel="stylesheet" href="~/css/all.min.css" />

<style>
    .form-wrapper { padding: 30px 20px; max-width: 700px; margin: 0 auto; }
    .form-card { border: 1.5px solid #252468; background: #fff; padding: 30px 36px; }
    .field-label { font-size: 12px; font-weight: 600; color: #555; display: block; margin-bottom: 5px; }
    .field-input { width: 100%; border: 1px solid #ddd; border-radius: 5px; padding: 8px 12px; font-size: 13px; box-sizing: border-box; }
    .field-input:focus { border-color: #252468; outline: none; }
    .field-group { margin-bottom: 16px; }
</style>

<div class="form-wrapper">
    <section id="title-wrapper" style="justify-content:center; margin-bottom:20px;">
        <div class="lineleft"></div>
        <h1 class="sectiontitle heading6">
            <p style="text-align:center;"><span style="color:#252468;">EDIT MEDICATION</span></p>
        </h1>
        <div class="lineright" style="display:block; background-color:#daa328;"></div>
    </section>

    <div class="form-card">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="font-size:13px; margin-bottom:12px;"></div>
            <input type="hidden" asp-for="MedicationID" />
            <input type="hidden" asp-for="PatientID" />

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                <div class="field-group">
                    <label class="field-label">Drug Name <span style="color:#c0392b;">*</span></label>
                    <input asp-for="DrugName" class="field-input" />
                    <span asp-validation-for="DrugName" class="text-danger" style="font-size:11px;"></span>
                </div>
                <div class="field-group">
                    <label class="field-label">Dose</label>
                    <input asp-for="Dose" class="field-input" />
                </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                <div class="field-group">
                    <label class="field-label">Frequency</label>
                    <input asp-for="Frequency" class="field-input" />
                </div>
                <div class="field-group">
                    <label class="field-label">Duration</label>
                    <input asp-for="Duration" class="field-input" />
                </div>
            </div>

            <select id="editMedFlagType" name="FlagType"
                    style="width:100%; border:1px solid #ddd; border-radius:5px; padding:8px 12px; font-size:13px;">
                <option value="">-- None --</option>
                <option value="Anticoagulant">Anticoagulant</option>
                <option value="Bisphosphonates">Bisphosphonates / Antiresorptive</option>
                <option value="Steroids">Steroids (Systemic)</option>
                <option value="Immunosuppressants">Immunosuppressants</option>
            </select>

            <div style="display:flex; justify-content:space-between; align-items:center; margin-top:24px;">
                <a asp-action="Index" style="color:#252468; font-size:13px; font-weight:600; text-decoration:none;">
                    <i class="fa-solid fa-arrow-left"></i> Back to List
                </a>
                <div class="btnwrap">
                    <button type="submit" class="mybtn heading13"
                        style="background-color:#DAA328; border-radius:0px 10px 10px; border:none; padding:10px 30px;">
                        Save Changes
                        <span class="line" style="border-right:6px solid #252468; border-bottom:6px solid #252468; right:-4px; bottom:-4px; border-top:none; border-left:none;"></span>
                        <span class="areaborder" style="border:0px;"></span>
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}