    <div class="row g-4">
        <div class="col-lg-3 col-md-6 d-grid">
            <div class="countersection">
                <h2 class="countertitle"><p><span class="heading8">TOTAL PATIENTS</span></p></h2>
                <span class="countercorner"></span>
                <div class="counterposition">
                    <div class="counterarea heading5">
                        <span style="color:inherit;" data-toggle="counterUp">@ViewBag.TotalPatients</span>
                        <span class="counterareacorner"></span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 d-grid">
            <div class="countersection">
                <h2 class="countertitle"><p><span class="heading8">PATIENTS</span></p></h2>
                <span class="countercorner"></span>
                <div class="counterposition">
                    <div class="counterarea heading5">
                        <span style="color:inherit;" data-toggle="counterUp">@ViewBag.AcceptedPatients</span>
                        <span class="counterareacorner"></span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 d-grid">
            <div class="countersection">
                <h2 class="countertitle"><p><span class="heading8">SCHEDULED APPOINTMENTS</span></p></h2>
                <span class="countercorner"></span>
                <div class="counterposition">
                    <div class="counterarea heading5">
                        <span style="color:inherit;" data-toggle="counterUp">@ViewBag.ScheduledAppointments</span>
                        <span class="counterareacorner"></span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 d-grid">
            <div class="countersection">
                <h2 class="countertitle"><p><span class="heading8">DISCHARGED PATIENTS</span></p></h2>
                <span class="countercorner"></span>
                <div class="counterposition">
                    <div class="counterarea heading5">
                        <span style="color:inherit;" data-toggle="counterUp">@ViewBag.DischargedPatients</span>
                        <span class="counterareacorner"></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="page-wrapper">
    <div class="container">

        <div style="background:#e9e8e8; width:100vw; position:relative; left:50%; right:50%; margin-left:-50vw; margin-right:-50vw; padding:30px 40px;">
            <div style="max-width:1300px; margin:0 auto;">
                <section id="title-wrapper" style="justify-content:flex-start;">
                    <div class="lineright" style="display:block; background-color:#daa328; max-width:650px;"></div>
                    <h1 class="sectiontitle heading6">
                        <p style="text-align:left;"><span style="color:#252468;">SEARCH</span></p>
                    </h1>
                </section>
                <br />
                <form method="get">
                    <div style="background:white; padding:16px 20px;">
                        <div class="row align-items-center mb-3">
                            <div class="col-md-2">
                                <label style="font-weight:600; font-size:13px; color:#252468; margin:0;">Search by Name</label>
                            </div>
                            <div class="col-md-10">
                                <input type="text" name="searchName" value="@searchName"
                                       placeholder="e.g. Ahmad Mohammad"
                                       class="form-control" style="border:1px solid #ddd; border-radius:0;" />
                            </div>
                        </div>
                        <div class="row align-items-center g-2">
                            <div class="col-md-2">
                                <label style="font-weight:600; font-size:13px; color:#252468; margin:0;">National ID / Passport</label>
                            </div>
                            <div class="col-md-2">
                                <input type="text" name="searchID" value="@searchID"
                                       placeholder="e.g. 9876543210"
                                       class="form-control" style="border:1px solid #ddd; border-radius:0;" />
                            </div>
                            <div class="col-md-2 text-center">
                                <label style="font-weight:600; font-size:13px; color:#252468; margin:0;">Appointment Date</label>
                            </div>
                            <div class="col-md-2">
                                <input type="date" name="filterDate" value="@filterDate"
                                       class="form-control" style="border:1px solid #ddd; border-radius:0;" />
                            </div>
                            <div class="col-md-1 text-center">
                                <label style="font-weight:600; font-size:13px; color:#252468; margin:0;">AM / PM</label>
                            </div>
                            <div class="col-md-1">
                                <select name="filterTime" class="form-control" style="border:1px solid #ddd; border-radius:0;">
                                    <option value="">-- All --</option>
                                    <option value="AM" selected="@(filterTime == "AM" ? "selected" : null)">AM</option>
                                    <option value="PM" selected="@(filterTime == "PM" ? "selected" : null)">PM</option>
                                </select>
                            </div>
                            <div class="col-md-1 text-center">
                                <label style="font-weight:600; font-size:13px; color:#252468; margin:0;">Status</label>
                            </div>
                            <div class="col-md-1">
                                <select name="filterStatus" class="form-control" style="border:1px solid #ddd; border-radius:0;">
                                    <option value="">-- All --</option>
                                    <option value="Screening" selected="@(filterStatus == "Screening" ? "selected" : null)">🔬 Screening</option>
                                    <option value="Allocated" selected="@(filterStatus == "Allocated" ? "selected" : null)">✅ Allocated</option>
                                    <option value="Discharged" selected="@(filterStatus == "Discharged" ? "selected" : null)">🚪 Discharged</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div style="text-align:center;">
                        <button type="submit"
                                style="width:90%; background:#c81589; color:white; border:none; padding:12px; font-size:15px; font-weight:600; cursor:pointer; margin-top:3px; letter-spacing:1px;">
                            Search &nbsp;<i class="fa-solid fa-magnifying-glass"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <br />

        <section id="title-wrapper" style="justify-content:End;">
            <div class="lineleft"></div>
            <h1 class="sectiontitle heading6">
                <p style="text-align:center;"><span style="color:#252468;">PATIENTS</span></p>
            </h1>
            <div class="lineright" style="display:block; background-color:#daa328;"></div>
        </section>

        <br />

        <div class="custom-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 style="color:rgb(38,76,159); font-weight:600; margin:0;">
                    Total Registered Patients
                    <span style="background-color:#daa328; color:white; padding:4px 12px; font-weight:600;">@totalItems</span>
                </h5>
                @if (userRole != "Student")
                {
                    <div class="d-flex" style="gap:10px;">
                        <a asp-controller="Patients" asp-action="CreatePublic"
                           style="background-color:#DAA328;color:white;border:2px solid white !important;outline:2px solid #DAA328 !important;padding:5px 10px;border-radius:0 !important;font-size:13px;font-weight:600;cursor:pointer;text-decoration:none;display:inline-block;">
                            <i class="fa-solid fa-person-circle-plus"></i> Add New Patient
                        </a>
                    </div>
                }
            </div>

            @* ===== Active Filters ===== *@
            @if (!string.IsNullOrEmpty(searchName) || !string.IsNullOrEmpty(searchID) ||
                 !string.IsNullOrEmpty(filterDate) || !string.IsNullOrEmpty(filterTime) ||
                 !string.IsNullOrEmpty(filterStatus))
            {
                <div class="active-filters">
                    <span style="font-size:12px;font-weight:600;color:#C81587;align-self:center;">Active filters:</span>
                    @if (!string.IsNullOrEmpty(searchName))
                    {
                        <span class="filter-tag"><i class="fa-solid fa-user me-1"></i> @searchName</span>
                    }
                    @if (!string.IsNullOrEmpty(searchID))
                    {
                        <span class="filter-tag"><i class="fa-solid fa-id-card me-1"></i> @searchID</span>
                    }
                    @if (!string.IsNullOrEmpty(filterDate))
                    {
                        <span class="filter-tag"><i class="fa-solid fa-calendar me-1"></i> @filterDate</span>
                    }
                    @if (!string.IsNullOrEmpty(filterTime))
                    {
                        <span class="filter-tag"><i class="fa-solid fa-clock me-1"></i> @filterTime</span>
                    }
                    @if (!string.IsNullOrEmpty(filterStatus))
                    {
                        string statusIcon = filterStatus == "Allocated" ? "fa-user-check"
                                          : filterStatus == "Discharged" ? "fa-door-open"
                                          : "fa-microscope";
                        <span class="filter-tag"><i class="fa-solid @statusIcon me-1"></i> @filterStatus</span>
                    }
                </div>
            }

            <div class="table-responsive">
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>National ID</th>
                            <th>Gender</th>
                            <th>Age</th>
                            <th>Next Appointment</th>
                            <th>Attendance</th>
                            <th>Patient Status</th>
                            <th>Phone</th>
                            <th style="white-space:nowrap;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!pagedModel.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4">
                                    <i class="fa-solid fa-circle-exclamation me-2"></i>
                                    No patients found matching your search.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in pagedModel)
                            {
                                DentalCollegeManagementSystem_AAU.Models.Appointment? nxt = null;
                                nextApptMap.TryGetValue(item.PatientID, out nxt);

                                <tr>
                                    <td>@item.FirstName @item.SecondName @item.ThirdName @item.FourthName</td>
                                    <td>@item.NationalID_PassportNumber</td>
                                    <td>@item.Gender?.Substring(0, 1)</td>
                                    <td>
                                        @if (item.DateOfBirth.HasValue)
                                        {
                                            int age = DateTime.Today.Year - item.DateOfBirth.Value.Year;
                                            if (item.DateOfBirth.Value.Date > DateTime.Today.AddYears(-age)) age--;
                                            @age
                                        }
                                        else
                                        {
                                            <span style="color:#aaa;">-</span>
                                        }
                                    </td>

                                    <td>
                                        @if (nxt != null)
                                        {
                                            string rawTime = nxt.Patient?.AppointmentTime ?? "";
                                            string apptPeriod = "";
                                            string apptTime = "";

                                            if (rawTime.Contains("|"))
                                            {
                                                var parts = rawTime.Split('|');
                                                apptPeriod = parts[0];
                                                apptTime = parts[1];
                                            }
                                            else if (rawTime == "AM" || rawTime == "PM")
                                            {
                                                apptPeriod = rawTime;
                                                apptTime = rawTime == "AM" ? "09:00" : "13:00";
                                            }
                                            else
                                            {
                                                apptPeriod = nxt.TimeFrom.Hours < 12 ? "AM" : "PM";
                                                apptTime = nxt.TimeFrom.Hours < 12 ? "09:00" : "13:00";
                                            }

                                            <span class="next-appt-badge">
                                                <i class="fa-solid fa-calendar-check me-1"></i>
                                                @nxt.AppointmentDate.ToString("yyyy-MM-dd")
                                                · @nxt.AppointmentDay
                                                · @apptPeriod
                                                @if (!string.IsNullOrEmpty(apptTime))
                                                {
                                                    <span> · @apptTime</span>
                                                }
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="next-appt-none">— No upcoming</span>
                                        }
                                    </td>

                                    <td>
                                        @if (item.AttendanceStatus == "Attended")
                                        {
                                            <span class="attendance-attended-badge">
                                                <i class="fa-solid fa-check me-1"></i>Attended
                                            </span>
                                        }
                                        else if (item.AttendanceStatus == "NoShow")
                                        {
                                            <span class="attendance-noshow-badge">
                                                <i class="fa-solid fa-xmark me-1"></i>No Show
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="attendance-pending-badge">
                                                <i class="fa-solid fa-clock me-1"></i>Pending
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        @if (item.PatientStatus == "Allocated")
                                        {
                                            <span style="background:#d1e7dd; color:#0f5132; border:1px solid #a3cfbb; border-radius:4px; padding:2px 8px; font-size:.72rem; font-weight:700;">
                                                <i class="fa-solid fa-user-check me-1"></i>Allocated
                                            </span>
                                        }
                                        else if (item.PatientStatus == "Discharged")
                                        {
                                            <span style="background:#e2e3e5; color:#383d41; border:1px solid #d6d8db; border-radius:4px; padding:2px 8px; font-size:.72rem; font-weight:700;">
                                                <i class="fa-solid fa-door-open me-1"></i>Discharged
                                            </span>
                                        }
                                        else
                                        {
                                            <span style="background:#fff3cd; color:#856404; border:1px solid #ffc107; border-radius:4px; padding:2px 8px; font-size:.72rem; font-weight:700;">
                                                <i class="fa-solid fa-microscope me-1"></i>Screening
                                            </span>
                                        }
                                    </td>

                                    <td>@item.PhoneNumber</td>
                                    <td style="white-space:nowrap;">
                                        <a asp-controller="Patients" asp-action="Edit" asp-route-id="@item.PatientID"
                                           style="background:none;color:#3F8CCA;border:none;padding:5px 6px;font-size:13px;font-weight:600;margin:2px;cursor:pointer;text-decoration:none;display:inline-block;">
                                            <i class="fa-solid fa-pen"></i> Edit
                                        </a>

                                        <button type="button"
                                                onclick="checkAttendance(@item.PatientID, '@item.FirstName @item.FourthName', '@item.AttendanceStatus', '@userRole')"
                                                style="background:none;color:#3F8CCA;border:none;padding:5px 6px;font-size:13px;font-weight:600;margin:2px;cursor:pointer;">
                                            <i class="fa-solid fa-eye"></i> Details
                                        </button>

                                        @if (item.StatusID == 3)
                                        {
                                            <form asp-controller="Patients" asp-action="SetInTreatment" asp-route-id="@item.PatientID" method="post" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" style="background:none;color:#264C9F;border:none;padding:5px 6px;font-size:13px;font-weight:600;margin:2px;cursor:pointer;">
                                                    <i class="fa-solid fa-stethoscope"></i> In Treatment
                                                </button>
                                            </form>
                                        }
                                        @if (item.StatusID == 4)
                                        {
                                            <form asp-controller="Patients" asp-action="SetCompleted" asp-route-id="@item.PatientID" method="post" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" style="background:none;color:#17a2b8;border:none;padding:5px 6px;font-size:13px;font-weight:600;margin:2px;cursor:pointer;">
                                                    <i class="fa-solid fa-circle-check"></i> Completed
                                                </button>
                                            </form>
                                        }
                                        @if (item.StatusID != 5)
                                        {
                                            <form asp-controller="Patients" asp-action="Reject" asp-route-id="@item.PatientID" method="post" style="display:inline">
                                                @Html.AntiForgeryToken()
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @* ===== Pagination ===== *@
            @if (totalPages > 1)
            {
                <nav class="mt-3">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(pageNumber == 1 ? "disabled" : "")">
                            <a class="page-link"
                               href="?page=@(pageNumber - 1)&searchName=@searchName&searchID=@searchID&filterDate=@filterDate&filterTime=@filterTime&filterStatus=@filterStatus">←</a>
                        </li>
                        @for (int p = 1; p <= totalPages; p++)
                        {
                            <li class="page-item @(p == pageNumber ? "active" : "")">
                                <a class="page-link"
                                   href="?page=@p&searchName=@searchName&searchID=@searchID&filterDate=@filterDate&filterTime=@filterTime&filterStatus=@filterStatus"
                                   style="border-radius:0 !important;border:none !important;box-shadow:none !important;font-weight:600;">
                                    @p
                                </a>
                            </li>
                        }
                        <li class="page-item @(pageNumber == totalPages ? "disabled" : "")">
                            <a class="page-link"
                               href="?page=@(pageNumber + 1)&searchName=@searchName&searchID=@searchID&filterDate=@filterDate&filterTime=@filterTime&filterStatus=@filterStatus">→</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

<!-- ✅ Attendance Modal -->
<div class="modal fade" id="attendanceModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header" style="background:#1a237e;">
                <h5 class="modal-title fw-bold text-white">
                    <i class="fa-solid fa-user-check me-2"></i>Patient Attendance
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <div style="font-size:1rem; font-weight:600; color:#1a237e; margin-bottom:8px;">
                    Did the patient show up?
                </div>
                <div id="attendancePatientName" style="font-size:.85rem; color:#888; margin-bottom:16px;">—</div>
                <div style="display:flex; gap:12px; justify-content:center;">
                    <button id="btnYesAttended"
                            style="background:#1a237e; color:#fff; border:none; padding:10px 28px; font-weight:700; border-radius:6px; cursor:pointer; font-size:.9rem;">
                        <i class="fa-solid fa-check me-1"></i> Yes
                    </button>
                    <button id="btnNoAttended"
                            style="background:#fff; color:#c0392b; border:2px solid #c0392b; padding:10px 28px; font-weight:700; border-radius:6px; cursor:pointer; font-size:.9rem;">
                        <i class="fa-solid fa-xmark me-1"></i> No
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let _attendancePatientId = null;
    let _isSubmitting        = false;

    function checkAttendance(patientId, patientName, attendanceStatus, userRole) {
        if (userRole === 'Receptionist') {
            alert("⛔ You don't have permission to view patient details.");
            return;
        }
        if (attendanceStatus === 'NoShow') {
            alert("This patient did not attend. You cannot open details.");
            return;
        }
        if (attendanceStatus === 'Attended') {
            window.location.href = `/Patients/Details/${patientId}`;
            return;
        }

        _attendancePatientId = patientId;
        document.getElementById('attendancePatientName').textContent = patientName;

        const modalEl = document.getElementById('attendanceModal');
        const modal   = new bootstrap.Modal(modalEl);

        document.getElementById('btnYesAttended').disabled = false;
        document.getElementById('btnNoAttended').disabled  = false;
        _isSubmitting = false;

        modal.show();
    }

    document.getElementById('btnYesAttended').addEventListener('click', async function () {
        if (!_attendancePatientId || _isSubmitting) return;
        _isSubmitting = true;
        this.disabled = true;
        document.getElementById('btnNoAttended').disabled = true;

        try {
            await fetch('/Appointments/MarkAttendance', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: `patientId=${_attendancePatientId}&status=Attended`
            });
            window.location.href = `/Patients/Details/${_attendancePatientId}`;
        } catch (err) {
            console.error(err);
            alert('Something went wrong');
            _isSubmitting = false;
        }
    });

    document.getElementById('btnNoAttended').addEventListener('click', async function () {
        if (!_attendancePatientId || _isSubmitting) return;
        _isSubmitting = true;
        this.disabled = true;
        document.getElementById('btnYesAttended').disabled = true;

        try {
            await fetch('/Appointments/MarkAttendance', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: `patientId=${_attendancePatientId}&status=NoShow`
            });
            bootstrap.Modal.getInstance(document.getElementById('attendanceModal')).hide();
            location.reload();
        } catch (err) {
            console.error(err);
            alert('Something went wrong');
            _isSubmitting = false;
        }
    });
</script>
