@model IEnumerable<DentalCollegeManagementSystem_AAU.Models.Patient>

@{
    ViewData["Title"] = "Patients";

    var userRole = Context.Session.GetString("UserRole") ?? "";

    int pageSize = 10;
    int pageNumber = Context.Request.Query.ContainsKey("page")
        ? int.Parse(Context.Request.Query["page"]) : 1;

    string searchName = Context.Request.Query["searchName"].ToString().Trim().ToLower();
    string searchID = Context.Request.Query["searchID"].ToString().Trim().ToLower();
    string filterDate = Context.Request.Query["filterDate"].ToString().Trim();
    string filterTime = Context.Request.Query["filterTime"].ToString().Trim();
    string filterStatus = Context.Request.Query["filterStatus"].ToString().Trim();

    var filtered = Model.AsEnumerable();

    if (!string.IsNullOrEmpty(searchName))
        filtered = filtered.Where(p =>
            (p.FirstName + " " + p.SecondName + " " + p.ThirdName + " " + p.FourthName)
            .ToLower().Contains(searchName));

    if (!string.IsNullOrEmpty(searchID))
        filtered = filtered.Where(p =>
            p.NationalID_PassportNumber != null &&
            p.NationalID_PassportNumber.ToLower().Contains(searchID));

    if (!string.IsNullOrEmpty(filterDate) && DateTime.TryParse(filterDate, out DateTime parsedDate))
        filtered = filtered.Where(p =>
            p.AppointmentDate != null &&
            p.AppointmentDate.Date == parsedDate.Date);

    if (!string.IsNullOrEmpty(filterTime))
        filtered = filtered.Where(p =>
            p.AppointmentTime != null &&
            p.AppointmentTime.StartsWith(filterTime, StringComparison.OrdinalIgnoreCase));

    if (!string.IsNullOrEmpty(filterStatus))
    {
        if (filterStatus == "Screening")
            filtered = filtered.Where(p => p.PatientStatus == "Screening"
                                        || string.IsNullOrEmpty(p.PatientStatus));
        else
            filtered = filtered.Where(p => p.PatientStatus == filterStatus);
    }

    int totalItems = filtered.Count();
    int totalPages = (int)Math.Ceiling((double)totalItems / pageSize);
    var pagedModel = filtered.OrderByDescending(p => p.PatientID)
                              .Skip((pageNumber - 1) * pageSize)
                              .Take(pageSize)
                              .ToList();

    var nextApptMap = ViewBag.NextAppointments as Dictionary<int, DentalCollegeManagementSystem_AAU.Models.Appointment>
                     ?? new Dictionary<int, DentalCollegeManagementSystem_AAU.Models.Appointment>();
}

<link rel="stylesheet" href="~/css/Site.css" />
<link rel="stylesheet" href="~/css/RTE.css" />

<style>
    .badge {
        border-radius: 0;
    }

    .active-filters {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 14px;
    }

    .filter-tag {
        background: #e8eaf6;
        color: #252468;
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .next-appt-badge {
        background: #e8eaf6;
        color: #1a237e;
        border-radius: 4px;
        padding: 3px 8px;
        font-size: .75rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .next-appt-none {
        color: #bbb;
        font-size: .78rem;
    }

    .vt-cancel-btn {
        background: #fff;
        color: #555;
        border: 1px solid #d0d7e3;
        border-radius: 6px;
        padding: 9px 20px;
        font-size: .88rem;
        font-weight: 500;
        cursor: pointer;
    }

    .attendance-pending-badge {
        background: #fff3cd;
        color: #856404;
        border: 1px solid #ffc107;
        border-radius: 4px;
        padding: 2px 8px;
        font-size: .72rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .attendance-attended-badge {
        background: #d1e7dd;
        color: #0f5132;
        border: 1px solid #a3cfbb;
        border-radius: 4px;
        padding: 2px 8px;
        font-size: .72rem;
        font-weight: 700;
    }

    .attendance-noshow-badge {
        background: #f8d7da;
        color: #842029;
        border: 1px solid #f5c2c7;
        border-radius: 4px;
        padding: 2px 8px;
        font-size: .72rem;
        font-weight: 700;
    }
</style>

@* ===== Toast ===== *@
@if (TempData["Success"] != null)
{
    <div id="successToast" style="
        position:fixed; bottom:30px; right:30px;
        background-color:#28a745; color:white;
        padding:16px 25px; border-radius:10px;
        font-weight:600; font-size:15px;
        box-shadow:0 8px 20px rgba(0,0,0,0.2);
        z-index:9999; opacity:1; transition:opacity 1s ease;">
        @TempData["Success"]
    </div>
    <script>
        setTimeout(function () {
            var t = document.getElementById('successToast');
            t.style.opacity = '0';
            setTimeout(function () { t.style.display = 'none'; }, 1000);
        }, 3000);
    </script>
}

@* ===== OVERVIEW Title ===== *@
<div>
    <section id="title-wrapper" style="justify-content:End;">
        <div class="lineleft"></div>
        <h1 class="sectiontitle heading6">
            <p style="text-align:center;"><span style="color:#252468;">OVERVIEW</span></p>
        </h1>
        <div class="lineright" style="display:block; background-color:#daa328;"></div>
    </section>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@* ===== Counter Cards ===== *@
