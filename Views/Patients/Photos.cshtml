@model DentalCollegeManagementSystem_AAU.Models.Patient
@using DentalCollegeManagementSystem_AAU.Models

@{
    var extraoralPhotos = ViewBag.ExtraoralPhotos as List<ExtraoralExamPhoto> ?? new();
    var intraoralPhotos = ViewBag.IntraoralPhotos as List<IntraoralExamPhoto> ?? new();
    var radiographs     = ViewBag.Radiographs     as List<Radiograph>         ?? new();
    var patientPhotos   = ViewBag.PatientPhotos   as List<PatientPhoto>       ?? new();

    var extraoralSections = new (string Key, string Label, string Icon)[]
    {
        ("right",         "Right Side",         "◀"),
        ("frontal",       "Frontal Side",       "👤"),
        ("left",          "Left Side",          "▶"),
        ("right_smile",   "Right Side Smile",   "😊"),
        ("frontal_smile", "Frontal Side Smile", "😁"),
        ("left_smile",    "Left Side Smile",    "😄"),
        ("other",         "Other",              "📷"),
    };

    var intraoralSections = new (string Key, string Label, string Icon)[]
    {
        ("right_lateral", "Right Side",  "▶"),
        ("anterior",      "Anterior",    "😬"),
        ("left_lateral",  "Left Side",   "◀"),
        ("upper_arch",    "Upper Jaw",   "⬆️"),
        ("other",         "Other",       "📷"),
        ("lower_arch",    "Lower Jaw",   "⬇️"),
    };
}

<style>
    :root {
        --vt-navy:     #1a237e;
        --vt-navy-mid: #283593;
        --vt-border:   #d0d7e3;
    }

    .ph-section-wrapper {
        background: #fff;
        border: 1.5px solid var(--vt-border);
        border-radius: 10px;
        padding: 22px 24px 18px;
        margin-bottom: 24px;
    }
    .ph-section-title {
        font-weight: 700; font-size: 1rem;
        color: var(--vt-navy); margin-bottom: 16px;
        display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    }

    .ph-flat-gallery { display: flex; flex-wrap: wrap; gap: 14px; padding: 4px 2px 8px; }

    .ph-photo-card {
        flex-shrink: 0; width: 165px;
        border-radius: 10px; border: 1px solid var(--vt-border);
        overflow: hidden; background: #fff; cursor: pointer;
        position: relative; transition: box-shadow .2s, transform .15s;
        display: flex; flex-direction: column;
    }
    .ph-photo-card:hover {
        box-shadow: 0 4px 18px rgba(26,35,126,.13);
        transform: translateY(-2px);
    }
    .ph-img-wrap {
        width: 165px; height: 118px;
        overflow: hidden; position: relative; flex-shrink: 0;
    }
    .ph-img-wrap img {
        width: 100%; height: 100%;
        object-fit: cover; display: block; transition: transform .2s;
    }
    .ph-photo-card:hover .ph-img-wrap img { transform: scale(1.05); }

    .ph-type-pill {
        position: absolute; top: 7px; left: 7px;
        background: rgba(26,35,126,.78);
        color: #fff; font-size: 10px; font-weight: 600;
        padding: 2px 9px; border-radius: 20px;
        pointer-events: none; letter-spacing: .02em;
        white-space: nowrap; max-width: 90%;
        overflow: hidden; text-overflow: ellipsis;
    }
    .ph-photo-info {
        padding: 10px 11px 12px; border-top: 1px solid #eee;
        background: #fff; display: flex; flex-direction: column; gap: 5px;
    }
    .ph-info-row { display: flex; align-items: center; gap: 7px; }
    .ph-icon-sq {
        width: 16px; height: 16px; border-radius: 4px;
        background: #f5f5f5; border: 1px solid #e8e8e8;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .ph-info-divider { height: 1px; background: #f0f0f0; margin: 1px 0; }
    .ph-info-section-name {
        font-size: 12px; font-weight: 700; color: #1a1a2e;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1;
    }
    .ph-info-date { font-size: 11px; color: #666; white-space: nowrap; }
    .ph-source-tag {
        display: inline-flex; align-items: center; gap: 4px;
        font-size: 10px; font-weight: 600;
        background: #f5f5f5; color: #888;
        padding: 2px 8px; border-radius: 20px; border: 1px solid #e8e8e8;
        width: fit-content; white-space: nowrap;
        overflow: hidden; text-overflow: ellipsis; max-width: 100%;
    }
    .ph-info-notes {
        font-size: 10px; color: #999;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-style: italic;
    }
    .ph-lock-icon {
        position: absolute; top: 5px; right: 5px;
        background: rgba(0,0,0,.35); border-radius: 50%;
        width: 20px; height: 20px;
        display: flex; align-items: center; justify-content: center;
        font-size: 10px; color: #fff;
        opacity: 0; transition: opacity .2s; pointer-events: none;
    }
    .ph-photo-card:hover .ph-lock-icon { opacity: 1; }
    .ph-delete-btn {
        position: absolute; top: 5px; right: 5px;
        background: rgba(192,57,43,.85); border: none; border-radius: 50%;
        width: 24px; height: 24px; color: white; font-size: 13px;
        cursor: pointer; display: flex; align-items: center; justify-content: center;
        opacity: 0; transition: opacity .2s; z-index: 3;
    }
    .ph-photo-card:hover .ph-delete-btn { opacity: 1; }
    .ph-empty { font-size: .82rem; color: #aaa; font-style: italic; padding: 8px 4px; }

    .ph-add-btn {
        background: var(--vt-navy); color: #fff; border: none;
        padding: 9px 22px; font-size: .9rem; font-weight: 700;
        cursor: pointer; border-radius: 0px 8px 8px; transition: background .15s;
    }
    .ph-add-btn:hover { background: var(--vt-navy-mid); }
    .vt-cancel-btn {
        background: #fff; color: #555; border: 1px solid var(--vt-border);
        border-radius: 6px; padding: 9px 20px; font-size: .88rem; cursor: pointer;
    }
    .vt-cancel-btn:hover { border-color: #e53935; color: #e53935; }
    .vt-modal-save-btn {
        background: #daa328; color: #fff; border: none;
        border-radius: 0px 8px 8px; padding: 9px 28px;
        font-size: .88rem; font-weight: 700; cursor: pointer; position: relative;
    }
    .vt-modal-save-btn::after {
        content: ''; position: absolute;
        border-right: 4px solid #252468; border-bottom: 4px solid #252468;
        right: -3px; bottom: -3px; width: 8px; height: 8px;
    }
    .ph-upload-zone {
        border: 2px dashed #ccc; border-radius: 8px; padding: 20px;
        text-align: center; cursor: pointer;
        transition: border-color .2s, background .2s; margin-top: 12px;
    }
    .ph-upload-zone:hover { border-color: var(--vt-navy); background: #f8f8ff; }
    .ph-upload-zone p { font-size: .8rem; color: #888; margin: 6px 0 10px; }
    .ph-upload-btn {
        background: var(--vt-navy); color: #fff; border: none;
        border-radius: 4px; padding: 6px 16px; font-size: .8rem; cursor: pointer;
    }

    /* ══ LIGHTBOX ══ */
    #ph-lightbox {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.92);
        z-index: 999999;
        display: flex;
        align-items: center;
        justify-content: center;
        visibility: hidden;
        opacity: 0;
        pointer-events: none;
        transition: opacity .2s ease;
    }
    #ph-lightbox.open {
        visibility: visible;
        opacity: 1;
        pointer-events: all;
    }
    #ph-lightbox-img {
        max-width: 82vw; max-height: 84vh;
        border-radius: 8px; object-fit: contain;
        box-shadow: 0 8px 40px rgba(0,0,0,.5); user-select: none;
    }
    #ph-lightbox-close {
        position: absolute; top: 20px; right: 24px;
        color: #fff; font-size: 32px; cursor: pointer;
        background: none; border: none; z-index: 2;
    }
    #ph-prev-btn, #ph-next-btn {
        position: absolute; top: 50%; transform: translateY(-50%);
        background: rgba(255,255,255,.15); color: #fff; border: none;
        font-size: 28px; padding: 14px 20px; cursor: pointer;
        border-radius: 6px; transition: background .2s; z-index: 2;
    }
    #ph-prev-btn { left: 20px; }
    #ph-next-btn { right: 20px; }
    #ph-prev-btn:hover, #ph-next-btn:hover { background: rgba(255,255,255,.3); }
    #ph-lightbox-caption {
        position: absolute; bottom: 48px; left: 50%; transform: translateX(-50%);
        color: #ddd; font-size: .78rem; background: rgba(0,0,0,.45);
        padding: 4px 16px; border-radius: 20px;
        white-space: nowrap; max-width: 78vw; overflow: hidden; text-overflow: ellipsis;
    }
    #ph-lightbox-counter {
        position: absolute; bottom: 18px; left: 50%; transform: translateX(-50%);
        color: #fff; font-size: .82rem; background: rgba(0,0,0,.5);
        padding: 4px 16px; border-radius: 20px; user-select: none;
    }
</style>

@{
    string iconPerson = @"<svg width=""9"" height=""9"" viewBox=""0 0 24 24"" fill=""none"" stroke=""#555"" stroke-width=""2.5"">
        <path d=""M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2""/><circle cx=""12"" cy=""7"" r=""4""/></svg>";

    string iconCal = @"<svg width=""9"" height=""9"" viewBox=""0 0 24 24"" fill=""none"" stroke=""#555"" stroke-width=""2.5"">
        <rect x=""3"" y=""4"" width=""18"" height=""18"" rx=""2""/>
        <line x1=""16"" y1=""2"" x2=""16"" y2=""6""/><line x1=""8"" y1=""2"" x2=""8"" y2=""6""/>
        <line x1=""3"" y1=""10"" x2=""21"" y2=""10""/></svg>";

    string iconFile = @"<svg width=""9"" height=""9"" viewBox=""0 0 24 24"" fill=""none"" stroke=""#555"" stroke-width=""2.5"">
        <path d=""M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z""/>
        <polyline points=""14 2 14 8 20 8""/></svg>";

    string iconInfo = @"<svg width=""8"" height=""8"" viewBox=""0 0 24 24"" fill=""none"" stroke=""currentColor"" stroke-width=""2.5"">
        <circle cx=""12"" cy=""12"" r=""10""/>
        <line x1=""12"" y1=""8"" x2=""12"" y2=""12""/>
        <line x1=""12"" y1=""16"" x2=""12.01"" y2=""16""/></svg>";
}

<div class="vt-container">

    <!-- ══ 1. EXTRAORAL PHOTOS ══ -->
    <div class="ph-section-wrapper" id="ph_extraoralWrapper">
        <div class="ph-section-title">Extraoral Photos</div>
        @if (!extraoralPhotos.Any())
        {
            <p class="ph-empty" id="ph_extraoralEmpty">No extraoral photos yet.</p>
        }
        else
        {
            <div class="ph-flat-gallery" id="ph_extraoralGallery">
                @foreach (var p in extraoralPhotos)
                {
                    var sec     = extraoralSections.FirstOrDefault(s => s.Key == p.PhotoSection);
                    var caption = $"{sec.Label} · {p.UploadedDate:dd/MM/yyyy}";
                    <div class="ph-photo-card"
                         id="ph_eePhoto_@p.ExtraoralExamPhotoID"
                         data-group="extraoral"
                         data-caption="@caption"
                         onclick="openLightbox('@p.PhotoPath', 'extraoral', '@caption')">
                        <div class="ph-img-wrap">
                            <img src="@p.PhotoPath" alt="@sec.Label" />
                            <div class="ph-type-pill">@sec.Label</div>
                            <div class="ph-lock-icon">🔒</div>
                        </div>
                        <div class="ph-photo-info">
                            <div class="ph-info-row">
                                <div class="ph-icon-sq">@Html.Raw(iconPerson)</div>
                                <span class="ph-info-section-name">@sec.Label</span>
                            </div>
                            <div class="ph-info-divider"></div>
                            <div class="ph-info-row">
                                <div class="ph-icon-sq">@Html.Raw(iconCal)</div>
                                <span class="ph-info-date">@p.UploadedDate.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="ph-source-tag">@Html.Raw(iconInfo) Extraoral Exam</div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- ══ 2. INTRAORAL PHOTOS ══ -->
    <div class="ph-section-wrapper" id="ph_intraoralWrapper">
        <div class="ph-section-title">Intraoral Photos</div>
        @if (!intraoralPhotos.Any())
        {
            <p class="ph-empty" id="ph_intraoralEmpty">No intraoral photos yet.</p>
        }
        else
        {
            <div class="ph-flat-gallery" id="ph_intraoralGallery">
                @foreach (var p in intraoralPhotos)
                {
                    var sec     = intraoralSections.FirstOrDefault(s => s.Key == p.PhotoSection);
                    var caption = $"{sec.Label} · {p.UploadedDate:dd/MM/yyyy}";
                    <div class="ph-photo-card"
                         id="ph_iePhoto_@p.IntraoralExamPhotoID"
                         data-group="intraoral"
                         data-caption="@caption"
                         onclick="openLightbox('@p.PhotoPath', 'intraoral', '@caption')">
                        <div class="ph-img-wrap">
                            <img src="@p.PhotoPath" alt="@sec.Label" />
                            <div class="ph-type-pill">@sec.Label</div>
                            <div class="ph-lock-icon">🔒</div>
                        </div>
                        <div class="ph-photo-info">
                            <div class="ph-info-row">
                                <div class="ph-icon-sq">@Html.Raw(iconPerson)</div>
                                <span class="ph-info-section-name">@sec.Label</span>
                            </div>
                            <div class="ph-info-divider"></div>
                            <div class="ph-info-row">
                                <div class="ph-icon-sq">@Html.Raw(iconCal)</div>
                                <span class="ph-info-date">@p.UploadedDate.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="ph-source-tag">@Html.Raw(iconInfo) Intraoral Exam</div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- ══ 3. RADIOGRAPHS ══ -->
    <div class="ph-section-wrapper" id="ph_radWrapper">
        <div class="ph-section-title">Radiographs</div>
        @if (!radiographs.Any())
        {
            <p class="ph-empty" id="ph_radEmpty">No radiographs uploaded yet.</p>
        }
        else
        {
            <div class="ph-flat-gallery" id="ph_radGallery">
                @foreach (var r in radiographs)
                {
                    var caption = $"{r.RadiographType} · {r.UploadedDate:dd/MM/yyyy HH:mm}";
                    <div class="ph-photo-card"
                         id="ph_rad_@r.RadiographID"
                         data-group="radiograph"
                         data-caption="@caption"
                         onclick="openLightbox('@r.PhotoPath', 'radiograph', '@caption')">
                        <div class="ph-img-wrap">
                            <img src="@r.PhotoPath" alt="@r.RadiographType" />
                            <div class="ph-type-pill">@r.RadiographType</div>
                            <div class="ph-lock-icon">🔒</div>
                        </div>
                        <div class="ph-photo-info">
                            <div class="ph-info-row">
                                <div class="ph-icon-sq">@Html.Raw(iconFile)</div>
                                <span class="ph-info-section-name">@r.FileName</span>
                            </div>
                            <div class="ph-info-divider"></div>
                            <div class="ph-info-row">
                                <div class="ph-icon-sq">@Html.Raw(iconCal)</div>
                                <span class="ph-info-date">@r.UploadedDate.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="ph-source-tag">@Html.Raw(iconInfo) Radiograph</div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- ══ 4. ADDITIONAL PHOTOS ══ -->
    <div class="ph-section-wrapper" id="ph_additionalWrapper">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="ph-section-title mb-0">Additional Photos</div>
            <button class="ph-add-btn"
                    data-bs-toggle="modal"
                    data-bs-target="#addPatientPhotoModal">
                + Add Photo
            </button>
        </div>
        @if (!patientPhotos.Any())
        {
            <p class="ph-empty" id="ppEmpty">No additional photos uploaded yet.</p>
        }
        else
        {
            <div class="ph-flat-gallery" id="patientPhotoGallery">
                @foreach (var p in patientPhotos)
                {
                    var caption = $"{p.FileName} · {p.UploadedDate:dd/MM/yyyy}";
                    <div class="ph-photo-card"
                         id="pp_@p.PatientPhotoID"
                         data-group="additional"
                         data-caption="@caption"
                         onclick="openLightbox('@p.PhotoPath', 'additional', '@caption')">
                        <div class="ph-img-wrap">
                            <img src="@p.PhotoPath" alt="@p.FileName" />
                            <div class="ph-type-pill">Additional</div>
                            <button class="ph-delete-btn"
                                    onclick="deletePatientPhoto(@p.PatientPhotoID, event)"
                                    title="Delete">&#x2715;</button>
                        </div>
                        <div class="ph-photo-info">
                            <div class="ph-info-row">
                                <div class="ph-icon-sq">@Html.Raw(iconFile)</div>
                                <span class="ph-info-section-name">@p.FileName</span>
                            </div>
                            <div class="ph-info-divider"></div>
                            <div class="ph-info-row">
                                <div class="ph-icon-sq">@Html.Raw(iconCal)</div>
                                <span class="ph-info-date">@p.UploadedDate.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="ph-source-tag">@Html.Raw(iconInfo) Additional</div>
                            @if (!string.IsNullOrEmpty(p.Notes))
                            {
                                <span class="ph-info-notes">@p.Notes</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>

</div>

<!-- ══ LIGHTBOX ══ -->
<div id="ph-lightbox" onclick="closeLightboxBackground(event)">
    <button id="ph-lightbox-close"
            onclick="event.stopPropagation(); closeLightbox()">&#x2715;</button>
    <button id="ph-prev-btn"
            onclick="event.stopPropagation(); prevPhoto(event)">&#8592;</button>
    <img id="ph-lightbox-img" src="" alt="" />
    <button id="ph-next-btn"
            onclick="event.stopPropagation(); nextPhoto(event)">&#8594;</button>
    <div id="ph-lightbox-caption"></div>
    <div id="ph-lightbox-counter"></div>
</div>

<!-- ══ ADD PATIENT PHOTO MODAL ══ -->
<div class="modal fade" id="addPatientPhotoModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" style="color:#1a237e;">Add Photo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label style="font-size:.85rem; font-weight:600; color:#555;">Notes (optional)</label>
                    <input type="text" id="ppNotes" class="form-control form-control-sm mt-1"
                           placeholder="e.g. Before treatment..." />
                </div>
                <div class="ph-upload-zone" onclick="document.getElementById('ppFileInput').click()">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none"
                         stroke="#aaa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="17 8 12 3 7 8"/>
                        <line x1="12" y1="3" x2="12" y2="15"/>
                    </svg>
                    <p>Click to select image</p>
                    <button type="button" class="ph-upload-btn">Choose File</button>
                    <input type="file" id="ppFileInput" accept="image/*" style="display:none;"
                           onchange="previewFileName(this,'ppFileName')" />
                </div>
                <div id="ppFileName" style="font-size:.8rem;color:#555;margin-top:8px;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="vt-cancel-btn" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="vt-modal-save-btn" onclick="uploadPatientPhoto()">Upload</button>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<!-- ══ JS — مدمج مباشرة لأن الصفحة partial view ══ -->
<script>
    // تعريف PATIENT_ID و CSRF_TOKEN
    const PATIENT_ID = @Model.PatientID;
    const CSRF_TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

    const _svgPerson = `<svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2.5">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`;
    const _svgCal = `<svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2.5">
        <rect x="3" y="4" width="18" height="18" rx="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/></svg>`;
    const _svgFile = `<svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2.5">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/></svg>`;
    const _svgInfo = `<svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/></svg>`;

    function _buildInfo(nameIcon, nameTxt, dateTxt, sourceLabel, notes = '') {
        return `
    <div class="ph-photo-info">
        <div class="ph-info-row">
            <div class="ph-icon-sq">${nameIcon}</div>
            <span class="ph-info-section-name">${nameTxt}</span>
        </div>
        <div class="ph-info-divider"></div>
        <div class="ph-info-row">
            <div class="ph-icon-sq">${_svgCal}</div>
            <span class="ph-info-date">${dateTxt}</span>
        </div>
        <div class="ph-source-tag">${_svgInfo} ${sourceLabel}</div>
        ${notes ? `<span class="ph-info-notes">${notes}</span>` : ''}
    </div>`;
    }

    // ══ LIGHTBOX ══
    let _lbPhotos   = [];
    let _lbCaptions = [];
    let _lbIndex    = 0;

    function _normUrl(url) {
        try { return new URL(url, location.origin).pathname; }
        catch { return url.split('?')[0]; }
    }

    function openLightbox(clickedSrc, group, caption) {
        const cards = Array.from(
            document.querySelectorAll(`.ph-photo-card[data-group="${group}"]`)
        );
        if (!cards.length) return;

        _lbPhotos   = cards.map(c => { const img = c.querySelector('img'); return img ? img.getAttribute('src') : ''; }).filter(Boolean);
        _lbCaptions = cards.map(c => c.dataset.caption ?? '');

        const clickedPath = _normUrl(clickedSrc);
        _lbIndex = _lbPhotos.findIndex(s => _normUrl(s) === clickedPath);
        if (_lbIndex === -1) _lbIndex = 0;

        if (caption) _lbCaptions[_lbIndex] = caption;

        _updateLB();
        document.getElementById('ph-lightbox').classList.add('open');
        document.addEventListener('keydown', _handleKey);
    }

    function closeLightbox() {
        document.getElementById('ph-lightbox').classList.remove('open');
        document.removeEventListener('keydown', _handleKey);
        _lbPhotos = []; _lbCaptions = [];
    }

    function closeLightboxBackground(e) {
        if (e.target === document.getElementById('ph-lightbox')) closeLightbox();
    }

    function _updateLB() {
        const src = (_lbPhotos[_lbIndex] ?? '').split('?')[0];
        const img     = document.getElementById('ph-lightbox-img');
        const caption = document.getElementById('ph-lightbox-caption');
        const counter = document.getElementById('ph-lightbox-counter');
        if (img)     img.src             = src;
        if (caption) caption.textContent = _lbCaptions[_lbIndex] ?? '';
        if (counter) counter.textContent = _lbPhotos.length > 1 ? `${_lbIndex + 1} / ${_lbPhotos.length}` : '';
    }

    function prevPhoto(e) {
        if (e) { e.stopPropagation(); e.preventDefault(); }
        if (!_lbPhotos.length) return;
        _lbIndex = (_lbIndex - 1 + _lbPhotos.length) % _lbPhotos.length;
        _updateLB();
    }

    function nextPhoto(e) {
        if (e) { e.stopPropagation(); e.preventDefault(); }
        if (!_lbPhotos.length) return;
        _lbIndex = (_lbIndex + 1) % _lbPhotos.length;
        _updateLB();
    }

    function _handleKey(e) {
        if (e.key === 'ArrowLeft')  prevPhoto(null);
        if (e.key === 'ArrowRight') nextPhoto(null);
        if (e.key === 'Escape')     closeLightbox();
    }

    // ══ مزامنة Extraoral ══
    function syncExtraoralFlat(photoPath, label, photoId) {
        const wrapper = document.getElementById('ph_extraoralWrapper');
        if (!wrapper) return false;
        document.getElementById('ph_extraoralEmpty')?.remove();
        let gallery = document.getElementById('ph_extraoralGallery');
        if (!gallery) {
            gallery = document.createElement('div');
            gallery.className = 'ph-flat-gallery';
            gallery.id = 'ph_extraoralGallery';
            wrapper.appendChild(gallery);
        }
        const today = new Date().toLocaleDateString('en-GB');
        const caption = `${label} · ${today}`;
        const card = document.createElement('div');
        card.className = 'ph-photo-card';
        card.id = `ph_eePhoto_${photoId}`;
        card.dataset.group = 'extraoral';
        card.dataset.caption = caption;
        card.setAttribute('onclick', `openLightbox('${photoPath}', 'extraoral', '${caption}')`);
        card.innerHTML = `
            <div class="ph-img-wrap">
                <img src="${photoPath}?t=${Date.now()}" alt="${label}" />
                <div class="ph-type-pill">${label}</div>
                <div class="ph-lock-icon">🔒</div>
            </div>
            ${_buildInfo(_svgPerson, label, today, 'Extraoral Exam')}`;
        gallery.appendChild(card);
        return true;
    }

    // ══ مزامنة Intraoral ══
    function syncIntraoralFlat(photoPath, label, photoId) {
        const wrapper = document.getElementById('ph_intraoralWrapper');
        if (!wrapper) return false;
        document.getElementById('ph_intraoralEmpty')?.remove();
        let gallery = document.getElementById('ph_intraoralGallery');
        if (!gallery) {
            gallery = document.createElement('div');
            gallery.className = 'ph-flat-gallery';
            gallery.id = 'ph_intraoralGallery';
            wrapper.appendChild(gallery);
        }
        const today = new Date().toLocaleDateString('en-GB');
        const caption = `${label} · ${today}`;
