            <input type="hidden" name="PatientID" value="@Model.PatientID" />
            <div id="medications-modal-list"></div>
            <button type="button" onclick="addMedicationRow()"
                    style="background:none; border:1px dashed #252468; color:#252468; padding:8px 18px; font-size:13px; font-weight:600; border-radius:5px; cursor:pointer; margin-top:12px; width:100%;">
                + Add Another Medication
            </button>
            <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:20px;">
                <button type="button" onclick="closeMedicationModal()" style="background:white; color:#555; border:1px solid #ddd; padding:10px 24px; font-size:14px; border-radius:5px; cursor:pointer;">Cancel</button>
                <button type="button" onclick="saveMedications()" style="background:#252468; color:white; border:none; padding:10px 28px; font-size:14px; font-weight:600; border-radius:5px; cursor:pointer;">Save Medications</button>
            </div>
        </form>
    </div>
</div>

<!-- ===== Medication EDIT Modal ===== -->
<div id="editMedicationModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:10px; padding:28px; width:560px; max-width:95vw; max-height:90vh; overflow-y:auto;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
            <h2 style="font-size:16px; font-weight:700; color:#252468; margin:0;">Edit Medication</h2>
            <button onclick="closeEditMedicationModal()" type="button" style="background:none; border:none; font-size:20px; cursor:pointer; color:#888;">✕</button>
        </div>
        <form id="editMedicationForm">
            @Html.AntiForgeryToken()
            <input type="hidden" id="editMedID" name="MedicationID" />
            <div style="margin-bottom:12px;">
                <label style="font-size:12px; font-weight:600; color:#555; display:block; margin-bottom:5px;">Flag Type</label>
                <select id="editMedFlagType" name="FlagType"
                        style="width:100%; border:1px solid #ddd; border-radius:5px; padding:8px 12px; font-size:13px; box-sizing:border-box;">
                    <option value="">-- None --</option>
                    <option value="Anticoagulant">Anticoagulant</option>
                    <option value="Bisphosphonates">Bisphosphonates / Antiresorptive</option>
                    <option value="Steroids">Steroids (Systemic)</option>
                    <option value="Immunosuppressants">Immunosuppressants</option>
                </select>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:12px;">
                <div>
                    <label style="font-size:12px; font-weight:600; color:#555; display:block; margin-bottom:5px;">Drug Name</label>
                    <input type="text" id="editMedDrugName" name="DrugName" style="width:100%; border:1px solid #ddd; border-radius:5px; padding:8px 12px; font-size:13px; box-sizing:border-box;" />
                </div>
                <div>
                    <label style="font-size:12px; font-weight:600; color:#555; display:block; margin-bottom:5px;">Dose</label>
                    <input type="text" id="editMedDose" name="Dose" style="width:100%; border:1px solid #ddd; border-radius:5px; padding:8px 12px; font-size:13px; box-sizing:border-box;" />
                </div>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:20px;">
                <div>
                    <label style="font-size:12px; font-weight:600; color:#555; display:block; margin-bottom:5px;">Frequency</label>
                    <input type="text" id="editMedFrequency" name="Frequency" style="width:100%; border:1px solid #ddd; border-radius:5px; padding:8px 12px; font-size:13px; box-sizing:border-box;" />
                </div>
                <div>
                    <label style="font-size:12px; font-weight:600; color:#555; display:block; margin-bottom:5px;">Duration</label>
                    <input type="text" id="editMedDuration" name="Duration" style="width:100%; border:1px solid #ddd; border-radius:5px; padding:8px 12px; font-size:13px; box-sizing:border-box;" />
                </div>
            </div>
            <div style="display:flex; justify-content:flex-end; gap:10px;">
                <button type="button" onclick="closeEditMedicationModal()" style="background:white; color:#555; border:1px solid #ddd; padding:10px 24px; font-size:13px; border-radius:5px; cursor:pointer;">Cancel</button>
                <button type="button" onclick="submitEditMedication()" id="editMedSaveBtn" style="background:#252468; color:white; border:none; padding:10px 28px; font-size:13px; font-weight:600; border-radius:5px; cursor:pointer;">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/Patientjs/Patient-details.js"></script>
}
