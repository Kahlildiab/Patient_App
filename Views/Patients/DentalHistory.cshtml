@model DentalCollegeManagementSystem_AAU.Models.Patient

@{
    var dh = ViewBag.DentalHistory as DentalCollegeManagementSystem_AAU.Models.DentalHistory;
    var visits = ViewBag.Visits as List<DentalCollegeManagementSystem_AAU.Models.Visit> ?? new List<DentalCollegeManagementSystem_AAU.Models.Visit>();

    var freqCheckup = dh?.FrequencyOfDentalCheckup ?? "";
    var brushFreq = dh?.BrushingFrequency ?? "";
    var brushTech = dh?.BrushingTechnique ?? "";
    var toothbrush = dh?.TypeOfToothbrush ?? "";
    var toothpaste = dh?.TypeOfToothpaste ?? "";
}

@using (Html.BeginForm("Save", "DentalHistories", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="PatientID" value="@Model.PatientID" />
    @if (dh != null)
    {
        <input type="hidden" name="DentalHistoryID" value="@dh.DentalHistoryID" />
    }


    <!-- Visits Details -->
    <div style="border:1.5px solid #252468; border-radius:6px; padding:16px 20px; margin-bottom:16px;">
        <div style="font-weight:700; font-size:14px; color:#252468; margin-bottom:14px;">
            Visits Details
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>AM / PM</th>
                        <th>Attendance</th>
                        <th>Supervisor Approval</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>

                    @if (!visits.Any())
                    {
                        <tr>
                            <td colspan="5" style="text-align:center; color:#777;">
                                No visits yet
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var v in visits)
                        {
                            <tr>
                                <!-- Date -->
                                <td>@v.VisitDate.ToString("yyyy-MM-dd")</td>

                                <!-- AM / PM -->
                                <td>
                                    <span style="font-weight:600; color:#252468;">
                                        @v.AppointmentPeriod
                                    </span>
                                </td>

                                <!-- Attendance -->
                                <td>
                                    @if (v.Attended)
                                    {
                                        <span style="color:green; font-weight:700;">✓ Attended</span>
                                    }
                                    else
                                    {
                                        <span style="color:red; font-weight:700;">✗ Not Attended</span>
                                    }
                                </td>

                                <!-- Supervisor Approval -->
                                <td>
                                    @if (v.IsApproved)
                                    {
                                        <span style="color:green; font-weight:700;">✓ Approved</span>
                                    }
                                    else
                                    {
                                        <span style="color:#e65100; font-weight:700;">⏳ Pending</span>
                                    }
                                </td>

                                <!-- Details Button -->
                                <td style="white-space:nowrap;">
                                    <button type="button"
                                            data-bs-toggle="modal"
                                            data-bs-target="#visitDetailsModal-@v.VisitID"
                                            style="background-color:#252468; border-radius:0px 8px 8px; border:none; padding:7px 20px; color:white; font-weight:700; font-size:13px; cursor:pointer;">
                                        Details
                                    </button>
                                </td>
                            </tr>

                            <!-- ===== DETAILS MODAL ===== -->
                            <div class="modal fade" id="visitDetailsModal-@v.VisitID" tabindex="-1">
                                <div class="modal-dialog modal-lg">
                                    <div class="modal-content">
                                        <div class="modal-header" style="background:#252468;">
                                            <h5 class="modal-title fw-bold text-white">
                                                Visit Details — @v.VisitDate.ToString("dd / MM / yyyy")
                                                @if (!string.IsNullOrWhiteSpace(v.AppointmentPeriod))
                                                {
                                                    <span style="background:#e8eaf6; color:#3949ab; border-radius:4px; padding:1px 8px; font-size:.72rem; font-weight:700; margin-left:8px;">
                                                        @v.AppointmentPeriod
                                                    </span>
                                                }
                                            </h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                        </div>

                                        <div class="modal-body">

                                            @{
                                                bool hasDetails = !string.IsNullOrWhiteSpace(v.ChiefComplaint)
                                                               || !string.IsNullOrWhiteSpace(v.ProceduresPerformed)
                                                               || !string.IsNullOrWhiteSpace(v.MaterialsUsed)
                                                               || !string.IsNullOrWhiteSpace(v.Complications)
                                                               || !string.IsNullOrWhiteSpace(v.StudentNotes);
                                            }

                                            @if (!hasDetails)
                                            {
                                                <!-- لا يوجد ديتيلز -->
                                                <div style="text-align:center; padding:30px 0;">
                                                    <div style="font-size:2.5rem; margin-bottom:10px;">📋</div>
                                                    <div style="font-weight:700; color:#555; font-size:.95rem;">
                                                        No details have been added for this visit yet.
                                                    </div>
                                                    <div style="color:#aaa; font-size:.82rem; margin-top:6px;">
                                                        Use the "Add Details" button to fill in visit information.
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <!-- الديتيلز موجودة -->
                                                <div style="display:flex; flex-direction:column; gap:12px;">

                                                    @if (!string.IsNullOrWhiteSpace(v.ChiefComplaint))
                                                    {
                                                        <div style="background:#f8f9ff; border:1px solid #e0e4f0; border-radius:8px; padding:12px 16px;">
                                                            <div style="font-size:.75rem; color:#78909c; font-weight:600; margin-bottom:4px;">CHIEF COMPLAINT</div>
                                                            <div style="font-weight:600; color:#252468;">@v.ChiefComplaint</div>
                                                        </div>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(v.ProceduresPerformed))
                                                    {
                                                        <div style="background:#f8f9ff; border:1px solid #e0e4f0; border-radius:8px; padding:12px 16px;">
                                                            <div style="font-size:.75rem; color:#78909c; font-weight:600; margin-bottom:4px;">PROCEDURES PERFORMED</div>
                                                            <div style="font-weight:600; color:#252468;">@v.ProceduresPerformed</div>
                                                        </div>
                                                    }

                                                    <div style="display:flex; gap:12px; flex-wrap:wrap;">
                                                        @if (!string.IsNullOrWhiteSpace(v.MaterialsUsed))
                                                        {
                                                            <div style="flex:1; min-width:200px; background:#f8f9ff; border:1px solid #e0e4f0; border-radius:8px; padding:12px 16px;">
                                                                <div style="font-size:.75rem; color:#78909c; font-weight:600; margin-bottom:4px;">MATERIALS USED</div>
                                                                <div style="font-weight:600; color:#252468;">@v.MaterialsUsed</div>
                                                            </div>
                                                        }
                                                        @if (!string.IsNullOrWhiteSpace(v.Complications))
                                                        {
                                                            <div style="flex:1; min-width:200px; background:#fff8f8; border:1px solid #ffcdd2; border-radius:8px; padding:12px 16px;">
                                                                <div style="font-size:.75rem; color:#e57373; font-weight:600; margin-bottom:4px;">COMPLICATIONS / ISSUES</div>
                                                                <div style="font-weight:600; color:#c62828;">@v.Complications</div>
                                                            </div>
                                                        }
                                                    </div>

                                                    @if (!string.IsNullOrWhiteSpace(v.StudentNotes))
                                                    {
                                                        <div style="background:#fffde7; border:1px solid #fff176; border-radius:8px; padding:12px 16px;">
                                                            <div style="font-size:.75rem; color:#f9a825; font-weight:600; margin-bottom:4px;">STUDENT NOTES</div>
                                                            <div style="font-weight:600; color:#555;">@v.StudentNotes</div>
                                                        </div>
                                                    }

                                                    <!-- Supervisor -->
                                                    @if (v.IsApproved)
                                                    {
                                                        <div style="background:#e8f5e9; border:1px solid #a5d6a7; border-radius:8px; padding:12px 16px; display:flex; align-items:center; gap:8px;">
                                                            <span style="font-size:1.1rem;">✅</span>
                                                            <div>
                                                                <span style="font-weight:700; color:#2e7d32;">Approved by @v.ApprovedBy</span>
                                                                <span style="color:#555; font-size:.82rem; margin-left:8px;">on @v.ApprovedDate?.ToString("dd-MM-yyyy")</span>
                                                                @if (!string.IsNullOrWhiteSpace(v.SupervisorComments))
                                                                {
                                                                    <div style="font-size:.82rem; color:#555; margin-top:4px;">"@v.SupervisorComments"</div>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div style="background:#fff8e1; border:1px solid #ffe082; border-radius:8px; padding:12px 16px; color:#e65100; font-weight:600; font-size:.85rem;">
                                                            ⚠️ Pending supervisor approval.
                                                        </div>
                                                    }

                                                </div>
                                            }

                                        </div>

                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- ===== END DETAILS MODAL ===== -->
                        }
                    }

                </tbody>
            </table>
        </div>
    </div>

    <!-- Previous Dental Attendance -->
    <div style="border:1px solid #ddd; border-radius:4px; padding:16px 20px; margin-bottom:12px;">
        <div style="font-weight:700; font-size:13px; color:#252468; margin-bottom:12px;">Previous Dental Attendance</div>
        <div style="display:flex; align-items:center; gap:16px; font-size:13px;">
            <label style="font-weight:600; color:#333; min-width:200px;">Frequency of Dental Checkup</label>
            <select name="FrequencyOfDentalCheckup" style="flex:1; border:1px solid #ddd; border-radius:4px; padding:7px 12px; font-size:13px;">
                <option value="">Select...</option>
                <option value="Every 6 months" selected="@(freqCheckup == "Every 6 months" ? "selected" : null)">Every 6 months</option>
                <option value="Once a year" selected="@(freqCheckup == "Once a year" ? "selected" : null)">Once a year</option>
                <option value="Every 2 years" selected="@(freqCheckup == "Every 2 years" ? "selected" : null)">Every 2 years</option>
                <option value="Only when in pain" selected="@(freqCheckup == "Only when in pain" ? "selected" : null)">Only when in pain</option>
                <option value="Never" selected="@(freqCheckup == "Never" ? "selected" : null)">Never</option>
            </select>
        </div>
    </div>

    <!-- Oral Hygiene Practice -->
    <div style="border:1px solid #ddd; border-radius:4px; padding:16px 20px; margin-bottom:24px;">
        <div style="font-weight:700; font-size:13px; color:#252468; margin-bottom:14px;">Oral Hygiene Practice</div>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:14px;">
            <div>
                <label style="font-size:12px; font-weight:600; color:#333; display:block; margin-bottom:5px;">Brushing Frequency</label>
                <select name="BrushingFrequency" style="width:100%; border:1px solid #ddd; border-radius:4px; padding:7px 12px; font-size:13px;">
                    <option value="">Select...</option>
                    <option value="Once daily" selected="@(brushFreq == "Once daily" ? "selected" : null)">Once daily</option>
                    <option value="Twice daily" selected="@(brushFreq == "Twice daily" ? "selected" : null)">Twice daily</option>
                    <option value="After each meal" selected="@(brushFreq == "After each meal" ? "selected" : null)">After each meal</option>
                    <option value="Irregular" selected="@(brushFreq == "Irregular" ? "selected" : null)">Irregular</option>
                </select>
            </div>
           @*  <div>
                <label style="font-size:12px; font-weight:600; color:#333; display:block; margin-bottom:5px;">Brushing Technique</label>
                <select name="BrushingTechnique" style="width:100%; border:1px solid #ddd; border-radius:4px; padding:7px 12px; font-size:13px;">
                    <option value="">Select...</option>
                    <option value="Horizontal scrubbing" selected="@(brushTech == "Horizontal scrubbing" ? "selected" : null)">Horizontal scrubbing</option>
                    <option value="Circular motion" selected="@(brushTech == "Circular motion" ? "selected" : null)">Circular motion</option>
                    <option value="Bass technique" selected="@(brushTech == "Bass technique" ? "selected" : null)">Bass technique</option>
                    <option value="Modified Bass technique" selected="@(brushTech == "Modified Bass technique" ? "selected" : null)">Modified Bass technique</option>
                    <option value="Other" selected="@(brushTech == "Other" ? "selected" : null)">Other</option>
                </select>
            </div> *@
            <div>
                <label style="font-size:12px; font-weight:600; color:#333; display:block; margin-bottom:5px;">Type of Toothbrush</label>
                <select name="TypeOfToothbrush" style="width:100%; border:1px solid #ddd; border-radius:4px; padding:7px 12px; font-size:13px;">
                    <option value="">Select...</option>
                    <option value="Manual - Soft bristles" selected="@(toothbrush == "Manual - Soft bristles" ? "selected" : null)">Manual - Soft bristles</option>
                    <option value="Manual - Medium bristles" selected="@(toothbrush == "Manual - Medium bristles" ? "selected" : null)">Manual - Medium bristles</option>
                    <option value="Manual - Hard bristles" selected="@(toothbrush == "Manual - Hard bristles" ? "selected" : null)">Manual - Hard bristles</option>
                    <option value="Electric" selected="@(toothbrush == "Electric" ? "selected" : null)">Electric</option>
                </select>
            </div>
            <div>
                <label style="font-size:12px; font-weight:600; color:#333; display:block; margin-bottom:5px;">Type of Toothpaste</label>
                <select name="TypeOfToothpaste" style="width:100%; border:1px solid #ddd; border-radius:4px; padding:7px 12px; font-size:13px;">
                    <option value="">Select...</option>
                    <option value="Fluoride" selected="@(toothpaste == "Fluoride" ? "selected" : null)">Fluoride</option>
                    <option value="Whitening" selected="@(toothpaste == "Whitening" ? "selected" : null)">Whitening</option>
                    <option value="Sensitive" selected="@(toothpaste == "Sensitive" ? "selected" : null)">Sensitive</option>
                    <option value="Herbal" selected="@(toothpaste == "Herbal" ? "selected" : null)">Herbal</option>
                    <option value="Other" selected="@(toothpaste == "Other" ? "selected" : null)">Other</option>
                </select>
            </div>
        </div>

        <!-- Adjunctive Hygiene Methods -->
        <div>
            <label style="font-size:12px; font-weight:600; color:#333; display:block; margin-bottom:8px;">Adjunctive Hygiene Methods</label>
            <div style="display:flex; flex-wrap:wrap; gap:20px; font-size:13px;">
                <label style="display:flex; align-items:center; gap:6px; cursor:pointer;">
                    <input type="checkbox" name="DentalFloss" value="true"
                           checked="@(dh?.DentalFloss == true ? "checked" : null)"
                           style="accent-color:#252468;" /> Dental Floss
                </label>
                <label style="display:flex; align-items:center; gap:6px; cursor:pointer;">
                    <input type="checkbox" name="InterdentalBrushes" value="true"
                           checked="@(dh?.InterdentalBrushes == true ? "checked" : null)"
                           style="accent-color:#252468;" /> Interdental Brushes
                </label>
                <label style="display:flex; align-items:center; gap:6px; cursor:pointer;">
                    <input type="checkbox" name="Mouthwash" value="true"
                           checked="@(dh?.Mouthwash == true ? "checked" : null)"
                           style="accent-color:#252468;" /> Mouthwash
                </label>
                <label style="display:flex; align-items:center; gap:6px; cursor:pointer;">
                    <input type="checkbox" name="TongueCleaner" value="true"
                           checked="@(dh?.TongueCleaner == true ? "checked" : null)"
                           style="accent-color:#252468;" /> Tongue Cleaner
                </label>
                <label style="display:flex; align-items:center; gap:6px; cursor:pointer;">
                    <input type="checkbox" name="WaterFlosser" value="true"
                           checked="@(dh?.WaterFlosser == true ? "checked" : null)"
                           style="accent-color:#252468;" /> Water Flosser
                </label>
            </div>
        </div>
    </div>

    <!-- Save Button -->
    <div class="btnwrap" style="padding-bottom:50px; display:flex; justify-content:center;">
        <button type="submit" class="mybtn heading13"
                onclick="return confirm('Are you sure you want to save the changes?')"
                style="background-color:#DAA328; border-radius:0px 10px 10px; width:200px; border:none;">
            Save
            <span class="line" style="border-right:6px solid #252468; border-bottom:6px solid #252468; right:-4px; bottom:-4px; border-top:none; border-left:none;"></span>
            <span class="areaborder" style="border:0px;"></span>
        </button>
    </div>
}

@* ✅ Success Popup *@
@if (TempData["Success"] != null)
{
    <div id="success-overlay" style="position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:99999; display:flex; align-items:center; justify-content:center;">
        <div style="background:white; border-radius:12px; padding:36px 40px; text-align:center; box-shadow:0 8px 40px rgba(0,0,0,0.25); max-width:360px; width:90%;">
            <div style="font-size:52px; margin-bottom:12px;">✅</div>
            <div style="font-weight:700; font-size:18px; color:#252468; margin-bottom:8px;">Saved Successfully!</div>
            <div style="font-size:13px; color:#555; margin-bottom:24px;">The information has been saved successfully.</div>
            <button onclick="document.getElementById('success-overlay').remove()"
                    style="background:#daa328; color:white; border:none; padding:10px 36px; font-size:14px; font-weight:700; border-radius:0px 10px 10px; cursor:pointer; position:relative;">
                OK
                <span style="position:absolute; border-right:4px solid #252468; border-bottom:4px solid #252468; right:-3px; bottom:-3px; width:8px; height:8px;"></span>
            </button>
        </div>
    </div>

    <script>
        setTimeout(() => {
            const el = document.getElementById('success-overlay');
            if (el) {
                el.style.transition = 'opacity 0.4s';
                el.style.opacity = '0';
                setTimeout(() => el.remove(), 400);
            }
        }, 4000);
    </script>
}

<script>
    const FORM_KEY = 'dentalHistoryForm_@Model.PatientID';

    function restoreFormData() {
        const saved = sessionStorage.getItem(FORM_KEY);
        if (!saved) return;
        const data = JSON.parse(saved);

        data.forEach(({ name, value, type, checked }) => {
            // ✅ بنبحث بس داخل dental-history
            const els = document.querySelectorAll(`#dental-history [name="${name}"]`);
            els.forEach(el => {
                if (type === 'radio') {
                    if (el.value === value) el.checked = true;
                } else if (type === 'checkbox') {
                    if (el.value === value) el.checked = checked;
                } else {
                    el.value = value;
                }
            });
        });
    }

    function saveFormData() {
        // ✅ بيمسك فورم الـ Dental History بالتحديد
        const form = document.querySelector('#dental-history form');
        if (!form) return;
        const elements = form.querySelectorAll('input, select, textarea');
        const data = [];

        elements.forEach(el => {
            if (!el.name || el.name === '__RequestVerificationToken'
                || el.name === 'PatientID' || el.name === 'DentalHistoryID') return;
            data.push({
                name: el.name,
                value: el.value,
                type: el.type,
                checked: el.checked
            });
        });

        sessionStorage.setItem(FORM_KEY, JSON.stringify(data));
    }

    function clearSavedData() {
        sessionStorage.removeItem(FORM_KEY);
    }

    document.addEventListener('DOMContentLoaded', function () {
        restoreFormData();

        // ✅ بيمسك فورم الـ Dental History بالتحديد
        const form = document.querySelector('#dental-history form');
        if (!form) return;

        form.addEventListener('change', saveFormData);
        form.addEventListener('input', saveFormData);
        form.addEventListener('submit', clearSavedData);
    });
</script>