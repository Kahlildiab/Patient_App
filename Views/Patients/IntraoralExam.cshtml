@model DentalCollegeManagementSystem_AAU.Models.Patient

@{
    var exam = ViewBag.IntraoralExam as DentalCollegeManagementSystem_AAU.Models.IntraoralExam;
    var oralHygiene = exam?.OralHygieneStatus.ToString() ?? "Excellent";
    var occlusionClass = exam?.OcclusionClassification?.ToString() ?? "";
    var examId = exam?.IntraoralExamID ?? 0;

    var savedPhotos = ViewBag.IntraoralPhotos as List<DentalCollegeManagementSystem_AAU.Models.IntraoralExamPhoto>
                      ?? new List<DentalCollegeManagementSystem_AAU.Models.IntraoralExamPhoto>();


    var photoSections = new (string Key, string Label, string Icon)[]
    {
        ("right_lateral", "Right in Occlusion", "▶"),
        ("anterior",      "Anterior Occlusion",  "😬"),
        ("left_lateral",  "Left Occlusion",      "◀"),
        ("upper_arch",    "Upper Occlusal",      "⬆️"),
        ("lower_arch",    "Lower Occlusal",      "⬇️"),
        ("other",         "Other",               "📷"),
    };

  }

<style>
    .ie-section {
        border: 1px solid #ddd;
        border-radius: 6px;
        padding: 18px 22px;
        margin-bottom: 14px;
        background: #fff;
    }

    .ie-section-title {
        font-weight: 700;
        font-size: 13px;
        color: #252468;
        margin-bottom: 12px;
    }

    .ie-label {
        font-size: 12px;
        font-weight: 600;
        color: #555;
        margin-bottom: 5px;
        display: block;
    }

    .ie-select, .ie-textarea {
        width: 100%;
        border: 1px solid #ddd;
        border-radius: 5px;
        padding: 9px 13px;
        font-size: 13px;
        box-sizing: border-box;
        color: #333;
        outline: none;
        transition: border-color .2s;
        background: #fff;
    }

        .ie-select:focus, .ie-textarea:focus {
            border-color: #252468;
        }

    .ie-textarea {
        resize: vertical;
        min-height: 90px;
    }

    .photo-drop-zone {
        border: 2px dashed #ccc;
        border-radius: 8px;
        padding: 30px 20px;
        text-align: center;
        cursor: pointer;
        transition: border-color .2s, background .2s;
        margin-top: 14px;
    }

        .photo-drop-zone:hover {
            border-color: #252468;
            background: #f8f8ff;
        }

        .photo-drop-zone.drag-over {
            border-color: #252468;
            background: #f0f0ff;
        }

        .photo-drop-zone svg {
            width: 40px;
            height: 40px;
            stroke: #aaa;
            margin-bottom: 8px;
        }

        .photo-drop-zone p {
            font-size: 13px;
            color: #888;
            margin: 0 0 10px;
        }

    .ie-photo-gallery {
        display: flex;
        flex-wrap: nowrap;
        gap: 12px;
        overflow-x: auto;
        padding: 10px 4px 14px;
        scrollbar-width: thin;
        scrollbar-color: #252468 #f0f0f0;
    }

        .ie-photo-gallery::-webkit-scrollbar {
            height: 6px;
        }

        .ie-photo-gallery::-webkit-scrollbar-track {
            background: #f0f0f0;
            border-radius: 3px;
        }

        .ie-photo-gallery::-webkit-scrollbar-thumb {
            background: #252468;
            border-radius: 3px;
        }

    .ie-photo-item {
        position: relative;
        flex-shrink: 0;
        width: 160px;
        height: 160px;
        border-radius: 8px;
        border: 1px solid #ddd;
        overflow: hidden;
        background: #fafafa;
    }

        .ie-photo-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .ie-photo-item .delete-btn {
            position: absolute;
            top: 4px;
            right: 4px;
            background: rgba(192,57,43,0.85);
            border: none;
            border-radius: 50%;
            width: 26px;
            height: 26px;
            color: white;
            font-size: 14px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

    .ie-photo-uploading {
        flex-shrink: 0;
        width: 160px;
        height: 160px;
        border-radius: 8px;
        border: 1px dashed #aaa;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #aaa;
        font-size: 13px;
        gap: 6px;
        background: #fafafa;
    }

    /* ── Pyramid rows ─────────────────────────────────────────────────── */
    .ie-photo-row {
        display: grid;
        gap: 16px;
        margin-bottom: 16px;
    }

    .ie-photo-row-3 {
        grid-template-columns: repeat(3, 1fr);
    }

    .ie-photo-row-2 {
        grid-template-columns: repeat(2, 1fr);
        width: 66.66%;
        margin-left: auto;
        margin-right: auto;
    }

    .ie-photo-row-1 {
        grid-template-columns: 1fr;
        width: 33.33%;
        margin-left: auto;
        margin-right: auto;
    }
    /* ─────────────────────────────────────────────────────────────────── */

    .ie-photo-section-card {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 14px;
        background: #fff;
    }

    .ie-photo-section-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 10px;
    }

    .ie-photo-section-icon {
        font-size: 16px;
    }

    .ie-photo-section-label {
        font-weight: 700;
        font-size: 13px;
        color: #252468;
        flex: 1;
    }

    .ie-photo-section-count {
        font-size: 11px;
        color: #888;
        background: #f0f0f0;
        padding: 2px 8px;
        border-radius: 10px;
    }

    .dz-btn {
        background: #252468;
        color: #fff;
        border: none;
        border-radius: 4px;
        padding: 6px 16px;
        font-size: 12px;
        cursor: pointer;
    }

        .dz-btn:hover {
            background: #1a1a5e;
        }
</style>

@using (Html.BeginForm("Save", "IntraoralExams", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="PatientID" value="@Model.PatientID" />
    @if (exam != null)
    {
        <input type="hidden" name="IntraoralExamID" value="@exam.IntraoralExamID" />
    }

    <!-- ─── Intraoral Examination Findings ─── -->
    <div class="ie-section">
        <div class="ie-section-title">Intraoral Examination Findings</div>

        <div style="margin-bottom:16px;">
            <label class="ie-label">Oral Hygiene Status</label>
            <select name="OralHygieneStatus" class="ie-select">
                <option value="Excellent" selected="@(oralHygiene == "Excellent" ? "selected" : null)">Excellent</option>
                <option value="Good" selected="@(oralHygiene == "Good" ? "selected" : null)">Good</option>
                <option value="Fair" selected="@(oralHygiene == "Fair" ? "selected" : null)">Fair</option>
                <option value="Poor" selected="@(oralHygiene == "Poor" ? "selected" : null)">Poor</option>
            </select>
        </div>

        <div style="margin-bottom:16px;">
            <label class="ie-label">Oral Mucosa</label>
            <textarea name="OralMucosa" class="ie-textarea" placeholder="Describe oral mucosa findings...">@(exam?.OralMucosa ?? "")</textarea>
        </div>

        <div style="margin-bottom:16px;">
            <label class="ie-label">Tongue Examination</label>
            <textarea name="TongueExamination" class="ie-textarea" placeholder="Tongue size, coating, lesions...">@(exam?.TongueExamination ?? "")</textarea>
        </div>

        <div style="margin-bottom:16px;">
            <label class="ie-label">Palate</label>
            <textarea name="Palate" class="ie-textarea" placeholder="Hard and soft palate findings...">@(exam?.Palate ?? "")</textarea>
        </div>

        <div style="margin-bottom:16px;">
            <label class="ie-label">Floor of Mouth</label>
            <textarea name="FloorOfMouth" class="ie-textarea" placeholder="Floor of mouth findings...">@(exam?.FloorOfMouth ?? "")</textarea>
        </div>

        <div style="margin-bottom:16px;">
            <label class="ie-label">Occlusion Classification</label>
            <select name="OcclusionClassification" class="ie-select">
                <option value="">-- Select --</option>
                <option value="ClassI" selected="@(occlusionClass == "ClassI" ? "selected" : null)">Class I</option>
                <option value="ClassIIDivision1" selected="@(occlusionClass == "ClassIIDivision1" ? "selected" : null)">Class II Division 1</option>
                <option value="ClassIIDivision2" selected="@(occlusionClass == "ClassIIDivision2" ? "selected" : null)">Class II Division 2</option>
                <option value="ClassIII" selected="@(occlusionClass == "ClassIII" ? "selected" : null)">Class III</option>
            </select>
        </div>

        <div>
            <label class="ie-label">Other Findings</label>
            <textarea name="OtherFindings" class="ie-textarea" placeholder="Any other relevant intraoral findings...">@(exam?.OtherFindings ?? "")</textarea>
        </div>
    </div>

    <!-- ─── Photo Documentation ─── -->
    <div class="ie-section">
        <div class="ie-section-title">Photo Documentation</div>

        @{
            // Split into pyramid rows
            var row1Keys = new[] { "right_lateral", "anterior", "left_lateral" };
            var row2Keys = new[] { "upper_arch", "lower_arch" };
            var row3Keys = new[] { "other" };

            var rowDefs = new[] {
                (Keys: row1Keys, CssClass: "ie-photo-row-3"),
                (Keys: row2Keys, CssClass: "ie-photo-row-2"),
                (Keys: row3Keys, CssClass: "ie-photo-row-1"),
            };
        }

        @foreach (var rowDef in rowDefs)
        {
            <div class="ie-photo-row @rowDef.CssClass">

                @foreach (var key in rowDef.Keys)
                {
                    var photoSec = photoSections.First(s => s.Key == key);
                    var sectionPhotos = savedPhotos.Where(x => x.PhotoSection == photoSec.Key).ToList();

                    <div class="ie-photo-section-card" id="ieCard_@photoSec.Key">

                        <div class="ie-photo-section-header">
                            <span class="ie-photo-section-label">@photoSec.Label</span>
                            <span class="ie-photo-section-count" id="ieCount_@photoSec.Key">
                                @sectionPhotos.Count photo@(sectionPhotos.Count != 1 ? "s" : "")
                            </span>
                        </div>

                        <div class="ie-photo-gallery" id="iePhotoGallery_@photoSec.Key">
                            @foreach (var p in sectionPhotos)
                            {
                                <div class="ie-photo-item" id="ieExamPhoto_@p.IntraoralExamPhotoID">
                                    <img src="@p.PhotoPath" alt="@photoSec.Label" />
                                    <button type="button" class="delete-btn"
                                            onclick="deleteIEPhoto(@p.IntraoralExamPhotoID, '@photoSec.Key')"
                                            title="Delete">
                                        ✕
                                    </button>
                                </div>
                            }
                        </div>

                        <div class="photo-drop-zone"
                             id="ieDropZone_@photoSec.Key"
                             onclick="document.getElementById('iePhotoInput_@photoSec.Key').click()">
                            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                                      stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                <polyline points="17 8 12 3 7 8"
                                          stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                <line x1="12" y1="3" x2="12" y2="15"
                                      stroke-width="2" stroke-linecap="round" />
                            </svg>
                            <p>Upload @photoSec.Label</p>
                            <button type="button" class="dz-btn">Choose File</button>
                        </div>

                        <input type="file"
                               id="iePhotoInput_@photoSec.Key"
                               accept="image/*"
                               multiple
                               style="display:none;"
                               data-section="@photoSec.Key"
                               onchange="uploadIEPhotos(this, '@photoSec.Key')" />
                    </div>
                }

            </div>
        }

        <div class="ie-photo-sections-grid">

            @foreach (var photoSec in photoSections)
            {
                var sectionPhotos = savedPhotos.Where(x => x.PhotoSection == photoSec.Key).ToList();

                <div class="ie-photo-section-card" id="ieCard_@photoSec.Key">

                    <!-- Section Header -->
                    <div class="ie-photo-section-header">
                        <span class="ie-photo-section-icon">@photoSec.Icon</span>
                        <span class="ie-photo-section-label">@photoSec.Label</span>
                        <span class="ie-photo-section-count" id="ieCount_@photoSec.Key">
                            @sectionPhotos.Count photo@(sectionPhotos.Count != 1 ? "s" : "")
                        </span>
                    </div>

                    <!-- Gallery -->
                    <div class="ie-photo-gallery" id="iePhotoGallery_@photoSec.Key">
                        @foreach (var p in sectionPhotos)
                        {
                            <div class="ie-photo-item" id="iePhoto_@p.IntraoralExamPhotoID">
                                <img src="@p.PhotoPath" alt="@photoSec.Label" />
                                <button type="button" class="delete-btn"
                                        onclick="deleteIEPhoto(@p.IntraoralExamPhotoID, '@photoSec.Key')"
                                        title="Delete">
                                    ✕
                                </button>
                            </div>
                        }
                    </div>

                    <!-- Drop Zone -->
                    <div class="photo-drop-zone"
                         id="ieDropZone_@photoSec.Key"
                         onclick="document.getElementById('iePhotoInput_@photoSec.Key').click()">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                                  stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            <polyline points="17 8 12 3 7 8"
                                      stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            <line x1="12" y1="3" x2="12" y2="15"
                                  stroke-width="2" stroke-linecap="round" />
                        </svg>
                        <p>Upload @photoSec.Label</p>
                        <button type="button" class="dz-btn">Choose File</button>
                    </div>

                    <!-- Hidden file input -->
                    <input type="file"
                           id="iePhotoInput_@photoSec.Key"
                           accept="image/*"
                           multiple
                           style="display:none;"
                           data-section="@photoSec.Key"
                           onchange="uploadIEPhotos(this, '@photoSec.Key')" />
                </div>
            }

        </div>
    </div>

    <div class="btnwrap" style="padding-bottom:50px;display:flex;justify-content:center;">
        <button type="submit" class="mybtn heading13" style="background-color:#DAA328;border-radius:0px 10px 10px;width:200px;border:none;">
            Save
            <span class="line" style="border-right:6px solid #252468;border-bottom:6px solid #252468;right:-4px;bottom:-4px;border-top:none;border-left:none;"></span>
            <span class="areaborder" style="border:0px;"></span>
        </button>
    </div>
}

@if (TempData["Success"] != null)
{
    <div id="ie-success-overlay" style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:99999;display:flex;align-items:center;justify-content:center;">
        <div style="background:white;border-radius:12px;padding:36px 40px;text-align:center;box-shadow:0 8px 40px rgba(0,0,0,0.25);max-width:360px;width:90%;">
            <div style="font-size:52px;margin-bottom:12px;">✅</div>
            <div style="font-weight:700;font-size:18px;color:#252468;margin-bottom:8px;">Saved Successfully!</div>
            <div style="font-size:13px;color:#555;margin-bottom:24px;">The information has been saved successfully.</div>
            <button onclick="document.getElementById('ie-success-overlay').remove()"
                    style="background:#daa328;color:white;border:none;padding:10px 36px;font-size:14px;font-weight:700;border-radius:0px 10px 10px;cursor:pointer;position:relative;">
                OK
                <span style="position:absolute;border-right:4px solid #252468;border-bottom:4px solid #252468;right:-3px;bottom:-3px;width:8px;height:8px;"></span>
            </button>
        </div>
    </div>
    <script>
        setTimeout(() => {
            const el = document.getElementById('ie-success-overlay');
            if (el) { el.style.transition = 'opacity 0.4s'; el.style.opacity = '0'; setTimeout(() => el.remove(), 400); }
        }, 4000);
    </script>
}

<script>
    const IE_FORM_KEY = 'intraoralExamForm_@Model.PatientID';

    // ─── Session Storage ───────────────────────────────────────
    function restoreIEFormData() {
        const saved = sessionStorage.getItem(IE_FORM_KEY);
        if (!saved) return;
        JSON.parse(saved).forEach(({ name, value, type, checked }) => {
            document.querySelectorAll(`form[action*="IntraoralExams"] [name="${name}"]`).forEach(el => {
                if (type === 'file') return;
                if (type === 'radio')         { if (el.value === value) el.checked = true; }
                else if (type === 'checkbox') { if (el.value === value) el.checked = checked; }
                else el.value = value;
            });
        });
    }

    function saveIEFormData() {
        const form = document.querySelector('form[action*="IntraoralExams"]');
        if (!form) return;
        const data = [];
        form.querySelectorAll('input, select, textarea').forEach(el => {
            if (!el.name || el.type === 'file' ||
                ['__RequestVerificationToken', 'PatientID', 'IntraoralExamID'].includes(el.name)) return;
            data.push({ name: el.name, value: el.value, type: el.type, checked: el.checked });
        });
        sessionStorage.setItem(IE_FORM_KEY, JSON.stringify(data));
    }

    // ─── DOM Ready ─────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', function () {
        restoreIEFormData();

        const form = document.querySelector('form[action*="IntraoralExams"]');
        if (!form) return;

        form.addEventListener('change', saveIEFormData);
        form.addEventListener('input',  saveIEFormData);
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            saveIntraoralExam(form);
        });

        document.querySelectorAll('[id^="ieDropZone_"]').forEach(zone => {
            const sectionKey = zone.id.replace('ieDropZone_', '');
            zone.addEventListener('dragover',  e  => { e.preventDefault(); zone.classList.add('drag-over'); });
            zone.addEventListener('dragleave', ()  => { zone.classList.remove('drag-over'); });
            zone.addEventListener('drop',      e  => {
        // تسجيل Drag & Drop لكل قسم
        document.querySelectorAll('.photo-drop-zone').forEach(zone => {
            const sectionKey = zone.id.replace('ieDropZone_', '');

            zone.addEventListener('dragover', e => {
                e.preventDefault();
                zone.classList.add('drag-over');
            });
            zone.addEventListener('dragleave', () => {
                zone.classList.remove('drag-over');
            });
            zone.addEventListener('drop', e => {
                e.preventDefault();
                zone.classList.remove('drag-over');
                const input = document.getElementById(`iePhotoInput_${sectionKey}`);
                if (input && e.dataTransfer.files.length) {
                    const dt = new DataTransfer();
                    Array.from(e.dataTransfer.files).forEach(f => dt.items.add(f));
                    input.files = dt.files;
                    uploadIEPhotos(input, sectionKey);
                }
            });
        });
    });

    // ─── Save Exam (AJAX) ──────────────────────────────────────
    function saveIntraoralExam(form) {
        const saveBtn = form.querySelector('button[type="submit"]');
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';

        fetch('/IntraoralExams/SaveAjax', { method: 'POST', body: new FormData(form) })
            .then(res => res.json())
            .then(result => {
                if (result.success) {
                    sessionStorage.removeItem(IE_FORM_KEY);
                    showToast('Intraoral Exam saved successfully.', 'success');
                    if (result.examId) {
                        let h = form.querySelector('[name="IntraoralExamID"]');

                        if (!h) { h = document.createElement('input'); h.type = 'hidden'; h.name = 'IntraoralExamID'; form.appendChild(h); }

                        if (!h) {
                            h = document.createElement('input');
                            h.type = 'hidden'; h.name = 'IntraoralExamID';
                            form.appendChild(h);
                        }

                        h.value = result.examId;
                    }
                } else {
                    showToast(result.message || 'Error saving.', 'error');
                }
            })
            .catch(() => showToast('Server error.', 'error'))
            .finally(() => { saveBtn.disabled = false; saveBtn.innerHTML = 'Save'; });
    }



    // ─── Upload Photos (per section) ──────────────────────────

    function uploadIEPhotos(input, sectionKey) {
        if (!input.files || input.files.length === 0) return;

        const token   = document.querySelector('form[action*="IntraoralExams"] [name="__RequestVerificationToken"]')?.value ?? '';
        const gallery = document.getElementById(`iePhotoGallery_${sectionKey}`);
        if (!gallery) return;

        Array.from(input.files).forEach(file => {

            const spinnerId = `ie_spinner_${Date.now()}_${Math.random().toString(36).slice(2)}`;

            // Spinner placeholder
            const spinnerId = `spinner_${Date.now()}_${Math.random().toString(36).slice(2)}`;

            const spinnerEl = document.createElement('div');
            spinnerEl.className = 'ie-photo-uploading';
            spinnerEl.id = spinnerId;
            spinnerEl.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i><span>Uploading...</span>`;
            gallery.appendChild(spinnerEl);

            const formData = new FormData();
            formData.append('patientId',    '@Model.PatientID');
            formData.append('photo',        file);
            formData.append('photoSection', sectionKey);
            formData.append('__RequestVerificationToken', token);

            fetch('/IntraoralExams/UploadPhotoAjax', { method: 'POST', body: formData })
                .then(res => res.json())
                .then(result => {
                    document.getElementById(spinnerId)?.remove();

                    if (result.success) {
                        const form = document.querySelector('form[action*="IntraoralExams"]');
                        let h = form.querySelector('[name="IntraoralExamID"]');
                        if (!h) { h = document.createElement('input'); h.type = 'hidden'; h.name = 'IntraoralExamID'; form.appendChild(h); }
                        h.value = result.examId;

                        const item = document.createElement('div');
                        item.className = 'ie-photo-item';
                        item.id = `ieExamPhoto_${result.photoId}`;
                        item.innerHTML = `
                            <img src="${result.photoPath}" alt="${sectionKey}" />
                            <button type="button" class="delete-btn"
                                    onclick="deleteIEPhoto(${result.photoId}, '${sectionKey}')"
                                    title="Delete">✕</button>`;
                        gallery.appendChild(item);
                        item.scrollIntoView({ behavior: 'smooth', inline: 'end' });

                        updateIESectionCount(sectionKey);
                        syncPhotoToPhotosTab('ie', sectionKey, result.photoPath, result.photoId);
                    if (result.success) {
                        const form = document.querySelector('form[action*="IntraoralExams"]');
                        let h = form.querySelector('[name="IntraoralExamID"]');
                        if (!h) {
                            h = document.createElement('input');
                            h.type = 'hidden'; h.name = 'IntraoralExamID';
                            form.appendChild(h);
                        }
                        h.value = result.examId;

                        const item = document.createElement('div');
                        item.className = 'ie-photo-item';
                        item.id = `iePhoto_${result.photoId}`;
                        item.innerHTML = `
                            <img src="${result.photoPath}" alt="${sectionKey}" />
                            <button type="button" class="delete-btn"
                                    onclick="deleteIEPhoto(${result.photoId}, '${sectionKey}')"
                                    title="Delete">✕</button>`;
                        gallery.appendChild(item);
                        item.scrollIntoView({ behavior: 'smooth', inline: 'end' });

                        updateIESectionCount(sectionKey);

                        showToast('Photo uploaded.', 'success');
                    } else {
                        showToast('Failed to upload: ' + file.name, 'error');
                    }
                })
                .catch(() => {
                    document.getElementById(spinnerId)?.remove();
                    showToast('Server error uploading: ' + file.name, 'error');
                });
        });

        input.value = '';
    }



    // ─── Delete Photo ──────────────────────────────────────────

    function deleteIEPhoto(photoId, sectionKey) {
        if (!confirm('Delete this photo?')) return;

        const token = document.querySelector('form[action*="IntraoralExams"] [name="__RequestVerificationToken"]')?.value ?? '';

        fetch('/IntraoralExams/DeletePhoto', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `photoId=${photoId}&__RequestVerificationToken=${encodeURIComponent(token)}`
        })
            .then(res => res.json())
            .then(result => {
                if (result.success) {
                    document.getElementById(`ieExamPhoto_${photoId}`)?.remove();
                    updateIESectionCount(sectionKey);
                    removePhotoFromPhotosTab('ie', photoId);

                    document.getElementById(`iePhoto_${photoId}`)?.remove();
                    if (sectionKey) updateIESectionCount(sectionKey);

                    showToast('Photo deleted.', 'success');
                } else {
                    showToast('Error deleting.', 'error');
                }
            })
            .catch(() => showToast('Server error.', 'error'));
    }



    // ─── Update Section Counter Badge ─────────────────────────

    function updateIESectionCount(sectionKey) {
        const gallery    = document.getElementById(`iePhotoGallery_${sectionKey}`);
        const countBadge = document.getElementById(`ieCount_${sectionKey}`);
        if (!gallery || !countBadge) return;
        const count = gallery.querySelectorAll('.ie-photo-item').length;
        countBadge.textContent = `${count} photo${count !== 1 ? 's' : ''}`;
    }


    function syncPhotoToPhotosTab(prefix, sectionKey, photoPath, photoId) {
        const map = {
            galleryId  : { ee: 'ph_extraoralGallery', ie: 'ph_intraoralGallery' },
            emptyId    : { ee: 'ph_extraoralEmpty',   ie: 'ph_intraoralEmpty'   },
            wrapperId  : { ee: 'ph_extraoralWrapper',  ie: 'ph_intraoralWrapper' },
            sourceLabel: { ee: 'Extraoral Exam',       ie: 'Intraoral Exam'      }
        };

        const wrapper = document.getElementById(map.wrapperId[prefix]);
        if (!wrapper) return;

        document.getElementById(map.emptyId[prefix])?.remove();

        let gallery = document.getElementById(map.galleryId[prefix]);
        if (!gallery) {
            gallery = document.createElement('div');
            gallery.className = 'ph-flat-gallery';
            gallery.id        = map.galleryId[prefix];
            wrapper.appendChild(gallery);
        }

        const srcs = Array.from(gallery.querySelectorAll('img')).map(i => `'${i.src}'`);
        srcs.push(`'${photoPath}'`);
        const allPaths = `[${srcs.join(',')}]`;

        gallery.querySelectorAll('.ph-photo-card').forEach(c => {
            const s   = c.querySelector('img')?.src;
            const cap = c.querySelector('.ph-info-section-name')?.textContent ?? '';
            const dt  = c.querySelector('.ph-info-date')?.textContent ?? '';
            if (s) c.setAttribute('onclick', `openLightbox('${s}', ${allPaths}, '${cap} · ${dt}')`);
        });

        const today     = new Date().toLocaleDateString('en-GB');
        const labelText = sectionKey.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());

        const card = document.createElement('div');
        card.className = 'ph-photo-card';
        card.id        = `ph_${prefix}Photo_${photoId}`;
        card.setAttribute('onclick', `openLightbox('${photoPath}', ${allPaths}, '${labelText} · ${today}')`);

        card.innerHTML = `
            <div class="ph-img-wrap">
                <img src="${photoPath}" alt="${labelText}" />
                <div class="ph-type-pill">${labelText}</div>
                <div class="ph-lock-icon">🔒</div>
            </div>
            <div class="ph-photo-info">
                <div class="ph-info-row">
                    <div class="ph-icon-sq">
                        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2.5">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                    </div>
                    <span class="ph-info-section-name">${labelText}</span>
                </div>
                <div class="ph-info-divider"></div>
                <div class="ph-info-row">
                    <div class="ph-icon-sq">
                        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#555" stroke-width="2.5">
                            <rect x="3" y="4" width="18" height="18" rx="2"/>
                            <line x1="16" y1="2" x2="16" y2="6"/>
                            <line x1="8"  y1="2" x2="8"  y2="6"/>
                            <line x1="3"  y1="10" x2="21" y2="10"/>
                        </svg>
                    </div>
                    <span class="ph-info-date">${today}</span>
                </div>
                <div class="ph-source-tag">${map.sourceLabel[prefix]}</div>
            </div>`;

        gallery.appendChild(card);
    }

    function removePhotoFromPhotosTab(prefix, photoId) {
        const map = {
            galleryId : { ee: 'ph_extraoralGallery', ie: 'ph_intraoralGallery' },
            emptyId   : { ee: 'ph_extraoralEmpty',   ie: 'ph_intraoralEmpty'   },
            wrapperId : { ee: 'ph_extraoralWrapper',  ie: 'ph_intraoralWrapper' }
        };

        document.getElementById(`ph_${prefix}Photo_${photoId}`)?.remove();

        const gallery = document.getElementById(map.galleryId[prefix]);
        if (!gallery) return;

        const remaining = gallery.querySelectorAll('.ph-photo-card').length;

        if (remaining === 0) {
            gallery.remove();
            const wrapper = document.getElementById(map.wrapperId[prefix]);
            if (wrapper && !document.getElementById(map.emptyId[prefix])) {
                const p = document.createElement('p');
                p.className   = 'ph-empty';
                p.id          = map.emptyId[prefix];
                p.textContent = 'No intraoral photos yet.';
                wrapper.appendChild(p);
            }
        } else {
            const srcs     = Array.from(gallery.querySelectorAll('img')).map(i => `'${i.src}'`);
            const allPaths = `[${srcs.join(',')}]`;
            gallery.querySelectorAll('.ph-photo-card').forEach(c => {
                const s   = c.querySelector('img')?.src;
                const cap = c.querySelector('.ph-info-section-name')?.textContent ?? '';
                const dt  = c.querySelector('.ph-info-date')?.textContent ?? '';
                if (s) c.setAttribute('onclick', `openLightbox('${s}', ${allPaths}, '${cap} · ${dt}')`);
            });
        }
    }
</script>