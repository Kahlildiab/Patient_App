@model DentalCollegeManagementSystem_AAU.Models.Patient

@{
    ViewData["Title"] = "Delete Patient";
}


<link rel="stylesheet" href="~/css/Site.css" />
<link rel="stylesheet" href="~/css/Site.css" />
<link rel="stylesheet" href="~/css/all.min.css" />
<link rel="stylesheet" href="~/css/_grid.scss" />
<link rel="stylesheet" href="~/css/_reboot.scss" />
<link rel="stylesheet" href="~/css/_root.scss" />
 
<div class="page-wrapper">
    <div class="card">

        <div class="card-header">
            <div class="header-line left"></div>
            <h1 class="page-title">DELETE PATIENT</h1>
            <div class="header-line right"></div>
        </div>

        <div class="warning-banner">
            <div class="warning-icon">!</div>
            <div class="warning-text">
                <strong>This action cannot be undone</strong>
                <span>The patient record and all associated data will be permanently removed.</span>
            </div>
        </div>

        <div class="section-label">Personal Information</div>
        <div class="info-grid">
            <div class="info-item full">
                <span class="label">Full Name</span>
                <span class="value">@Model.FirstName @Model.SecondName @Model.ThirdName @Model.FourthName</span>
            </div>
            <div class="info-item">
                <span class="label">National ID / Passport</span>
                <span class="value">@Model.NationalID_PassportNumber</span>
            </div>
            <div class="info-item">
                <span class="label">Gender</span>
                <span class="value">@Model.Gender</span>
            </div>
            <div class="info-item">
                <span class="label">Date of Birth</span>
                <span class="value">@Model.DateOfBirth</span>
            </div>
            <div class="info-item">
                <span class="label">Phone</span>
                <span class="value">@Model.PhoneNumber</span>
            </div>
            <div class="info-item full">
                <span class="label">Address</span>
                <span class="value">@Model.Address</span>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="PatientID" />
            <div class="actions">
                <button type="submit" class="btn-delete">Yes, Delete Patient</button>
                @* <a asp-action="Index" class="btn-back">← Cancel & Go Back</a> *@
            </div>
        </form>

    </div>
</div>
