            case 24: return `<pattern id="${patId}" patternUnits="userSpaceOnUse" width="8" height="8"${transform}><rect x="1.5" y="1.5" width="5" height="5" fill="none" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/></pattern>`;
            case 25: return `<pattern id="${patId}" patternUnits="userSpaceOnUse" width="9" height="9"${transform}><circle cx="4.5" cy="4.5" r="3" fill="none" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><circle cx="4.5" cy="4.5" r="0.9" fill="${color}" fill-opacity="${op}"/></pattern>`;
            case 26: return `<pattern id="${patId}" patternUnits="userSpaceOnUse" width="9" height="9"${transform}><path d="M4.5 1.2 L5.4 3.6 L8 4.5 L5.4 5.4 L4.5 7.8 L3.6 5.4 L1 4.5 L3.6 3.6 Z" fill="${color}" fill-opacity="${op}"/></pattern>`;
            case 27: return `<pattern id="${patId}" patternUnits="userSpaceOnUse" width="6" height="6"${transform}><line x1="0" y1="0" x2="6" y2="6" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><line x1="6" y1="0" x2="0" y2="6" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><line x1="3" y1="-3" x2="9" y2="3" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><line x1="-3" y1="3" x2="3" y2="9" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/></pattern>`;
            case 28: return `<pattern id="${patId}" patternUnits="userSpaceOnUse" width="10" height="10"${transform}><circle cx="5" cy="5" r="3.5" fill="none" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><circle cx="5" cy="5" r="1" fill="${color}" fill-opacity="${op}"/></pattern>`;
            case 29: return `<pattern id="${patId}" patternUnits="userSpaceOnUse" width="8" height="8"${transform}><path d="M0 2 L2 0 L4 4 L6 0 L8 2" fill="none" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><path d="M0 6 L2 4 L4 8 L6 4 L8 6" fill="none" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/></pattern>`;
            case 30: return `<pattern id="${patId}" patternUnits="userSpaceOnUse" width="8" height="8"${transform}><line x1="0" y1="4" x2="4" y2="0" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><line x1="4" y1="8" x2="8" y2="4" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><line x1="0" y1="8" x2="8" y2="0" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/></pattern>`;
            case 31: return `<pattern id="${patId}" patternUnits="userSpaceOnUse" width="9" height="9"${transform}><circle cx="4.5" cy="4.5" r="2" fill="none" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><line x1="4.5" y1="0" x2="4.5" y2="2.5" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><line x1="4.5" y1="6.5" x2="4.5" y2="9" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><line x1="0" y1="4.5" x2="2.5" y2="4.5" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><line x1="6.5" y1="4.5" x2="9" y2="4.5" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/></pattern>`;
            case 32: return `<pattern id="${patId}" patternUnits="userSpaceOnUse" width="10" height="10"${transform}><circle cx="5" cy="5" r="4" fill="none" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><circle cx="5" cy="5" r="2" fill="none" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><circle cx="5" cy="5" r="0.7" fill="${color}" fill-opacity="${op}"/></pattern>`;
