        function occlusalToothSvg(tid, arch) {
        const insideName = arch === "upper" ? "palatal" : "lingual";
        const cx = 32, cy = 26, rx = 26, ry = 20, irx = 13, iry = 10;

        const extractedColor = getExtractedColor(tid);   // ⬅️ نتحقق أول شي

        function ptOuter(a) { const r=a*Math.PI/180; return {x:cx+rx*Math.cos(r),y:cy+ry*Math.sin(r)}; }
        function ptInner(a) { const r=a*Math.PI/180; return {x:cx+irx*Math.cos(r),y:cy+iry*Math.sin(r)}; }
        function segmentPath(sa, ea) {
            const t=a=>a*Math.PI/180;
            const x1o=cx+rx*Math.cos(t(sa)),y1o=cy+ry*Math.sin(t(sa));
            const x2o=cx+rx*Math.cos(t(ea)),y2o=cy+ry*Math.sin(t(ea));
            const x1i=cx+irx*Math.cos(t(ea)),y1i=cy+iry*Math.sin(t(ea));
            const x2i=cx+irx*Math.cos(t(sa)),y2i=cy+iry*Math.sin(t(sa));
            const la=Math.abs(ea-sa)>180?1:0;
            return `M ${x1o} ${y1o} A ${rx} ${ry} 0 ${la} 1 ${x2o} ${y2o} L ${x1i} ${y1i} A ${irx} ${iry} 0 ${la} 0 ${x2i} ${y2i} Z`;
        }
        const xAngles = [45, 135, 225, 315];
        const segments = [
            { key:"distal",    startAngle:-45,  endAngle:45  },
            { key:"buccal",    startAngle:45,   endAngle:135 },
            { key:"mesial",    startAngle:135,  endAngle:225 },
            { key:insideName,  startAngle:225,  endAngle:315 }
        ];
        const badgeSpots = {
            buccal:[{x:28,y:40},{x:36,y:40}], palatal:[{x:28,y:10},{x:36,y:10}],
            lingual:[{x:28,y:10},{x:36,y:10}], mesial:[{x:6,y:22},{x:6,y:30}],
            distal:[{x:52,y:22},{x:52,y:30}],  occlusal:[{x:28,y:22},{x:36,y:22}]
        };
        const allKeys = [...segments.map(s=>s.key), "occlusal"];

        const defsContent = extractedColor ? "" : allKeys.map(key => {     // ⬅️ بدون patterns لو مخلوع
            const marks = getAreaMarks(tid, key);
            if (!marks.length) return "";
            return glyphPattern(`occ_${tid}_${key}`, marks[0].tool.glyph, GROUP_COLORS[marks[0].tool.group]);
        }).join("");

        const segmentsSvg = segments.map(s => {
            const marks  = extractedColor ? [] : getAreaMarks(tid, s.key);   // ⬅️ فاضي لو مخلوع
            const fill   = marks.length ? `url(#occ_${tid}_${s.key})` : "transparent";
            const stroke = isSelected(tid, s.key) ? "#111827" : "#c4ccd7";
            const sw     = isSelected(tid, s.key) ? 2.0 : 0.9;
            return `<path d="${segmentPath(s.startAngle, s.endAngle)}" fill="${fill}" stroke="${stroke}" stroke-width="${sw}" onclick="selectArea('${tid}','${s.key}')" style="cursor:pointer"/>`;
        }).join("");

        const occlusalMarks = extractedColor ? [] : getAreaMarks(tid, "occlusal");  // ⬅️ فاضي لو مخلوع
        const occlusalFill  = occlusalMarks.length ? `url(#occ_${tid}_occlusal)` : "transparent";

        const xLines = xAngles.map(a => {
            const o=ptOuter(a), i=ptInner(a);
            return `<line x1="${i.x.toFixed(2)}" y1="${i.y.toFixed(2)}" x2="${o.x.toFixed(2)}" y2="${o.y.toFixed(2)}" stroke="#1f2937" stroke-width="0.9"/>`;
        }).join("");

        // ⬇️ جديد: X كبيرة عبر السن كامل بالـ occlusal view
        const extractedBigX = extractedColor ? `
            <line x1="${cx-rx*0.85}" y1="${cy-ry*0.85}" x2="${cx+rx*0.85}" y2="${cy+ry*0.85}"
                  stroke="${extractedColor}" stroke-width="2.6" stroke-linecap="round"/>
            <line x1="${cx+rx*0.85}" y1="${cy-ry*0.85}" x2="${cx-rx*0.85}" y2="${cy+ry*0.85}"
                  stroke="${extractedColor}" stroke-width="2.6" stroke-linecap="round"/>
        ` : "";

        return `
            <svg class="tooth-svg" viewBox="0 0 64 52" xmlns="http://www.w3.org/2000/svg">
              <defs>${defsContent}</defs>
              <ellipse cx="${cx}" cy="${cy}" rx="${rx}" ry="${ry}" fill="#fafafa" stroke="#d0d6df" stroke-width="1.4"/>
              ${segmentsSvg}
              ${xLines}
              <ellipse cx="${cx}" cy="${cy}" rx="${irx}" ry="${iry}"
                       fill="${occlusalFill}"
                       stroke="${isSelected(tid,'occlusal') ? '#111827' : '#c4ccd7'}"
                       stroke-width="${isSelected(tid,'occlusal') ? 2.0 : 0.9}"
                       onclick="selectArea('${tid}','occlusal')" style="cursor:pointer"/>
              <ellipse cx="${cx}" cy="${cy}" rx="${rx}" ry="${ry}" fill="none" stroke="#c4ccd7" stroke-width="1.3"/>
              ${wholeToothOverlayOcclusal(tid)}
              ${segments.map(s=>areaBadges(tid,s.key,badgeSpots[s.key]||badgeSpots.occlusal)).join("")}
              ${areaBadges(tid,'occlusal',badgeSpots.occlusal,false)}
              ${extractedBigX}
            </svg>`;
    }
        function toggleToothVariant(tid) {
        const tooth = chartData[tid];
        if (!tooth) return;
        tooth.isDeciduous = !tooth.isDeciduous;

        // سجّل/امسح الأداة بالـ whole.others عشان تنعكس بالـ Tool Report تلقائياً
        const arr = tooth.whole.others;
        const idx = arr.indexOf("teeth_change");
        if (tooth.isDeciduous) {
            if (idx === -1) arr.push("teeth_change");
        } else {
            if (idx > -1) arr.splice(idx, 1);
        }
    }
    // ════════════════════════════════════════════════════════════════
    //  INTERACTIONS
    // ════════════════════════════════════════════════════════════════

              function selectArea(tid, area) {
        selectedTarget = { toothId: tid, area };

        if (selectedToolId === "others_text") {
            openOthersTextModal(tid, area);
            return;
        }

        if (selectedToolId === "teeth_change") {
            if (!pendingSwapToothId) {
                pendingSwapToothId = tid;
                showToast(`🔁 اختر السن الثاني للتبديل مع ${tid}`, "info");
                renderAll();
                return;
            }
            if (pendingSwapToothId === tid) {
                pendingSwapToothId = null;
                showToast("❌ تم إلغاء التبديل", "info");
                renderAll();
                return;
            }
            const firstId = pendingSwapToothId;
            swapTeeth(firstId, tid);
            pendingSwapToothId = null;
            showToast(`✅ تم تبديل ${firstId} مع ${tid}`, "success");
            renderAll();
            return;
        }

        if (selectedToolId) applyToolToSelectedTarget();
        renderAll();
    }

    function applyToolToSelectedTarget() {
        if (!selectedToolId || !selectedTarget) return;
        const tool  = getTool(selectedToolId);
        const tooth = chartData[selectedTarget.toothId];
        if (!tool) return;
        if (tool.scope === "whole") {
            if (!Array.isArray(tooth.whole[tool.group])) tooth.whole[tool.group] = [];
            if (!tooth.whole[tool.group].includes(tool.id)) tooth.whole[tool.group].push(tool.id);
        } else if (tool.scope === "root") {
            const arr = tooth.areas.root[tool.group];
            if (!arr.includes(tool.id)) arr.push(tool.id);
            selectedTarget.area = "root";
        } else {
            const arr = tooth.areas[selectedTarget.area][tool.group];
            if (!arr.includes(tool.id)) arr.push(tool.id);
        }
    }

    function clearSelectedTarget() {
        if (!selectedTarget) return;
        chartData[selectedTarget.toothId].areas[selectedTarget.area] = makeSlot();
        renderAll();
    }

    function clearSelectedTooth() {
        if (!selectedTarget) return;
        const id = selectedTarget.toothId;
        chartData[id] = makeTooth(id);
        renderAll();
    }

    function clearAllChart() {
        [...UPPER_IDS, ...LOWER_IDS].forEach(id => { chartData[id] = makeTooth(id); });
        renderAll();
    }

    function saveNote() {
        if (!selectedTarget) return;
        const text = document.getElementById("noteBox").value.trim();
        chartData[selectedTarget.toothId].areas[selectedTarget.area].note = text;
        renderAll();
    }

    function removeGroupFromArea(group, toolId) {
        if (!selectedTarget) return;
        const arr = chartData[selectedTarget.toothId].areas[selectedTarget.area][group];
        const idx = arr.indexOf(toolId);
        if (idx > -1) arr.splice(idx, 1);
        renderAll();
    }

    function removeWholeGroup(tid, group, toolId) {
        const arr = chartData[tid].whole[group];
        if (Array.isArray(arr)) {
            const idx = arr.indexOf(toolId);
            if (idx > -1) arr.splice(idx, 1);
        }
        renderAll();
    }

    function removeFromArea(toothId, areaKey, group, toolId) {
        const arr = chartData[toothId].areas[areaKey][group];
        const idx = arr.indexOf(toolId);
        if (idx > -1) arr.splice(idx, 1);
        renderAll();
    }

    function clearAreaNote() {
        if (!selectedTarget) return;
        chartData[selectedTarget.toothId].areas[selectedTarget.area].note = "";
        renderAll();
    }

    function clearAreaNoteFor(toothId, areaKey) {
        chartData[toothId].areas[areaKey].note = "";
        renderAll();
    }

    // ════════════════════════════════════════════════════════════════
    //  DESELECT ON BACKGROUND CLICK
    // ════════════════════════════════════════════════════════════════
    document.addEventListener("click", function(e) {
        const isOnTooth    = e.target.closest("svg.tooth-svg");
        const isOnBtn      = e.target.closest("button");
        const isOnTextarea = e.target.closest("textarea");
        const isOnMiniItem = e.target.closest(".mini-item");
        const isOnToolbar  = e.target.closest("#toolbar");
        const isOnModal    = e.target.closest(".modal-box");
        const isOnReport   = e.target.closest("#reportPanel");
        if (!isOnTooth && !isOnBtn && !isOnTextarea && !isOnMiniItem && !isOnToolbar && !isOnModal && !isOnReport) {
            if (selectedToolId) {
                selectedToolId = null;
                pendingSwapToothId = null;
                renderAll();
            }
        }
    });

    // ════════════════════════════════════════════════════════════════
    //  REPORT
    // ════════════════════════════════════════════════════════════════
    function buildToolReport() {
        const report   = {};
        const allAreas = ["buccal","lingual","palatal","mesial","distal","occlusal","root"];
        const grps     = ["disease","previous","inside","others"];
        [...UPPER_IDS, ...LOWER_IDS].forEach(tid => {
            const tooth = chartData[tid];
            if (!tooth) return;
            grps.forEach(g => {
                (tooth.whole[g] || []).forEach(toolId => {
                    if (!report[toolId]) report[toolId] = [];
                    report[toolId].push({ toothId: tid, area: "whole", group: g });
                });
            });
            allAreas.forEach(area => {
                const slot = tooth.areas[area];
                if (!slot) return;
                grps.forEach(g => {
                    (slot[g] || []).forEach(toolId => {
                        if (!report[toolId]) report[toolId] = [];
                        report[toolId].push({ toothId: tid, area, group: g });
                    });
                });
            });
        });
        return report;
    }

    function selectReportTool(toolId) {
        reportToolId = (reportToolId === toolId) ? null : toolId;
        renderSideInfo();
    }

    // ════════════════════════════════════════════════════════════════
    //  RENDER
    // ════════════════════════════════════════════════════════════════
    function renderSideInfo() {
        const AREA_NAMES = ["buccal","lingual","palatal","mesial","distal","occlusal","root"];
        const GRPS       = ["disease","previous","inside","others"];

        document.getElementById("selectedToolLabel").textContent  = selectedToolId ? getTool(selectedToolId).label : "—";
        document.getElementById("selectedToothLabel").textContent = selectedTarget  ? selectedTarget.toothId        : "—";
        document.getElementById("selectedAreaLabel").textContent  = selectedTarget  ? selectedTarget.area           : "—";

        // ── Report Panel ──
        const report      = buildToolReport();
        const reportKeys  = Object.keys(report);
        const reportPanel = document.getElementById("reportPanel");
        if (reportPanel) {
            if (!reportKeys.length) {
                reportPanel.innerHTML = `<div style="color:var(--muted);font-size:13px;padding:6px 0;">No tools applied yet.</div>`;
            } else {
                reportPanel.innerHTML = reportKeys.map(toolId => {
                    const tool     = getTool(toolId);
                    if (!tool) return "";
                    const color    = GROUP_COLORS[tool.group];
                    const usages   = report[toolId];
                    const isActive = reportToolId === toolId;
                    return `
                    <div onclick="selectReportTool('${toolId}')"
                         style="display:flex;align-items:center;gap:8px;padding:8px 10px;
                                border-radius:10px;cursor:pointer;margin-bottom:5px;
                                border:2px solid ${isActive ? color : 'var(--line)'};
                                background:${isActive ? hexToRgba(color,.07) : '#fafafa'};
                                transition:.15s;">
                        <div style="flex:0 0 auto;">${iconSvg(tool.glyph, color, 28)}</div>
                        <div style="flex:1;min-width:0;">
                            <div style="font-size:12px;font-weight:bold;color:${color};
                                        white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                ${escapeHtml(tool.label)}
                            </div>
                            <div style="font-size:11px;color:var(--muted);">
                                ${GROUP_LABELS[tool.group]} · ${usages.length} location${usages.length>1?'s':''}
                            </div>
                        </div>
                        <div style="font-size:16px;font-weight:bold;color:${color};flex:0 0 auto;
                                    background:${hexToRgba(color,.12)};border-radius:8px;padding:2px 8px;">
                            ${usages.length}
                        </div>
                    </div>`;
                }).join("");
            }
        }

        // ── Detail List ──
        const detailList = document.getElementById("detailList");

        if (reportToolId) {
            const tool   = getTool(reportToolId);
            const usages = report[reportToolId] || [];
            const color  = tool ? GROUP_COLORS[tool.group] : "#6b7280";
            if (!tool || !usages.length) {
                detailList.innerHTML = `<div style="color:var(--muted);font-size:13px;">Nothing found.</div>`;
                return;
            }
            detailList.innerHTML = `
                <div style="font-size:12px;font-weight:bold;color:${color};
                            margin-bottom:8px;display:flex;align-items:center;gap:6px;">
                    ${iconSvg(tool.glyph, color, 18)}
                    ${escapeHtml(tool.label)}
                    <span style="margin-left:auto;background:${hexToRgba(color,.12)};
                                 color:${color};border-radius:6px;padding:1px 8px;font-size:11px;">
                        ${usages.length} location${usages.length>1?'s':''}
                    </span>
                </div>
                ${usages.map(u => `
                    <div class="mini-item" style="margin-bottom:5px;cursor:pointer;
                                border-left:3px solid ${GROUP_COLORS[u.group]};"
                         onclick="selectArea('${u.toothId}','${u.area==='whole'?'buccal':u.area}');
                                  reportToolId=null;renderSideInfo();">
                        <div class="mini-icon">${iconSvg(tool.glyph, GROUP_COLORS[u.group], 22)}</div>
                        <div class="mini-text">
                            <div class="key">Tooth ${u.toothId} · ${u.area} · ${u.group}</div>
                            <div class="value" style="color:${GROUP_COLORS[u.group]};">
                                ${u.toothId} — ${u.area}
                            </div>
                        </div>
                    </div>
                `).join("")}`;
            return;
        }

        if (!selectedTarget) {
            detailList.innerHTML = `<div style="color:#6b7280;font-size:13px;">Nothing selected.</div>`;
            document.getElementById("noteBox").value = "";
            return;
        }

        const { toothId, area } = selectedTarget;
        const areaSlot  = chartData[toothId].areas[area];
        const wholeSlot = chartData[toothId].whole;
        document.getElementById("noteBox").value = areaSlot.note || "";

        const reportRows = [];
        AREA_NAMES.forEach(areaKey => {
            const slot  = chartData[toothId].areas[areaKey];
            const marks = [];
            GRPS.forEach(g => {
                (slot[g] || []).forEach(tid => {
                    const t = getTool(tid);
                    if (t) marks.push({ group: g, tool: t });
                });
            });
            if (marks.length || slot.note) reportRows.push({ areaKey, marks, note: slot.note });
        });

        const wholeMarks = [];
        GRPS.forEach(g => {
            (wholeSlot[g] || []).forEach(tid => {
                const t = getTool(tid);
                if (t) wholeMarks.push({ group: g, tool: t });
            });
        });
        if (wholeMarks.length || wholeSlot.note) {
            reportRows.push({ areaKey: "whole tooth", marks: wholeMarks, note: wholeSlot.note });
        }

        if (!reportRows.length) {
            detailList.innerHTML = `<div style="color:#6b7280;font-size:13px;">Area is empty.</div>`;
            return;
        }

        detailList.innerHTML = reportRows.map(row => {
            const toolsHtml = row.marks.map(m => `
                <div class="mini-item" style="margin-bottom:4px;">
                    <div class="mini-icon">${iconSvg(m.tool.glyph, GROUP_COLORS[m.group], 22)}</div>
                    <div class="mini-text">
                        <div class="key">Tooth ${toothId} · ${row.areaKey} · ${m.group}</div>
                        <div class="value">${escapeHtml(m.tool.label)}</div>
                    </div>
                    <button onclick="${row.areaKey==='whole tooth'
                        ? `removeWholeGroup('${toothId}','${m.group}','${m.tool.id}')`
                        : `removeFromArea('${toothId}','${row.areaKey}','${m.group}','${m.tool.id}')`
                    }">✕</button>
                </div>`).join("");

            const noteHtml = row.note ? `
                <div class="mini-item" style="margin-bottom:4px;">
                    <div class="mini-icon">${iconSvg("note","#6b7280",22)}</div>
                    <div class="mini-text">
                        <div class="key">Tooth ${toothId} · ${row.areaKey} · note</div>
                        <div class="value">${escapeHtml(row.note)}</div>
                    </div>
                    <button onclick="clearAreaNoteFor('${toothId}','${row.areaKey}')">✕</button>
                </div>` : "";

            return `
                <div style="border:1px solid var(--line);border-radius:12px;padding:8px;
                            margin-bottom:8px;background:#f8fafc;">
                    <div style="font-size:12px;font-weight:bold;color:#374151;margin-bottom:6px;
                                text-transform:uppercase;letter-spacing:.5px;">
                        📍 ${row.areaKey}
                    </div>
                    ${toolsHtml}${noteHtml}
                </div>`;
        }).join("");
    }
