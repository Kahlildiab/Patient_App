@* ─────────────────────────────────────────────────────────────────────────
   Views/DentalCharting/Index.cshtml
───────────────────────────────────────────────────────────────────────── *@
@{
    ViewData["Title"] = "Dental Chart";
    var patientId = ViewBag.PatientId ?? 0;
}

<style>
    * {
        box-sizing: border-box;
    }

    :root {
        --bg: #f4f6fb;
        --panel: #ffffff;
        --line: #d7dde6;
        --soft: #eef2f7;
        --text: #1f2937;
        --muted: #6b7280;
        --disease: #d9485f;
        --previous: #2463b3;
        --inside: #2f9e44;
        --others: #f08c00;
        --neutral: #8a93a3;
    }

    body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: var(--bg);
        color: var(--text);
    }

    .app {
        width: 111%;
        margin: 0 auto;
        padding: 12px;
    }

    .topbar {
        position: static;
        background: transparent;
        padding-bottom: 12px;
    }

    .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 10px;
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 12px 16px;
    }

        .header h1 {
            margin: 0;
            font-size: 28px;
        }

        .header small {
            color: var(--muted);
            display: block;
            margin-top: 4px;
            font-size: 13px;
        }

    .db-bar {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
    }

        .db-bar .db-status {
            font-size: 13px;
            color: var(--muted);
            margin-left: auto;
        }

    .toolbar {
        position: static;
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 10px;
    }

    .toolbar-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
    }

    .tool-strip {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        justify-content: space-evenly;
    }

    .group-block {
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 8px;
        background: #fff;
        min-width: max-content;
    }

    .group-title {
        font-size: 12px;
        font-weight: bold;
        color: #111827;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
    }

    .group-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
    }

    .tool-strip {
        display: flex;
        gap: 6px;
        flex-wrap: nowrap;
    }

    .tool-btn {
        flex: 1;
        max-width: 60px;
        width: 54px;
        height: 44px;
        border: 0px solid var(--line);
        background: #fff;
        border-radius: 10px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: .15s;
        position: relative;
        flex: 0 0 auto;
    }

        .tool-btn:hover {
            transform: translateY(-1px);
            background: #f0f4ff;
        }

        .tool-btn.active {
            background: #e8f0ff;
            box-shadow: 0 0 0 3px rgba(17,24,39,.12);
            border-radius: 12px;
        }

        .tool-btn .tip {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            bottom: -34px;
            background: #111827;
            color: #fff;
            font-size: 11px;
            padding: 4px 7px;
            border-radius: 8px;
            white-space: nowrap;
            opacity: 0;
            pointer-events: none;
            transition: .15s;
            z-index: 99;
        }

        .tool-btn:hover .tip {
            opacity: 1;
        }

    .main {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 12px;
        margin-top: 12px;
        align-items: start;
    }

    .chart-panel,
    .side-panel {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 14px;
    }

    .side-panel {
        position: sticky;
        top: 160px;
    }

    .status-box {
        background: #f8fafc;
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 12px;
        margin-bottom: 12px;
        font-size: 14px;
        line-height: 1.6;
    }

        .status-box b {
            color: #111827;
        }

    .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
    }

    .btn {
        border: none;
        border-radius: 10px;
        padding: 10px 12px;
        cursor: pointer;
        font-weight: bold;
        font-size: 13px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: opacity .15s, transform .1s;
    }

        .btn:hover {
            opacity: .88;
            transform: translateY(-1px);
        }

        .btn:active {
            transform: translateY(0);
        }

    .btn-secondary {
        background: #e5e7eb;
        color: #111827;
    }

    .btn-danger {
        background: #dc2626;
        color: #fff;
    }

    .btn-primary {
        background: #2563eb;
        color: #fff;
    }

    .btn-warning {
        background: #f59e0b;
        color: #fff;
    }

    .btn-green {
        background: #16a34a;
        color: #fff;
    }

    textarea {
        width: 100%;
        min-height: 90px;
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 10px;
        resize: vertical;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 14px;
        margin-top: 8px;
    }

    .legend {
        margin-top: 12px;
        font-size: 13px;
        color: #4b5563;
        line-height: 1.6;
        background: #fafafa;
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 10px;
    }

    .chart-title {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        gap: 12px;
        flex-wrap: wrap;
    }

        .chart-title h2 {
            margin: 0;
            font-size: 22px;
        }

        .chart-title .hint {
            color: var(--muted);
            font-size: 13px;
        }

    .chart-grid {
        display: grid;
        grid-template-columns: 52px repeat(16, minmax(56px, 1fr));
        gap: 6px;
        align-items: center;
    }

    .side-label {
        writing-mode: vertical-rl;
        transform: rotate(180deg);
        text-align: center;
        color: #4b5563;
        font-style: italic;
        font-size: 14px;
        padding: 8px 0;
        justify-self: center;
        align-self: stretch;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .number-cell {
        text-align: center;
        font-size: 18px;
        font-weight: bold;
        color: #111827;
        padding: 2px 0 6px;
    }

    .tooth-cell {
        text-align: center;
        padding: 2px;
    }

    .tooth-svg {
        width: 135%;
        height: auto;
        display: block;
        cursor: pointer;
        /*
                                Bridge and Space Maintainer connector lines extend slightly
                                outside the SVG so adjacent teeth can be visually connected.
                            */
        overflow: visible;
    }

    .mid-rl {
        grid-column: 2 / span 16;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: #4b5563;
        font-size: 22px;
        font-weight: bold;
        padding: 2px 8px 6px;
        border-top: 1px solid #e5e7eb;
        border-bottom: 1px solid #e5e7eb;
        margin: 4px 0;
    }

    .mini-list {
        display: grid;
        gap: 8px;
        margin-top: 12px;
    }

    .mini-item {
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 8px;
        display: flex;
        gap: 8px;
        align-items: center;
        background: #fff;
    }

    .mini-icon {
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--line);
        border-radius: 8px;
        flex: 0 0 auto;
    }

    .mini-text {
        font-size: 13px;
        line-height: 1.4;
        min-width: 0;
        flex: 1;
    }

        .mini-text .key {
            font-size: 11px;
            color: var(--muted);
            text-transform: uppercase;
        }

        .mini-text .value {
            font-weight: bold;
            word-break: break-word;
        }

    .mini-item button {
        width: 28px;
        height: 28px;
        border: none;
        border-radius: 8px;
        background: #ef4444;
        color: #fff;
        font-weight: bold;
        cursor: pointer;
        flex: 0 0 auto;
    }

    .session-note-wrap {
        margin-top: 10px;
    }

        .session-note-wrap label {
            font-size: 13px;
            font-weight: bold;
            display: block;
            margin-bottom: 4px;
        }

        .session-note-wrap textarea {
            min-height: 56px;
        }

    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }

        .modal-overlay.open {
            display: flex;
        }

    .modal-box {
        background: #fff;
        border-radius: 18px;
        padding: 20px;
        width: 90%;
        max-width: 600px;
        max-height: 80vh;
        overflow-y: auto;
        box-shadow: 0 20px 60px rgba(0,0,0,.25);
    }

        .modal-box h3 {
            margin: 0 0 14px;
            font-size: 20px;
        }

    .history-item {
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 12px;
        margin-bottom: 8px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
    }

        .history-item .hi-meta {
            font-size: 13px;
            color: var(--muted);
        }

        .history-item .hi-note {
            font-weight: bold;
            font-size: 14px;
            margin-top: 2px;
        }

    #toastContainer {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .toast {
        padding: 12px 20px;
        border-radius: 12px;
        color: #fff;
        font-size: 14px;
        font-weight: bold;
        box-shadow: 0 4px 20px rgba(0,0,0,.25);
        animation: slideIn .25s ease;
        transition: opacity .4s;
    }

    @@keyframes slideIn {
        from {
            transform: translateX(40px);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @@media (max-width: 1280px) {
        .main {
            grid-template-columns: 1fr;
        }

        .side-panel {
            position: static;
        }
    }

    @@media (max-width: 920px) {
        .chart-grid {
            grid-template-columns: 42px repeat(16, minmax(48px, 1fr));
        }

        .number-cell {
            font-size: 15px;
        }
    }
    /* Permanent / Deciduous switch */
    .dentition-switch {
        display: flex;
        align-items: center;
        gap: 9px;
        background: #f8fafc;
        border: 1px solid var(--line);
        border-radius: 11px;
        padding: 7px 11px;
        cursor: pointer;
        user-select: none;
        transition: .15s;
    }

        .dentition-switch:hover {
            background: #eef2ff;
            border-color: #c7d2fe;
        }

        .dentition-switch input {
            width: 18px;
            height: 18px;
            margin: 0;
            cursor: pointer;
            accent-color: #2563eb;
        }

    .dentition-switch-text {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
    }

        .dentition-switch-text strong {
            font-size: 13px;
            color: #111827;
        }

        .dentition-switch-text span {
            margin-top: 2px;
            font-size: 11px;
            color: var(--muted);
        }

    /*
                    نخفي السن مع الاحتفاظ بمكانه داخل Grid،
                    حتى تبقى الأسنان 1-5 في مكانها الصحيح.
                */
    .dentition-hidden {
        visibility: hidden !important;
        pointer-events: none !important;
    }
</style>

<div id="toastContainer"></div>

<!-- History Modal -->
<div class="modal-overlay" id="historyModal">
    <div class="modal-box">
        <h3>📋 Previous Sessions History</h3>
        <div id="historyList"><p style="color:var(--muted)">Loading...</p></div>
        <div style="margin-top:14px;text-align:right;">
            <button class="btn btn-secondary" onclick="closeHistory()">✕ Close</button>
        </div>
    </div>
</div>
<div class="modal-overlay" id="summaryModal">
    <div class="modal-box" style="max-width:700px">
        <h3>📊 Session Summary</h3>
        <div id="summaryMeta" style="font-size:13px;color:var(--muted);margin-bottom:12px;"></div>
        <div id="summaryTable"></div>
        <div style="margin-top:14px;display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap;">
            <button class="btn btn-secondary" onclick="closeSummary()">✕ Close</button>
            <button class="btn btn-primary" id="summaryOpenBtn">📂 Open in Chart</button>
        </div>
    </div>
</div>
<div class="modal-overlay" id="othersTextModal">
    <div class="modal-box" style="max-width:460px;">
        <h3 id="othersTextTitle">📝 Add Note</h3>
        <textarea id="othersTextInput"
                  placeholder="اكتب ملاحظتك هنا / Write your note here..."
                  style="min-height:120px;margin-top:0;font-size:15px;"></textarea>
        <div style="margin-top:14px;display:flex;gap:8px;justify-content:flex-end;">
            <button class="btn btn-secondary" onclick="closeOthersTextModal()">✕ Cancel</button>
            <button class="btn btn-primary" onclick="saveOthersText()">💾 Save Note</button>
        </div>
    </div>
</div>
<div class="app">
    <div class="topbar">

        <div class="header">
            <div>
                <h1>🦷 Dental Chart</h1>

                <small>
                    Patient ID:
                    <strong>@patientId</strong>
                    — SVG Interactive Chart
                </small>
            </div>

            <div class="db-bar">

                <label class="dentition-switch">
                    <input type="checkbox"
                           id="deciduousModeCheckbox"
                           onchange="changeDentitionMode(this.checked)" />

                    <span class="dentition-switch-text">
                        <strong id="dentitionModeLabel">
                            Permanent Teeth
                        </strong>

                        <span id="dentitionModeDescription">
                            Showing teeth 1–8
                        </span>
                    </span>
                </label>

                <button class="btn btn-primary"
                        type="button"
                        onclick="loadChartFromDb()">
                    📥 Load
                </button>

                <button class="btn btn-green"
                        type="button"
                        onclick="saveChartToDb()">
                    💾 Save
                </button>

                <button class="btn btn-warning"
                        type="button"
                        onclick="saveNewSession()">
                    🗂️ New Session
                </button>

                <button class="btn btn-secondary"
                        type="button"
                        onclick="openHistory()">
                    🕐 History
                </button>

                <span class="db-status" id="dbStatus">—</span>
            </div>
        </div>

    </div>

    <!-- تكون خارج topbar حتى تبقى Sticky طوال الصفحة -->
    <div class="toolbar" id="toolbar"></div>

    <div class="main">
        <div class="chart-panel">
            <div class="chart-title">
                <h2>Interactive Dental Chart</h2>
                <div class="hint">Select a tool from the toolbar, then click on a tooth area.</div>
            </div>
            <div id="chartHost"></div>
        </div>

        <div class="side-panel">

            <div class="status-box">
                <div><b>Selected Tool:</b>  <span id="selectedToolLabel">—</span></div>
                <div><b>Selected Tooth:</b> <span id="selectedToothLabel">—</span></div>
                <div><b>Selected Area:</b>  <span id="selectedAreaLabel">—</span></div>

                <div class="actions">
                    <button class="btn btn-secondary" onclick="clearSelectedTarget()">Clear Area</button>
                    <button class="btn btn-danger" onclick="clearSelectedTooth()">Clear Tooth</button>
                    <button class="btn btn-warning" onclick="clearAllChart()">Clear All</button>
                </div>

                <div style="margin-top:10px;"><b>Area Note</b></div>
                <textarea id="noteBox" placeholder="Write a note for the selected area..."></textarea>
                <div class="actions">
                    <button class="btn btn-primary" onclick="saveNote()">💾 Save Note</button>
                </div>

                <div class="session-note-wrap">
                    <label>General Session Note</label>
                    <textarea id="sessionNoteGlobal" placeholder="General note for this session..."></textarea>
                </div>
            </div>

            <div class="legend">
                <b>Colors:</b><br>
                <span style="color:#d9485f">■</span> Disease &nbsp;
                <span style="color:#2463b3">■</span> Previous Treatment &nbsp;
                <span style="color:#2f9e44">■</span> In-Hospital &nbsp;
                <span style="color:#f08c00">■</span> Others
                <br><br>
                <b>Scope:</b><br>
                Surface = Selected area only<br>
                Root = Root only<br>
                Whole = Entire tooth in all views
            </div>

            <div style="margin-top:12px;font-weight:bold;">Tool Report</div>
            <div id="reportPanel" style="margin-top:8px;"></div>

            <div style="margin-top:14px;font-weight:bold;">Selected Details</div>
            <div class="mini-list" id="detailList">
                <div style="color:#6b7280;font-size:13px;">Nothing selected.</div>
            </div>
        </div>
    </div>
</div>

<script>
       // ════════════════════════════════════════════════════════════════
    //  CONFIG
    // ════════════════════════════════════════════════════════════════
    const PATIENT_ID = @patientId;
    const API_BASE = "/DentalChart/api";

    // ════════════════════════════════════════════════════════════════
    //  CONSTANTS
    // ════════════════════════════════════════════════════════════════
    const GROUP_COLORS = {
        disease:  getComputedStyle(document.documentElement).getPropertyValue('--disease').trim(),
        previous: getComputedStyle(document.documentElement).getPropertyValue('--previous').trim(),
        inside:   getComputedStyle(document.documentElement).getPropertyValue('--inside').trim(),
        others:   getComputedStyle(document.documentElement).getPropertyValue('--others').trim()
    };

    const GROUP_LABELS = {
        disease:  "Disease",
        previous: "Previous Treatment",
        inside:   "In-Hospital",
        others:   "Others"
    };

    const TOOLS = [
        { id:"caries",                      label:"Caries",                             group:"disease",  glyph:"caries",           scope:"surface" },
        { id:"secondary_caries",            label:"Secondary Caries",                   group:"disease",  glyph:"secondary",        scope:"surface" },
        { id:"periapical_lesion",           label:"Periapical Lesion",                  group:"disease",  glyph:"periapical",       scope:"whole" },
        { id:"crack_tooth",                 label:"Crack Tooth",                        group:"disease",  glyph:"crack",            scope:"whole" },
        { id:"tooth_mobility",              label:"Tooth Mobility",                     group:"disease",  glyph:"mobility",         scope:"whole" },
        { id:"remaining_root",              label:"Remaining Root",                     group:"disease",  glyph:"remainingRoot",    scope:"root" },
        { id:"surface_loss",                label:"Tooth Surface Loss",                 group:"disease",  glyph:"surfaceLoss",      scope:"surface" },

        { id:"amalgam_prev",                label:"Amalgam",                            group:"previous", glyph:"resto1",           scope:"surface" },
        { id:"composite_prev",              label:"Composite Restoration",              group:"previous", glyph:"resto2",           scope:"surface" },
        { id:"gic_prev",                    label:"GIC",                                group:"previous", glyph:"resto3",           scope:"surface" },
        { id:"temporary_restoration_prev",  label:"Temporary Restoration",              group:"previous", glyph:"resto4",           scope:"surface" },
        { id:"partial_restoration_prev",    label:"Partial Restoration",                group:"previous", glyph:"resto5",           scope:"surface" },
        { id:"metal_crown_prev",            label:"Metal Crown",                        group:"previous", glyph:"crown1",           scope:"whole" },
        { id:"zirconia_crown_prev",         label:"Zirconia Crown",                     group:"previous", glyph:"crown2",           scope:"whole" },
        { id:"emax_crown_prev",             label:"Emax Crown",                         group:"previous", glyph:"crown3",           scope:"whole" },
        { id:"pfm_crown_prev",              label:"PFM Crown",                          group:"previous", glyph:"crown4",           scope:"whole" },
        {id:"temporary_crown_prev",         label:"Temporary Crown",                    group:"previous", glyph:"tempCrown",        scope:"whole" },
        { id:"stainless_crown_prev",        label:"Stainless Steel Crown",              group:"previous", glyph:"crown6",           scope:"whole" },
        { id:"resin_bonded_bridge_prev",    label:"Bridge",                             group:"previous", glyph:"bridge",           scope:"whole" },
        { id:"root_canal_prev",             label:"Root Canal Treatment",               group:"previous", glyph:"rct",              scope:"surface" },
        { id:"vital_pulp_therapy_prev",     label:"Vital Pulp Therapy",                 group:"previous", glyph:"vpt",              scope:"surface" },
        { id:"post_prev",                   label:"Post",                               group:"previous", glyph:"post",             scope:"surface" },
        { id:"stabilization_splint_prev",   label:"Stabilization Splint",               group:"previous", glyph:"splint",           scope:"surface" },
        { id:"partial_acrylic_denture_prev",label:"Partial Acrylic Denture",            group:"previous", glyph:"denture",          scope:"surface" },
        { id:"cc_denture_prev",             label:"Cobalt Chromium Partial Denture",    group:"previous", glyph:"ccDenture",        scope:"surface" },
        { id:"complete_denture_prev",       label:"Complete Denture",                   group:"previous", glyph:"completeDenture",  scope:"surface" },
        { id:"space_maintainer_prev",       label:"Space Maintainer",                   group:"previous", glyph:"spaceMaintainer",  scope:"whole" },
        { id:"pulpotomy_prev",              label:"Pulpotomy",                          group:"previous", glyph:"pulpotomy",        scope:"surface" },
        { id:"pulpectomy_prev",             label:"Pulpectomy",                         group:"previous", glyph:"pulpectomy",       scope:"surface" },

        { id:"amalgam_in",                  label:"Amalgam",                            group:"inside",   glyph:"resto1",           scope:"surface" },
        { id:"composite_in",                label:"Composite Restoration",              group:"inside",   glyph:"resto2",           scope:"surface" },
        { id:"gic_in",                      label:"GIC",                                group:"inside",   glyph:"resto3",           scope:"surface" },
        { id:"temporary_restoration_in",    label:"Temporary Restoration",              group:"inside",   glyph:"resto4",           scope:"surface" },
        { id:"partial_restoration_in",      label:"Partial Restoration",                group:"inside",   glyph:"resto5",           scope:"surface" },
        { id:"metal_crown_in",              label:"Metal Crown",                        group:"inside",   glyph:"crown1",           scope:"whole" },
        { id:"ceramic_crown_in",            label:"Ceramic Crown",                      group:"inside",   glyph:"crown2",           scope:"whole" },
        { id:"emax_crown_in",               label:"Emax Crown",                         group:"inside",   glyph:"crown3",           scope:"whole" },
        { id:"pfm_crown_in",                label:"PFM Crown",                          group:"inside",   glyph:"crown4",           scope:"whole" },
        { id:"temporary_crown_in",          label:"Temporary Crown",                    group:"inside",   glyph:"tempCrown",        scope:"whole" },
        { id:"stainless_crown_in",          label:"Stainless Steel Crown",              group:"inside",   glyph:"crown6",           scope:"whole" },
        { id:"resin_bonded_bridge_in",      label:"Bridge",                             group:"inside",   glyph:"bridge",           scope:"whole" },
        { id:"root_canal_in",               label:"Root Canal Treatment",               group:"inside",   glyph:"rct",              scope:"surface" },
        { id:"vpt_in",                      label:"Vital Pulp Therapy",                 group:"inside",   glyph:"vpt",              scope:"surface" },
        { id:"post_in",                     label:"Post",                               group:"inside",   glyph:"post",             scope:"surface" },
        { id:"stabilization_splint_in",     label:"Stabilization Splint",               group:"inside",   glyph:"splint",           scope:"surface" },
        { id:"partial_denture_in",          label:"Partial Acrylic Denture",            group:"inside",   glyph:"denture",          scope:"surface" },
        { id:"cc_denture_in",               label:"Cobalt Chromium Partial Denture",    group:"inside",   glyph:"ccDenture",        scope:"surface" },
        { id:"complete_denture_in",         label:"Complete Denture",                   group:"inside",   glyph:"completeDenture",  scope:"surface" },
        { id:"space_maintainer_in",         label:"Space Maintainer",                   group:"inside",   glyph:"spaceMaintainer",  scope:"surface" },
        { id:"pulpotomy_in",                label:"Pulpotomy",                          group:"inside",   glyph:"pulpotomy",        scope:"surface" },
        { id:"pulpectomy_in",               label:"Pulpectomy",                         group:"inside",   glyph:"pulpectomy",       scope:"surface" },
        { id:"extracted_tooth_in",          label:"Extracted Tooth",                    group:"inside",   glyph:"extracted",        scope:"surface" },

        { id:"impacted_tooth",              label:"Impacted Tooth",                     group:"others",   glyph:"impacted",         scope:"surface" },
        { id:"soft_tissue_impacted",        label:"Soft Tissue Impacted Tooth",         group:"others",   glyph:"softImpacted",     scope:"surface" },
        { id:"partially_erupted",           label:"Partially Erupted Tooth",            group:"others",   glyph:"partiallyErupted", scope:"surface" },
        { id:"teeth_transposition",         label:"Teeth Transposition",                group:"others",   glyph:"transposition",    scope:"whole" },
        { id:"teeth_change",                label:"Teeth Change Permanent/Deciduous",   group:"others",   glyph:"teethChange",      scope:"whole" },
        { id:"extracted_tooth",             label:"Extracted Tooth",                    group:"others",   glyph:"extracted",        scope:"surface" },
        { id:"others_text",                 label:"Others / Text",                      group:"others",   glyph:"note",             scope:"surface" }
    ];

    const POS_LABELS  = [8,7,6,5,4,3,2,1,1,2,3,4,5,6,7,8];

    /*
        Permanent view:
            8 7 6 5 4 3 2 1 | 1 2 3 4 5 6 7 8

        Deciduous view:
            hidden hidden hidden E D C B A | A B C D E hidden hidden hidden

        This keeps the same 16 grid positions, hides 6/7/8, and relabels
        positions 1-5 into A-E.
    */
    const DECIDUOUS_POS_LABELS = [
        "", "", "", "E", "D", "C", "B", "A",
        "A", "B", "C", "D", "E", "", "", ""
    ];

    const TOOTH_TYPES = [
        "molar3","molar2","molar1","premolar2","premolar1","canine","lateral","central",
        "central","lateral","canine","premolar1","premolar2","molar1","molar2","molar3"
    ];
    const UPPER_IDS = Array.from({length:16}, (_,i)=>`U${i}`);
    const LOWER_IDS = Array.from({length:16}, (_,i)=>`L${i}`);

    // ════════════════════════════════════════════════════════════════
    //  STATE
    // ════════════════════════════════════════════════════════════════
    const chartData = {};
    let selectedToolId   = null;
    let selectedTarget   = null;
    let currentSessionId = null;
    let reportToolId     = null;
    let pendingSwapToothId = null;

    /*
        Surface selection highlighting is temporary.

        When the user clicks one of the Lingual / Palatal surface sections,
        it stays highlighted only while the user is interacting with that
        surface chart. Clicking anywhere outside the surface chart removes
        the visual highlight without deleting the applied treatment.
    */
    let lastSelectionSource = null;
    let hideSurfaceSelectionHighlight = false;

    function makeSlot() { return { disease:[], previous:[], inside:[], others:[], note:"" }; }

    function makeTooth(id) {
        return {
            // id = the current chart position.
            id,

            // sourceId = the real tooth image currently occupying this position.
            // This value moves with the tooth when Teeth Change is used.
            sourceId: id,

            isDeciduous: false,
            whole: makeSlot(),
            areas: {
                buccal: makeSlot(), lingual: makeSlot(), palatal: makeSlot(),
                mesial: makeSlot(), distal: makeSlot(), occlusal: makeSlot(), root: makeSlot()
            }
        };
    }

    [...UPPER_IDS, ...LOWER_IDS].forEach(id => { chartData[id] = makeTooth(id); });

    // ════════════════════════════════════════════════════════════════
    //  HELPERS
    // ════════════════════════════════════════════════════════════════
    function pick(obj, camel, pascal) {
        return obj[camel] !== undefined ? obj[camel] : obj[pascal];
    }

    function getTool(id)      { return TOOLS.find(t => t.id === id) || null; }
    function getToothType(id) { return TOOTH_TYPES[parseInt(id.slice(1), 10)]; }

    function getDisplayedPositionLabel(index) {
        if (isDeciduousChartView) {
            return DECIDUOUS_POS_LABELS[index] || "";
        }

        return String(POS_LABELS[index]);
    }

    function getChartHalf(index) {
        return index >= 8 ? "right" : "left";
    }

    function getChartArch(toothId) {
        return toothId[0];
    }

    function findToothIdByNumberAndHalf(archPrefix, half, toothNumber) {
        const start = half === "left" ? 0 : 8;
        const end   = half === "left" ? 8 : 16;

        for (let i = start; i < end; i++) {
            if (POS_LABELS[i] === toothNumber) {
                return `${archPrefix}${i}`;
            }
        }

        return `${archPrefix}${half === "left" ? 0 : 8}`;
    }

    /*
        In Deciduous chart view, the visible 5-tooth set should look like:
            E D C B A | A B C D E

        To achieve that, the visible permanent positions are remapped as:
            5 -> E -> use current 7 image
            4 -> D -> use current 6 image
            3 -> C -> use current 3 image
            2 -> B -> use current 2 image
            1 -> A -> use current 1 image

        This is a visual-only mapping for the chart mode.
    */
    function getDentitionVisualSourceId(positionId) {
        const sourceId = getSourceToothId(positionId);

        if (!isDeciduousChartView) {
            return sourceId;
        }

        if (!canBeDeciduousTooth(positionId)) {
            return sourceId;
        }

        const positionNumber = getToothPositionNumber(positionId);
        const archPrefix = getChartArch(positionId);
        const half = getChartHalf(parseInt(positionId.slice(1), 10));

        const deciduousVisualMap = {
            5: 7, // E
            4: 6, // D
            3: 3, // C
            2: 2, // B
            1: 1  // A
        };

        const mappedPermanentNumber =
            deciduousVisualMap[positionNumber];

        if (!mappedPermanentNumber) {
            return sourceId;
        }

        return findToothIdByNumberAndHalf(
            archPrefix,
            half,
            mappedPermanentNumber
        );
    }

    function getSourceToothId(positionId) {
        const tooth = chartData[positionId];
        return tooth && tooth.sourceId ? tooth.sourceId : positionId;
    }
        /*
        false = Permanent Teeth: show positions 1-8.
        true  = Deciduous Teeth: show positions A-E and hide 6, 7 and 8.
    */
    let isDeciduousChartView = false;

        

    function shouldHideToothForDentition(toothId) {
        if (!isDeciduousChartView) {
            return false;
        }

        const positionNumber =
            getToothPositionNumber(toothId);

        return (
            positionNumber === 6 ||
            positionNumber === 7 ||
            positionNumber === 8
        );
    }

    function getDentitionToothClass(toothId) {
        return shouldHideToothForDentition(toothId)
            ? "dentition-hidden"
            : "";
    }

    function getDentitionNumberClass(positionNumber) {
        return (
            isDeciduousChartView &&
            (
                positionNumber === 6 ||
                positionNumber === 7 ||
                positionNumber === 8
            )
        )
            ? "dentition-hidden"
            : "";
    }
        function changeDentitionMode(isChecked) {

        /*
            Checked   = Deciduous Teeth
            Unchecked = Permanent Teeth
        */
        isDeciduousChartView = isChecked === true;

        const label =
            document.getElementById("dentitionModeLabel");

        const description =
            document.getElementById("dentitionModeDescription");

        const allTeeth = [
            ...UPPER_IDS,
            ...LOWER_IDS
        ];

        /*
            الأسنان من 1 إلى 5:
            - عند التشييك تصبح لبنية ويصغر شكلها.
            - تتغيّر التسميات إلى A-E.
            - المواضع 4 و5 تعرض بصريًا صور 6 و7 لتصبح D وE.
            - عند إزالة التشييك تعود دائمة 1-8.
        */
        allTeeth.forEach(function (toothId) {

            if (canBeDeciduousTooth(toothId)) {

                setToothDeciduousState(
                    toothId,
                    isDeciduousChartView
                );

            } else {

                /*
                    الأسنان 6 و7 و8 تظل دائمة دائماً.
                */
                setToothDeciduousState(
                    toothId,
                    false
                );
            }
        });

        if (isDeciduousChartView) {

            if (label) {
                label.textContent = "Deciduous Teeth";
            }

            if (description) {
                description.textContent = "Showing teeth A–E";
            }

            showToast(
                "تم تحويل عرض الأسنان إلى النظام اللبني A–E.",
                "success"
            );

        } else {

            if (label) {
                label.textContent = "Permanent Teeth";
            }

            if (description) {
                description.textContent = "Showing teeth 1–8";
            }

            showToast(
                "تم تحويل عرض الأسنان إلى النظام الدائم 1–8.",
                "success"
            );
        }

        /*
            إلغاء التحديد إذا كان السن المحدد من 6 أو 7 أو 8
            وأصبح مخفياً.
        */
        if (
            selectedTarget &&
            shouldHideToothForDentition(
                selectedTarget.toothId
            )
        ) {
            selectedTarget = null;
        }

        pendingSwapToothId = null;

        renderAll();
    }
    /*
        Deciduous / temporary teeth exist only in positions 1 through 5
        in every quadrant. Positions 6, 7, and 8 must remain permanent.
    */
    function getToothPositionNumber(tid) {
        const index = parseInt(tid.slice(1), 10);

        if (
            Number.isNaN(index) ||
            index < 0 ||
            index >= POS_LABELS.length
        ) {
            return null;
        }

        return POS_LABELS[index];
    }

    function canBeDeciduousTooth(tid) {
        const toothNumber = getToothPositionNumber(tid);

        return toothNumber !== null &&
               toothNumber >= 1 &&
               toothNumber <= 5;
    }

    const AREA_ICON_LOCK_GROUPS = [
        "disease",
        "previous",
        "inside"
    ];

    function isAreaIconLockGroup(group) {
        return AREA_ICON_LOCK_GROUPS.includes(group);
    }

    /*
        One icon only inside the SAME area from:
        - Disease
        - Previous Treatment
        - In-Hospital

        The tooth itself may still contain different icons in different areas.
        Example: Buccal, Lingual/Palatal, Mesial, Distal and Occlusal may each
        contain one different filling/treatment.
    */
    function getToolStorageArea(tool, requestedArea) {
        if (!tool) {
            return requestedArea;
        }

        if (isExtractedTool(tool.id)) {
            return "whole";
        }

        if (isRemainingRootTool(tool.id)) {
            return "root";
        }

        if (
            isWholeToothDiseaseTool(tool.id) ||
            isToothApplianceTool(tool.id) ||
            tool.scope === "whole"
        ) {
            return "whole";
        }

        if (tool.scope === "root") {
            return "root";
        }

        return requestedArea;
    }

    function getAreaSlot(tid, area) {
        const tooth = chartData[tid];

        if (!tooth) {
            return null;
        }

        if (area === "whole") {
            return tooth.whole;
        }

        return tooth.areas?.[area] || null;
    }

    function getAreaLockedMark(tid, area) {
        const slot = getAreaSlot(tid, area);

        if (!slot) {
            return null;
        }

        for (const group of AREA_ICON_LOCK_GROUPS) {
            const toolId = (slot[group] || [])[0];

            if (toolId) {
                return {
                    toolId,
                    group,
                    area,
                    tool: getTool(toolId)
                };
            }
        }

        return null;
    }

    function getAreaIconConflict(tid, area, incomingTool) {
        if (
            !incomingTool ||
            !isAreaIconLockGroup(incomingTool.group)
        ) {
            return null;
        }

        const existing = getAreaLockedMark(tid, area);

        if (!existing) {
            return null;
        }

        // Re-clicking the same icon does not add a duplicate.
        if (existing.toolId === incomingTool.id) {
            return null;
        }

        return existing;
    }

    function getAreaDisplayName(area) {
        const names = {
            whole: "Whole Tooth",
            root: "Root",
            buccal: "Buccal",
            lingual: "Lingual",
            palatal: "Palatal",
            mesial: "Mesial",
            distal: "Distal",
            occlusal: "Occlusal"
        };

        return names[area] || area;
    }

    function showAreaIconConflict(tid, area, incomingTool, existing) {
        const existingLabel = existing?.tool?.label || "أداة أخرى";
        const incomingLabel = incomingTool?.label || "الأداة الحالية";
        const areaLabel = getAreaDisplayName(area);

        showToast(
            `منطقة ${areaLabel} في السن ${tid} تحتوي بالفعل على "${existingLabel}". لا يمكن إضافة "${incomingLabel}" فوقها. اختر منطقة أخرى أو احذف الموجود أولًا.`,
            "warning"
        );
    }

    function canApplyLockedToolToArea(tid, area, tool) {
        const conflict = getAreaIconConflict(
            tid,
            area,
            tool
        );

        if (!conflict) {
            return true;
        }

        showAreaIconConflict(
            tid,
            area,
            tool,
            conflict
        );

        return false;
    }

    const CROWN_TOOL_IDS = [
        "metal_crown_prev",
        "zirconia_crown_prev",
        "emax_crown_prev",
        "pfm_crown_prev",
        "temporary_crown_prev",
        "stainless_crown_prev",

        "metal_crown_in",
        "ceramic_crown_in",
        "emax_crown_in",
        "pfm_crown_in",
        "temporary_crown_in",
        "stainless_crown_in"
    ];

    function isCrownTool(toolId = selectedToolId) {
        return CROWN_TOOL_IDS.includes(toolId);
    }

    /*
        A Crown covers exactly five Surface areas.

        Upper jaw:
            buccal, palatal, mesial, distal, occlusal

        Lower jaw:
            buccal, lingual, mesial, distal, occlusal
    */
    function getCrownSurfaceAreas(tid) {
        const insideArea = tid.startsWith("U")
            ? "palatal"
            : "lingual";

        return [
            "buccal",
            insideArea,
            "mesial",
            "distal",
            "occlusal"
        ];
    }

    function getCrownMark(tid) {
        const tooth = chartData[tid];

        if (!tooth) {
            return null;
        }

        const groups = [
            "previous",
            "inside"
        ];

        /*
            New storage:
            Crown is written into all five Surface areas so ChartDataJson,
            ReportJson and DentalToothData all contain the five areas.
        */
        const crownAreas = getCrownSurfaceAreas(tid);

        for (const area of crownAreas) {
            const slot = tooth.areas?.[area];

            if (!slot) {
                continue;
            }

            for (const group of groups) {
                const toolId = (slot[group] || [])
                    .find(id => isCrownTool(id));

                if (toolId) {
                    return {
                        group,
                        area,
                        toolId,
                        tool: getTool(toolId),
                        storageArea: area
                    };
                }
            }
        }

        /*
            Backward compatibility:
            older sessions may have stored Crown on Whole Tooth or on only
            one Surface area.
        */
        for (const group of groups) {
            const toolId = (tooth.whole?.[group] || [])
                .find(id => isCrownTool(id));

            if (toolId) {
                return {
                    group,
                    toolId,
                    tool: getTool(toolId),
                    storageArea: "whole"
                };
            }
        }

        const areas = [
            "buccal",
            "lingual",
            "palatal",
            "mesial",
            "distal",
            "occlusal",
            "root"
        ];

        for (const area of areas) {
            const slot = tooth.areas?.[area];

            if (!slot) {
                continue;
            }

            for (const group of groups) {
                const toolId = (slot[group] || [])
                    .find(id => isCrownTool(id));

                if (toolId) {
                    return {
                        group,
                        area,
                        toolId,
                        tool: getTool(toolId),
                        storageArea: area
                    };
                }
            }
        }

        return null;
    }

    function removeAllCrownMarks(tid) {
        const tooth = chartData[tid];

        if (!tooth) {
            return;
        }

        const groups = [
            "disease",
            "previous",
            "inside",
            "others"
        ];

        const areas = [
            "buccal",
            "lingual",
            "palatal",
            "mesial",
            "distal",
            "occlusal",
            "root"
        ];

        groups.forEach(group => {
            tooth.whole[group] = (tooth.whole[group] || [])
                .filter(id => !isCrownTool(id));
        });

        areas.forEach(area => {
            const slot = tooth.areas?.[area];

            if (!slot) {
                return;
            }

            groups.forEach(group => {
                slot[group] = (slot[group] || [])
                    .filter(id => !isCrownTool(id));
            });
        });
    }

    function applyCrownToTooth(tid, tool) {
        const tooth = chartData[tid];

        if (
            !tooth ||
            !tool ||
            !isCrownTool(tool.id)
        ) {
            return false;
        }

        const crownAreas =
            getCrownSurfaceAreas(tid);

        /*
            Crown occupies all five Surface areas.

            Before applying, verify that none of those areas already contains
            another Disease / Previous Treatment / In-Hospital action.
        */
        for (const area of crownAreas) {
            const conflict = getAreaIconConflict(
                tid,
                area,
                tool
            );

            if (conflict) {
                showAreaIconConflict(
                    tid,
                    area,
                    tool,
                    conflict
                );
                return false;
            }
        }

        removeAllCrownMarks(tid);

        crownAreas.forEach(area => {
            const slot = tooth.areas?.[area];

            if (!slot) {
                return;
            }

            if (!Array.isArray(slot[tool.group])) {
                slot[tool.group] = [];
            }

            if (!slot[tool.group].includes(tool.id)) {
                slot[tool.group].push(tool.id);
            }
        });

        return true;
    }

    function normalizeCrownMark(tid) {
        const tooth = chartData[tid];

        if (!tooth) {
            return;
        }

        const found = [];
        const groups = [
            "previous",
            "inside"
        ];
        const scanAreas = [
            "buccal",
            "lingual",
            "palatal",
            "mesial",
            "distal",
            "occlusal",
            "root"
        ];

        groups.forEach(group => {
            (tooth.whole?.[group] || []).forEach(toolId => {
                if (isCrownTool(toolId)) {
                    found.push({
                        group,
                        toolId
                    });
                }
            });
        });

        scanAreas.forEach(area => {
            const slot = tooth.areas?.[area];

            if (!slot) {
                return;
            }

            groups.forEach(group => {
                (slot[group] || []).forEach(toolId => {
                    if (isCrownTool(toolId)) {
                        found.push({
                            group,
                            toolId
                        });
                    }
                });
            });
        });

        if (!found.length) {
            return;
        }

        /*
            Use the final Crown found, remove duplicate/legacy values, then
            write the same Crown into the five correct Surface areas.
        */
        const chosen =
            found[found.length - 1];

        removeAllCrownMarks(tid);

        getCrownSurfaceAreas(tid).forEach(area => {
            const slot = tooth.areas?.[area];

            if (!slot) {
                return;
            }

            if (!Array.isArray(slot[chosen.group])) {
                slot[chosen.group] = [];
            }

            if (!slot[chosen.group].includes(chosen.toolId)) {
                slot[chosen.group].push(
                    chosen.toolId
                );
            }
        });
    }

    const BRIDGE_TOOL_IDS = [
        "resin_bonded_bridge_prev",
        "resin_bonded_bridge_in"
    ];

    const SPACE_MAINTAINER_TOOL_IDS = [
        "space_maintainer_prev",
        "space_maintainer_in"
    ];

    const TOOTH_APPLIANCE_TOOL_IDS = [
        ...BRIDGE_TOOL_IDS,
        ...SPACE_MAINTAINER_TOOL_IDS
    ];

    function isBridgeTool(toolId = selectedToolId) {
        return BRIDGE_TOOL_IDS.includes(toolId);
    }

    function isSpaceMaintainerTool(toolId = selectedToolId) {
        return SPACE_MAINTAINER_TOOL_IDS.includes(toolId);
    }

    function isToothApplianceTool(toolId = selectedToolId) {
        return TOOTH_APPLIANCE_TOOL_IDS.includes(toolId);
    }

    function getToothApplianceFamily(toolId) {
        if (BRIDGE_TOOL_IDS.includes(toolId)) return "bridge";
        if (SPACE_MAINTAINER_TOOL_IDS.includes(toolId)) return "spaceMaintainer";
        return null;
    }

    const TEETH_TRANSPOSITION_TOOL_ID = "teeth_transposition";
    const PERMANENT_DECIDUOUS_TOOL_ID = "teeth_change";

    /*
        Swapped functions:

        Teeth Transposition:
        - Select the first tooth and then the second tooth.
        - Swap their positions.

        Teeth Change Permanent/Deciduous:
        - Convert tooth positions 1-5 to a deciduous / temporary tooth.
        - Show the same tooth image slightly smaller.
    */
    function isTeethTranspositionTool(toolId = selectedToolId) {
        return toolId === TEETH_TRANSPOSITION_TOOL_ID;
    }

    function isPermanentDeciduousTool(toolId = selectedToolId) {
        return toolId === PERMANENT_DECIDUOUS_TOOL_ID;
    }

    /*
        Teeth Change Permanent/Deciduous marks a permanent tooth as
        deciduous / temporary.

        The state is stored once on the whole tooth and the front tooth image
        is rendered slightly smaller. No treatment pattern is added to the
        Lingual / Palatal diagram.
    */
    function setToothDeciduousState(tid, makeDeciduous = true) {
        const tooth = chartData[tid];
        if (!tooth) return false;

        /*
            Only tooth positions 1-5 can become deciduous.
            Positions 6-8 remain permanent and are never resized.
        */
        if (
            makeDeciduous === true &&
            !canBeDeciduousTooth(tid)
        ) {
            return false;
        }

        const groups = ["disease", "previous", "inside", "others"];
        const areas = [
            "buccal", "lingual", "palatal",
            "mesial", "distal", "occlusal", "root"
        ];

        /*
            Remove duplicate/legacy deciduous markers.

            Older sessions stored this state under teeth_transposition.
            The new correct storage ID is teeth_change.
        */
        const deciduousMarkerIds = [
            PERMANENT_DECIDUOUS_TOOL_ID,
            TEETH_TRANSPOSITION_TOOL_ID
        ];

        groups.forEach(group => {
            tooth.whole[group] = (tooth.whole[group] || [])
                .filter(id => !deciduousMarkerIds.includes(id));
        });

        areas.forEach(area => {
            const slot = tooth.areas?.[area];
            if (!slot) return;

            groups.forEach(group => {
                slot[group] = (slot[group] || [])
                    .filter(id => !deciduousMarkerIds.includes(id));
            });
        });

        tooth.isDeciduous = makeDeciduous === true;

        if (tooth.isDeciduous) {
            if (!Array.isArray(tooth.whole.others)) {
                tooth.whole.others = [];
            }

            tooth.whole.others.push(PERMANENT_DECIDUOUS_TOOL_ID);
        }

        return true;
    }

    function normalizePermanentDeciduousState(tid) {
        const tooth = chartData[tid];
        if (!tooth) return;

        const groups = ["disease", "previous", "inside", "others"];
        const areas = [
            "buccal", "lingual", "palatal",
            "mesial", "distal", "occlusal", "root"
        ];

        const compatibleMarkerIds = [
            PERMANENT_DECIDUOUS_TOOL_ID,
            TEETH_TRANSPOSITION_TOOL_ID
        ];

        let found = tooth.isDeciduous === true;

        groups.forEach(group => {
            if (
                (tooth.whole?.[group] || [])
                    .some(id => compatibleMarkerIds.includes(id))
            ) {
                found = true;
            }
        });

        areas.forEach(area => {
            const slot = tooth.areas?.[area];
            if (!slot) return;

            groups.forEach(group => {
                if (
                    (slot[group] || [])
                        .some(id => compatibleMarkerIds.includes(id))
                ) {
                    found = true;
                }
            });
        });

        /*
            Convert legacy teeth_transposition deciduous records to the new
            teeth_change marker and remove invalid states from teeth 6-8.
        */
        setToothDeciduousState(
            tid,
            found && canBeDeciduousTooth(tid)
        );
    }

    const REMAINING_ROOT_TOOL_ID = "remaining_root";

    function isRemainingRootTool(toolId = selectedToolId) {
        return toolId === REMAINING_ROOT_TOOL_ID;
    }

    function getRemainingRootMark(tid) {
        const marks = getAreaMarks(tid, "root");

        return marks.find(mark =>
            mark.tool &&
            mark.tool.id === REMAINING_ROOT_TOOL_ID
        ) || null;
    }

    /*
        Remaining Root is displayed only over the anatomical root half
        of the front tooth image.

        Upper jaw root = upper half.
        Lower jaw root = lower half.
    */
    function remainingRootOverlay(tid, arch) {
        const mark = getRemainingRootMark(tid);

        if (!mark || !mark.tool) {
            return "";
        }

        const color = GROUP_COLORS[mark.group] || GROUP_COLORS.disease;
        const iconTop = arch === "upper" ? 0.75 : 11.15;
        const iconSize = 7.35;
        const scale = iconSize / 24;

        return `
            <g class="remaining-root-icon"
               pointer-events="none"
               transform="translate(1.82,${iconTop})">
                <g transform="scale(${scale})">
                    ${iconSvg(
                        "remainingRoot",
                        color,
                        24,
                        mark.group
                    )}
                </g>
            </g>`;
    }

    /*
        Remaining Root means the crown/tooth part is broken away.
        When it exists, hide the opposite half of the front tooth image:

        Upper jaw  -> keep root (upper half), hide lower half.
        Lower jaw  -> keep root (lower half), hide upper half.
    */
    function remainingRootHideOtherHalfOverlay(tid, arch, splitY) {
        const mark = getRemainingRootMark(tid);

        if (!mark) {
            return "";
        }

        const hideY = arch === "upper" ? splitY : 0;

        return `
            <rect x="0"
                  y="${hideY}"
                  width="11"
                  height="${splitY}"
                  fill="#ffffff"
                  opacity="1"
                  pointer-events="none"/>`;
    }

    function rejectRemainingRootOutsideRoot() {
        showToast(
            "Remaining Root مسموح فقط على جذر صورة السن، وليس على Surface.",
            "warning"
        );
    }

    const WHOLE_TOOTH_DISEASE_TOOL_IDS = [
        "periapical_lesion",
        "crack_tooth",
        "tooth_mobility"
    ];

    function isWholeToothDiseaseTool(toolId = selectedToolId) {
        return WHOLE_TOOTH_DISEASE_TOOL_IDS.includes(toolId);
    }

    /*
        Return the active whole-tooth disease mark.

        Only one of these three visual whole-tooth conditions is kept at
        a time, preventing their large overlays from becoming cluttered.
    */
    function getWholeToothDiseaseMark(tid) {
        const tooth = chartData[tid];
        if (!tooth) return null;

        const toolId = (tooth.whole?.disease || [])
            .find(id => WHOLE_TOOTH_DISEASE_TOOL_IDS.includes(id));

        if (!toolId) return null;

        return {
            group: "disease",
            toolId,
            tool: getTool(toolId)
        };
    }

    function removeWholeToothDiseaseMarks(tid) {
        const tooth = chartData[tid];
        if (!tooth) return;

        const groups = ["disease", "previous", "inside", "others"];
        const areas = [
            "buccal", "lingual", "palatal",
            "mesial", "distal", "occlusal", "root"
        ];

        groups.forEach(group => {
            tooth.whole[group] = (tooth.whole[group] || [])
                .filter(id => !WHOLE_TOOTH_DISEASE_TOOL_IDS.includes(id));
        });

        areas.forEach(area => {
            const slot = tooth.areas?.[area];
            if (!slot) return;

            groups.forEach(group => {
                slot[group] = (slot[group] || [])
                    .filter(id => !WHOLE_TOOTH_DISEASE_TOOL_IDS.includes(id));
            });
        });
    }

    function applyWholeToothDisease(tid, tool) {
        const tooth = chartData[tid];

        if (
            !tooth ||
            !tool ||
            !isWholeToothDiseaseTool(tool.id)
        ) {
            return false;
        }

        if (
            !canApplyLockedToolToArea(
                tid,
                "whole",
                tool
            )
        ) {
            return false;
        }

        /*
            Periapical Lesion, Crack Tooth, and Tooth Mobility use large
            whole-tooth graphics. Keep only the most recently selected one.
        */
        removeWholeToothDiseaseMarks(tid);

        if (!Array.isArray(tooth.whole.disease)) {
            tooth.whole.disease = [];
        }

        tooth.whole.disease.push(tool.id);
        return true;
    }

    /*
        Upgrade old sessions where one of these tools was stored on an
        individual surface. Move the final located one to the whole tooth.
    */
    function normalizeWholeToothDisease(tid) {
        const tooth = chartData[tid];
        if (!tooth) return;

        const groups = ["disease", "previous", "inside", "others"];
        const areas = [
            "buccal", "lingual", "palatal",
            "mesial", "distal", "occlusal", "root"
        ];

        const found = [];

        groups.forEach(group => {
            (tooth.whole?.[group] || []).forEach(toolId => {
                if (WHOLE_TOOTH_DISEASE_TOOL_IDS.includes(toolId)) {
                    found.push(toolId);
                }
            });
        });

        areas.forEach(area => {
            const slot = tooth.areas?.[area];
            if (!slot) return;

            groups.forEach(group => {
                (slot[group] || []).forEach(toolId => {
                    if (WHOLE_TOOTH_DISEASE_TOOL_IDS.includes(toolId)) {
                        found.push(toolId);
                    }
                });
            });
        });

        if (!found.length) return;

        const selectedToolId = found[found.length - 1];

        removeWholeToothDiseaseMarks(tid);
        tooth.whole.disease.push(selectedToolId);
    }

    const EXTRACTED_TOOL_IDS = [
        "extracted_tooth",
        "extracted_tooth_in"
    ];

    function isExtractedTool(toolId = selectedToolId) {
        return EXTRACTED_TOOL_IDS.includes(toolId);
    }

    /*
        Return the single Bridge / Space Maintainer selected for a tooth.

        New values are stored in tooth.whole. Area scanning remains for
        compatibility with previously saved sessions.
    */
    function getToothApplianceMark(tid, requestedFamily = null) {
        const tooth = chartData[tid];
        if (!tooth) return null;

        const groups = ["disease", "previous", "inside", "others"];
        const areas = [
            "buccal", "lingual", "palatal",
            "mesial", "distal", "occlusal", "root"
        ];

        const matchesFamily = toolId => {
            if (!TOOTH_APPLIANCE_TOOL_IDS.includes(toolId)) return false;
            return !requestedFamily ||
                   getToothApplianceFamily(toolId) === requestedFamily;
        };

        // Prefer the new whole-tooth storage.
        for (const group of groups) {
            const toolId = (tooth.whole?.[group] || []).find(matchesFamily);

            if (toolId) {
                return {
                    group,
                    toolId,
                    tool: getTool(toolId),
                    family: getToothApplianceFamily(toolId),
                    storageArea: "whole"
                };
            }
        }

        // Backward compatibility for old Root/Surface records.
        for (const area of areas) {
            const slot = tooth.areas?.[area];
            if (!slot) continue;

            for (const group of groups) {
                const toolId = (slot[group] || []).find(matchesFamily);

                if (toolId) {
                    return {
                        group,
                        area,
                        toolId,
                        tool: getTool(toolId),
                        family: getToothApplianceFamily(toolId),
                        storageArea: area
                    };
                }
            }
        }

        return null;
    }

    function removeAllToothAppliances(tid) {
        const tooth = chartData[tid];
        if (!tooth) return;

        const groups = ["disease", "previous", "inside", "others"];
        const areas = [
            "buccal", "lingual", "palatal",
            "mesial", "distal", "occlusal", "root"
        ];

        groups.forEach(group => {
            tooth.whole[group] = (tooth.whole[group] || [])
                .filter(id => !TOOTH_APPLIANCE_TOOL_IDS.includes(id));
        });

        areas.forEach(area => {
            const slot = tooth.areas?.[area];
            if (!slot) return;

            groups.forEach(group => {
                slot[group] = (slot[group] || [])
                    .filter(id => !TOOTH_APPLIANCE_TOOL_IDS.includes(id));
            });
        });
    }

    /*
        Only one appliance is allowed on a tooth.

        Selecting Previous Treatment after In-Hospital, or the opposite,
        replaces the old value instead of drawing both on top of each other.

        Selecting Bridge after Space Maintainer, or the opposite, also
        replaces the old appliance so the tooth never receives two icons.
    */
    function applyToothAppliance(tid, tool) {
        const tooth = chartData[tid];

        if (!tooth || !tool || !isToothApplianceTool(tool.id)) {
            return false;
        }

        if (
            !canApplyLockedToolToArea(
                tid,
                "whole",
                tool
            )
        ) {
            return false;
        }

        removeAllToothAppliances(tid);

        if (!Array.isArray(tooth.whole[tool.group])) {
            tooth.whole[tool.group] = [];
        }

        tooth.whole[tool.group].push(tool.id);
        return true;
    }

    /*
        Normalize old saved sessions:
        - Move old Root/Surface Bridge or Space Maintainer to the whole tooth.
        - Keep one appliance only.
    */
    function normalizeSingleToothLockedMark(tid) {
        const tooth = chartData[tid];
        if (!tooth) return;

        const areas = [
            "buccal", "lingual", "palatal",
            "mesial", "distal", "occlusal", "root"
        ];

        function normalizeOneAreaSlot(slot) {
            if (!slot) return;

            let hasKeptIcon = false;

            AREA_ICON_LOCK_GROUPS.forEach(group => {
                const oldValues = Array.isArray(slot[group])
                    ? slot[group]
                    : [];

                if (hasKeptIcon) {
                    slot[group] = [];
                    return;
                }

                if (oldValues.length > 0) {
                    slot[group] = [oldValues[0]];
                    hasKeptIcon = true;
                } else {
                    slot[group] = [];
                }
            });
        }

        /*
            Keep one icon in Whole Tooth, and independently keep one icon
            in each surface area. Different surface areas do not affect
            one another.
        */
        normalizeOneAreaSlot(tooth.whole);

        areas.forEach(area => {
            normalizeOneAreaSlot(tooth.areas?.[area]);
        });
    }

    function normalizeToothAppliance(tid) {
        const tooth = chartData[tid];
        if (!tooth) return;

        const groups = ["disease", "previous", "inside", "others"];
        const areas = [
            "buccal", "lingual", "palatal",
            "mesial", "distal", "occlusal", "root"
        ];

        const found = [];

        groups.forEach(group => {
            (tooth.whole?.[group] || []).forEach(toolId => {
                if (TOOTH_APPLIANCE_TOOL_IDS.includes(toolId)) {
                    found.push({ group, toolId });
                }
            });
        });

        areas.forEach(area => {
            const slot = tooth.areas?.[area];
            if (!slot) return;

            groups.forEach(group => {
                (slot[group] || []).forEach(toolId => {
                    if (TOOTH_APPLIANCE_TOOL_IDS.includes(toolId)) {
                        found.push({ group, toolId });
                    }
                });
            });
        });

        if (!found.length) return;

        /*
            When an old session contains both Previous and In-Hospital values,
            retain only one. The final located value is used.
        */
        const chosen = found[found.length - 1];

        removeAllToothAppliances(tid);

        if (!Array.isArray(tooth.whole[chosen.group])) {
            tooth.whole[chosen.group] = [];
        }

        tooth.whole[chosen.group].push(chosen.toolId);
    }

    function getPairConnectorColor(leftMark, rightMark) {
        if (!leftMark || !rightMark) {
            return "#64748b";
        }

        if (leftMark.group === rightMark.group) {
            return GROUP_COLORS[leftMark.group];
        }

        return "#64748b";
    }

    function connectorCurveSvg(x1, x2, y, curveAmount, color) {
        const middleX = (x1 + x2) / 2;
        const controlY = y - curveAmount;
        const path = `M ${x1} ${y} Q ${middleX} ${controlY} ${x2} ${y}`;

        return `
            <path d="${path}"
                  fill="none"
                  stroke="#ffffff"
                  stroke-width="1.55"
                  stroke-linecap="round"
                  stroke-linejoin="round"/>

            <path d="${path}"
                  fill="none"
                  stroke="${color}"
                  stroke-width="0.68"
                  stroke-linecap="round"
                  stroke-linejoin="round"/>`;
    }

    /*
        Bridge chain connectors for normal teeth:
        If adjacent teeth both have Bridge, draw a clean connector segment
        between them even when there is no extracted tooth in the middle.

        This allows:
        - Bridge + Bridge  => line between them
        - Bridge + Bridge + Bridge => one continuous shared line
    */
    function getDirectBridgeSegments(tid, arch) {
        if (isToothExtracted(tid)) {
            return [];
        }

        const currentMark = getToothApplianceMark(tid, "bridge");

        if (!currentMark) {
            return [];
        }

        const archIds = tid.startsWith("U")
            ? UPPER_IDS
            : LOWER_IDS;

        const index = archIds.indexOf(tid);

        if (index < 0) {
            return [];
        }

        const baseY = arch === "upper"
            ? 15.0
            : 6.0;

        const segments = [];

        // Left adjacent Bridge tooth
        if (index > 0) {
            const leftId = archIds[index - 1];

            if (!isToothExtracted(leftId)) {
                const leftMark = getToothApplianceMark(leftId, "bridge");

                if (leftMark) {
                    segments.push({
                        x1: -2.4,
                        x2: 5.6,
                        y: baseY,
                        curve: 0.34,
                        color: getPairConnectorColor(leftMark, currentMark)
                    });
                }
            }
        }

        // Right adjacent Bridge tooth
        if (index < archIds.length - 1) {
            const rightId = archIds[index + 1];

            if (!isToothExtracted(rightId)) {
                const rightMark = getToothApplianceMark(rightId, "bridge");

                if (rightMark) {
                    segments.push({
                        x1: 5.4,
                        x2: 13.4,
                        y: baseY,
                        curve: 0.34,
                        color: getPairConnectorColor(currentMark, rightMark)
                    });
                }
            }
        }

        return segments;
    }

    /*
        Gap connector exists only for the extracted middle tooth:

            appliance + extracted tooth + same appliance family

        This is kept for both Bridge and Space Maintainer.
    */
    function getGapConnectorInfo(tid) {
        if (!isToothExtracted(tid)) {
            return null;
        }

        const archIds = tid.startsWith("U")
            ? UPPER_IDS
            : LOWER_IDS;

        const index = archIds.indexOf(tid);

        if (
            index <= 0 ||
            index >= archIds.length - 1
        ) {
            return null;
        }

        const leftId  = archIds[index - 1];
        const rightId = archIds[index + 1];

        if (
            isToothExtracted(leftId) ||
            isToothExtracted(rightId)
        ) {
            return null;
        }

        const leftMark  = getToothApplianceMark(leftId);
        const rightMark = getToothApplianceMark(rightId);

        if (
            !leftMark ||
            !rightMark ||
            leftMark.family !== rightMark.family
        ) {
            return null;
        }

        return {
            family: leftMark.family,
            leftMark,
            rightMark
        };
    }

    /*
        Draw front connector overlays.

        Rules:
        1. Bridge on normal adjacent teeth => draw connecting line(s).
        2. 3 consecutive Bridge teeth share one continuous line visually.
        3. appliance + extracted + same appliance => draw gap connector
           from the extracted middle tooth.
        4. If a supporting tooth becomes extracted, the connector disappears.
    */
    function frontToothConnectorOverlay(tid, arch) {
        const baseY = arch === "upper"
            ? 15.0
            : 6.0;

        let svg = "";

        // Extracted middle-tooth connector for Bridge / Space Maintainer.
        const gapInfo = getGapConnectorInfo(tid);

        if (gapInfo) {
            const color = getPairConnectorColor(
                gapInfo.leftMark,
                gapInfo.rightMark
            );

            if (gapInfo.family === "spaceMaintainer") {
                svg += connectorCurveSvg(-4.0, 15.0, baseY - 0.72, 0.55, color);
                svg += connectorCurveSvg(-4.0, 15.0, baseY + 0.72, 0.55, color);
            } else {
                svg += connectorCurveSvg(-4.0, 15.0, baseY, 0.75, color);
            }
        }

        // Normal Bridge chain connectors on non-extracted teeth.
        const bridgeSegments = getDirectBridgeSegments(tid, arch);

        bridgeSegments.forEach(seg => {
            svg += connectorCurveSvg(
                seg.x1,
                seg.x2,
                seg.y,
                seg.curve,
                seg.color
            );
        });

        if (!svg) {
            return "";
        }

        return `
            <g class="tooth-connector-overlay"
               pointer-events="none">
                ${svg}
            </g>`;
    }

    /*
        Draw exactly one Bridge or Space Maintainer icon on the tooth crown.

        Upper jaw crown = lower half of the image.
        Lower jaw crown = upper half of the image.
    */
    function toothApplianceOverlay(tid, arch) {
        const mark = getToothApplianceMark(tid);
        if (!mark || !mark.tool) return "";

        const color = GROUP_COLORS[mark.group];
        const iconTop = arch === "upper" ? 12.0 : 1.5;
        const iconSize = 7.1;
        const scale = iconSize / 24;

        return `
            <g class="tooth-appliance-icon" pointer-events="none"
               transform="translate(1.95,${iconTop})">
                <g transform="scale(${scale})">
                    ${iconSvg(mark.tool.glyph, color, 24, mark.group)}
                </g>
            </g>`;
    }

    function crownTreatmentOverlay(
        tid,
        arch,
        splitY
    ) {
        const mark = getCrownMark(tid);

        if (!mark || !mark.tool) {
            return "";
        }

        const color =
            GROUP_COLORS[mark.group] ||
            GROUP_COLORS.previous;

        /*
            Upper jaw crown = lower half.
            Lower jaw crown = upper half.

            Requested behavior:
            - No shading/pattern on the tooth image.
            - Only a smaller tidy outline box.
        */
        const crownY =
            arch === "upper"
                ? splitY
                : 0;

        const boxX = 1.85;
        const boxY = crownY + 1.65;
        const boxWidth = 7.30;
        const boxHeight = splitY - 3.30;

        return `
            <g class="crown-treatment-overlay"
               pointer-events="none">

                <!-- Small outline only: no fill / no shading -->
                <rect x="${boxX}"
                      y="${boxY}"
                      width="${boxWidth}"
                      height="${boxHeight}"
                      rx="1.12"
                      fill="none"
                      stroke="${color}"
                      stroke-width="0.66"/>

                <!-- Fine inner white line for readability -->
                <rect x="${boxX + 0.28}"
                      y="${boxY + 0.28}"
                      width="${boxWidth - 0.56}"
                      height="${boxHeight - 0.56}"
                      rx="0.92"
                      fill="none"
                      stroke="#ffffff"
                      stroke-opacity="0.84"
                      stroke-width="0.18"/>
            </g>`;
    }

    function rejectCrownOnRoot(label) {
        showToast(
            `${label} مسموح فقط على تاج السن، وليس على الجذر.`,
            "warning"
        );
    }

    function rejectToothApplianceOnRoot(label) {
        showToast(
            `${label} ممنوع على الجذر. اختاره على جسم السن في الاتجاه الصحيح داخل Lingual / Palatal.`,
            "warning"
        );
    }

    /*
        Return the first Extracted Tooth mark found for this tooth.

        New selections are stored on the whole tooth. Area checks are kept
        for backward compatibility with sessions saved by older versions.
    */
    function getExtractedMark(tid) {
        const tooth = chartData[tid];
        if (!tooth) return null;

        const groups = ["disease", "previous", "inside", "others"];
        const areas = [
            "buccal", "lingual", "palatal",
            "mesial", "distal", "occlusal", "root"
        ];

        for (const group of groups) {
            const toolId = (tooth.whole?.[group] || [])
                .find(id => EXTRACTED_TOOL_IDS.includes(id));

            if (toolId) {
                return {
                    group,
                    toolId,
                    tool: getTool(toolId)
                };
            }
        }

        for (const area of areas) {
            const slot = tooth.areas?.[area];
            if (!slot) continue;

            for (const group of groups) {
                const toolId = (slot[group] || [])
                    .find(id => EXTRACTED_TOOL_IDS.includes(id));

                if (toolId) {
                    return {
                        group,
                        area,
                        toolId,
                        tool: getTool(toolId)
                    };
                }
            }
        }

        return null;
    }

    function isToothExtracted(tid) {
        return !!getExtractedMark(tid);
    }

    /*
        Store Extracted Tooth once on the whole tooth.

        Any old Extracted Tooth entries saved on individual areas are removed
        first to prevent duplicate report entries.
    */
    function applyExtractedToWholeTooth(tid, tool) {
        const tooth = chartData[tid];
        if (!tooth || !tool) return false;

        /*
            An extracted tooth cannot remain a Bridge or Space Maintainer
            supporting tooth. Remove the appliance first so every connector
            disappears immediately.
        */
        removeAllToothAppliances(tid);

        const groups = ["disease", "previous", "inside", "others"];
        const areas = [
            "buccal", "lingual", "palatal",
            "mesial", "distal", "occlusal", "root"
        ];

        groups.forEach(group => {
            tooth.whole[group] = (tooth.whole[group] || [])
                .filter(id => !EXTRACTED_TOOL_IDS.includes(id));
        });

        areas.forEach(area => {
            const slot = tooth.areas?.[area];
            if (!slot) return;

            groups.forEach(group => {
                slot[group] = (slot[group] || [])
                    .filter(id => !EXTRACTED_TOOL_IDS.includes(id));
            });
        });

        if (!Array.isArray(tooth.whole[tool.group])) {
            tooth.whole[tool.group] = [];
        }

        tooth.whole[tool.group].push(tool.id);
        return true;
    }

    function removeExtractedFromTooth(tid) {
        const tooth = chartData[tid];
        if (!tooth) return;

        const groups = ["disease", "previous", "inside", "others"];
        const areas = [
            "buccal", "lingual", "palatal",
            "mesial", "distal", "occlusal", "root"
        ];

        groups.forEach(group => {
            tooth.whole[group] = (tooth.whole[group] || [])
                .filter(id => !EXTRACTED_TOOL_IDS.includes(id));
        });

        areas.forEach(area => {
            const slot = tooth.areas?.[area];
            if (!slot) return;

            groups.forEach(group => {
                slot[group] = (slot[group] || [])
                    .filter(id => !EXTRACTED_TOOL_IDS.includes(id));
            });
        });
    }

    function rejectExtractedToothAction(tid) {
        showToast(
            `السن ${tid} مخلوع. احذف Extracted Tooth أو استخدم Clear Tooth قبل إجراء أي تعديل.`,
            "warning"
        );
    }

    /*
        Draw Periapical Lesion, Crack Tooth, or Tooth Mobility only over
        the front tooth image.

        These tools are intentionally not rendered on Lingual / Palatal
        Surface. Tooth Mobility uses its tidy tooth-shaped mark without the
        horizontal arrow after application.
    */
    function wholeToothDiseaseFrontOverlay(tid, arch) {
        const mark = getWholeToothDiseaseMark(tid);
        if (!mark || !mark.tool) return "";

        const color = GROUP_COLORS[mark.group] || GROUP_COLORS.disease;
        const glyph = mark.tool.glyph;

        if (glyph === "mobility") {
            const patternId = `front_mobility_${tid}`;
            const mobilityTransform =
                "translate(-2.0,2.5) scale(0.46,0.48)";

            return `
                <g class="whole-disease-front mobility"
                   pointer-events="none"
                   opacity="0.92">
                    <defs>
                        ${glyphPattern(patternId, "mobility", color)}
                    </defs>

                    <!--
                        Thin outline only: no white fill, so the original
                        tooth image remains clearly visible.
                    -->
                    <path d="M12 7 Q16 6 20 7 L19 26 Q16 28 13 26 Z"
                          transform="${mobilityTransform}"
                          fill="none"
                          stroke="#ffffff"
                          stroke-width="3"
                          stroke-linecap="round"
                          stroke-linejoin="round"/>

                    <!-- Small and tidy applied Tooth Mobility mark -->
                    <path d="M12 7 Q16 6 20 7 L19 26 Q16 28 13 26 Z"
                          transform="${mobilityTransform}"
                          fill="url(#${patternId})"
                          stroke="${color}"
                          stroke-width="1.55"
                          stroke-linecap="round"
                          stroke-linejoin="round"/>
                </g>`;
        }

        if (glyph === "crack") {
            return `
                <g class="whole-disease-front crack" pointer-events="none">
                    <!-- White halo -->
                    <path d="M6.25 1.25
                             L4.35 5.25
                             L6.25 8.15
                             L4.15 11.45
                             L6.35 14.55
                             L4.65 19.75"
                          fill="none"
                          stroke="#ffffff"
                          stroke-width="1.65"
                          stroke-linecap="round"
                          stroke-linejoin="round"/>

                    <!-- Crack -->
                    <path d="M6.25 1.25
                             L4.35 5.25
                             L6.25 8.15
                             L4.15 11.45
                             L6.35 14.55
                             L4.65 19.75"
                          fill="none"
                          stroke="${color}"
                          stroke-width="0.88"
                          stroke-linecap="round"
                          stroke-linejoin="round"/>
                </g>`;
        }

        if (glyph === "periapical") {
            const lesionY = arch === "upper" ? 2.35 : 18.65;
            const stemStart = arch === "upper" ? 3.9 : 17.1;
            const stemEnd = arch === "upper" ? 10.8 : 10.2;

            return `
                <g class="whole-disease-front periapical" pointer-events="none">
                    <!-- White halo around the root canal/lesion symbol -->
                    <path d="M5.5 ${stemStart} V${stemEnd}"
                          stroke="#ffffff"
                          stroke-width="1.75"
                          stroke-linecap="round"/>
                    <ellipse cx="5.5"
                             cy="${lesionY}"
                             rx="2.35"
                             ry="1.55"
                             fill="#ffffff"
                             stroke="#ffffff"
                             stroke-width="1.15"/>

                    <!-- Periapical lesion -->
                    <path d="M5.5 ${stemStart} V${stemEnd}"
                          stroke="${color}"
                          stroke-width="0.88"
                          stroke-linecap="round"/>
                    <ellipse cx="5.5"
                             cy="${lesionY}"
                             rx="2.05"
                             ry="1.25"
                             fill="${hexToRgba(color, .24)}"
                             stroke="${color}"
                             stroke-width="0.72"/>
                </g>`;
        }

        return "";
    }

    /*
        Draw the same clean X used in the Lingual / Palatal surface diagram
        directly over the front tooth image.
    */
    function extractedToothOverlay(tid) {
        const mark = getExtractedMark(tid);
        if (!mark) return "";

        const color = GROUP_COLORS[mark.group] || GROUP_COLORS.others;

        return `
            <g class="extracted-tooth-overlay" pointer-events="none">
                <!-- White underlay keeps the X readable over every tooth image -->
                <path d="M1.55 1.45 L9.45 19.55"
                      stroke="#ffffff"
                      stroke-width="1.55"
                      stroke-linecap="round"/>
                <path d="M9.45 1.45 L1.55 19.55"
                      stroke="#ffffff"
                      stroke-width="1.55"
                      stroke-linecap="round"/>

                <!-- Actual Extracted Tooth icon -->
                <path d="M1.55 1.45 L9.45 19.55"
                      stroke="${color}"
                      stroke-width="0.92"
                      stroke-linecap="round"/>
                <path d="M9.45 1.45 L1.55 19.55"
                      stroke="${color}"
                      stroke-width="0.92"
                      stroke-linecap="round"/>
            </g>`;
    }

    /*
        Bridge and Space Maintainer are stored on the whole tooth and appear
        in the matching tooth/crown segment inside Lingual / Palatal.
    */
    function getApplianceVisualArea(arch, insideArea) {
        /*
            Match the same anatomical tooth/crown direction used by
            the front tooth image:

            Upper jaw  -> tooth/crown is the lower segment  -> Buccal
            Lower jaw  -> tooth/crown is the upper segment  -> Lingual
        */
        return arch === "upper"
            ? "buccal"
            : insideArea;
    }

    /*
        Kept for backward-compatible rendering signatures.

        Remaining Root is now image-only, so this Surface mapping is no
        longer used to display or select anything in Lingual / Palatal.
    */
    function getRemainingRootVisualArea(arch, insideArea) {
        return arch === "upper"
            ? insideArea
            : "buccal";
    }

    function getOcclusalAreaMarks(
        tid,
        area,
        applianceVisualArea,
        remainingRootVisualArea
    ) {
        const directMarks = getAreaMarks(tid, area);
        const result = [];

        /*
            A Crown covers all five Surface sections:
            Buccal, Lingual/Palatal, Mesial, Distal and Occlusal.

            Add it first so the exact selected Crown icon pattern becomes
            the main shading across the complete Surface diagram.
        */
        const crownMark = getCrownMark(tid);

        if (crownMark && crownMark.tool) {
            result.push({
                group: crownMark.group,
                tool: crownMark.tool
            });
        }

        /*
            Remaining Root is image-only.

            Do not inject its icon, pattern, or color into any
            Lingual / Palatal Surface section.
        */

        /*
            Whole-tooth Disease tools are image-only:
            - Periapical Lesion
            - Crack Tooth
            - Tooth Mobility

            Do not inject them into any Lingual / Palatal Surface section.
        */

        if (area === applianceVisualArea) {
            const applianceMark = getToothApplianceMark(tid);

            if (applianceMark && applianceMark.tool) {
                result.push({
                    group: applianceMark.group,
                    tool: applianceMark.tool
                });
            }
        }

        directMarks.forEach(mark => {
            const alreadyExists = result.some(existing =>
                existing.group === mark.group &&
                existing.tool &&
                mark.tool &&
                existing.tool.id === mark.tool.id
            );

            if (!alreadyExists) {
                result.push(mark);
            }
        });

        return result;
    }

    function isOcclusalAreaSelected(
        tid,
        area,
        applianceVisualArea,
        remainingRootVisualArea
    ) {
        /*
            Selection highlight is view-specific:

            - Clicking the front tooth image shows the square on the image only.
            - It must not highlight any Lingual / Palatal Surface section.
            - Applied treatments/patterns on Surface remain visible normally.
        */
        if (lastSelectionSource === "front") {
            return false;
        }

        /*
            The applied pattern/treatment remains visible, but the dark
            selection border disappears after clicking outside Surface.
        */
        if (hideSurfaceSelectionHighlight) {
            return false;
        }

        if (isSelected(tid, area)) {
            return true;
        }

        const sameTooth =
            selectedTarget &&
            selectedTarget.toothId === tid;

        const selectedWhole =
            sameTooth &&
            selectedTarget.area === "whole";

        const selectedRoot =
            sameTooth &&
            selectedTarget.area === "root";

        /*
            Whole-tooth Disease tools are image-only, so they must never
            highlight Lingual / Palatal Surface areas.
        */
        if (
            selectedWhole &&
            isWholeToothDiseaseTool()
        ) {
            return false;
        }

        /*
            Remaining Root is image-only, so Root selection on the front
            image must never highlight a Lingual / Palatal Surface section.
        */
        if (
            isRemainingRootTool() &&
            selectedRoot
        ) {
            return false;
        }

        return area === applianceVisualArea &&
               isToothApplianceTool() &&
               selectedWhole;
    }

    function isSelected(tid, area) {
        return selectedTarget && selectedTarget.toothId === tid && selectedTarget.area === area;
    }

    /*
        Show a selection square on the front tooth image only when the
        selection originated from the front image itself.

        Clicking any Lingual / Palatal Surface section may update the data
        and report, but it must not draw the upper/lower square on the image.
    */
    function isFrontImageAreaSelected(tid, area) {
        return (
            lastSelectionSource === "front" &&
            isSelected(tid, area)
        );
    }

    function hexToRgba(hex, alpha) {
        const h = hex.replace('#','');
        const b = parseInt(h, 16);
        return `rgba(${(b>>16)&255},${(b>>8)&255},${b&255},${alpha})`;
    }

    function getMarks(slot) {
        const out = [];
        ["disease","previous","inside","others"].forEach(g => {
            (slot[g] || []).forEach(tid => {
                const t = getTool(tid);
                if (t) out.push({ group: g, tool: t });
            });
        });
        return out;
    }

    function getWholeMarks(tid)      { return getMarks(chartData[tid].whole); }
    function getAreaMarks(tid, area) { return getMarks(chartData[tid].areas[area]); }

    function surfaceTint(tid, area) {
        const m = getAreaMarks(tid, area);
        if (!m.length)    return "#ffffff";
        if (m.length===1) return hexToRgba(GROUP_COLORS[m[0].group], .24);
        return "#eef2f7";
    }

    function escapeHtml(s) {
        return String(s)
            .replaceAll("&","&amp;").replaceAll("<","&lt;")
            .replaceAll(">","&gt;").replaceAll('"',"&quot;").replaceAll("'","&#039;");
    }

    // ════════════════════════════════════════════════════════════════
    //  ICONS
    // ════════════════════════════════════════════════════════════════
                  function iconSvg(glyph, color, size = 24, group = "") {
