        function getExtractedColor(tid) {
        const allAreas = ["buccal","lingual","palatal","mesial","distal","occlusal","root"];
        const groups   = ["disease","previous","inside","others"];

        for (const g of groups) {
            const tools = chartData[tid].whole[g] || [];
            if (tools.includes("extracted_tooth") || tools.includes("extracted_tooth_in")) {
                return GROUP_COLORS[g];
            }
        }

        for (const area of allAreas) {
            const slot = chartData[tid].areas[area];
            for (const g of groups) {
                const tools = slot[g] || [];
                if (tools.includes("extracted_tooth") || tools.includes("extracted_tooth_in")) {
                    return GROUP_COLORS[g];
                }
            }
        }

        return null;
    }

               function frontToothSvg(tid, arch) {
