    }
    function getExtractedColor(tid, view = "all") {
        const groups = ["disease", "previous", "inside", "others"];
        const tooth = chartData[tid];

        if (!tooth) return null;

        // Whole-tooth extraction is allowed to appear in every view.
        for (const g of groups) {
            const tools = tooth.whole[g] || [];
            if (tools.includes("extracted_tooth") || tools.includes("extracted_tooth_in")) {
                return GROUP_COLORS[g];
            }
        }

        // Important:
        // The front tooth image must not display marks coming from Buccal,
        // Lingual, Palatal, Mesial, Distal, or Occlusal surfaces.
        // Root marks may still appear on the front tooth image.
        const areasToCheck = view === "front"
            ? ["root"]
            : ["buccal", "lingual", "palatal", "mesial", "distal", "occlusal", "root"];

        for (const area of areasToCheck) {
            const slot = tooth.areas?.[area];
            if (!slot) continue;

            for (const g of groups) {
                const tools = slot[g] || [];
                if (tools.includes("extracted_tooth") || tools.includes("extracted_tooth_in")) {
                    return GROUP_COLORS[g];
                }
            }
        }

        return null;
    }
    // ════════════════════════════════════════════════════════════════
    //  FRONT TOOTH IMAGE CLICK MAPPING
    //
    //  Top half of the tooth image:
    //      Upper arch  -> Palatal
    //      Lower arch  -> Lingual
    //
    //  Bottom half of the tooth image:
    //      Upper/Lower -> Buccal
    //
    //  No treatment icon/pattern is drawn over the tooth image itself.
    //  The selected treatment is displayed only in the surface diagram.
    // ════════════════════════════════════════════════════════════════
    function buildFrontToothSvg(tid, arch, useUnflippedImage) {
        const insideArea = arch === "upper" ? "palatal" : "lingual";
        const sourceId   = getSourceToothId(tid);
        const visualSourceId =
            getDentitionVisualSourceId(tid);

        /*
            In Deciduous chart mode, visible teeth 1-5 are rendered as:
            E D C B A | A B C D E

            Positions D and E visually reuse the current permanent 6 and 7
            tooth images, exactly as requested.
        */
        const imgSrc =
            TOOTH_IMAGES[visualSourceId] ||
            TOOTH_IMAGES[sourceId] ||
            TOOTH_IMAGES[tid] ||
            "/images/teeth/U-8R-F.svg";

        const splitY = 10.5;

        const isDeciduous =
            chartData[tid].isDeciduous === true;

        /*
            Shrink only tooth positions 1-5.
            Teeth 6-8 always remain at their normal permanent size.
        */
        const shouldShrinkDeciduous =
            isDeciduous &&
            canBeDeciduousTooth(tid);

        const toothScale = shouldShrinkDeciduous
            ? 0.86
            : 1;

        const toothOffsetX =
            (11 - (11 * toothScale)) / 2;

        const toothOffsetY =
            (21 - (21 * toothScale)) / 2;

        const toothVisualTransform = shouldShrinkDeciduous
            ? `translate(${toothOffsetX} ${toothOffsetY}) scale(${toothScale})`
            : "";

        // Preserve the original image orientation behavior.
        const imgTransform = (!useUnflippedImage && arch === "upper")
            ? `transform="translate(0,21) scale(1,-1)"`
            : "";

        const applianceMode     = isToothApplianceTool();
        const crownMode         = isCrownTool();
        const remainingRootMode = isRemainingRootTool();
        const extractedMode     = isToothExtracted(tid);

        /*
            Appliance mode:
            - Upper arch root = upper half, crown/tooth = lower half.
            - Lower arch root = lower half, crown/tooth = upper half.
            - Bridge and Space Maintainer are allowed on the crown/tooth only.
        */
        const rootY  = arch === "upper" ? 0 : splitY;
        const toothY = arch === "upper" ? splitY : 0;

        /*
            Front-image selection squares are view-specific:
            Surface clicks never draw these upper/lower rectangles.
        */
        const normalHitAreas = `
              <rect x="0.5"
                    y="0"
                    width="10"
                    height="${splitY}"
                    fill="transparent"
                    pointer-events="all"
                    stroke="${isFrontImageAreaSelected(tid, insideArea) ? '#111827' : 'none'}"
                    stroke-width="0.35"
                    rx="1.2"
                    onclick="selectArea('${tid}','${insideArea}','front')"
                    style="cursor:pointer">
                <title>${insideArea}</title>
              </rect>

              <rect x="0.5"
                    y="${splitY}"
                    width="10"
                    height="${splitY}"
                    fill="transparent"
                    pointer-events="all"
                    stroke="${isFrontImageAreaSelected(tid, 'buccal') ? '#111827' : 'none'}"
                    stroke-width="0.35"
                    rx="1.2"
                    onclick="selectArea('${tid}','buccal','front')"
                    style="cursor:pointer">
                <title>buccal</title>
              </rect>`;

        const crownLabel =
            selectedToolId &&
            getTool(selectedToolId)
                ? getTool(selectedToolId).label
                : "Crown";

        const crownHitAreas = `
              <!-- Crown half accepts all 6 Crown types -->
              <rect x="0.5"
                    y="${toothY}"
                    width="10"
                    height="${splitY}"
                    fill="transparent"
                    pointer-events="all"
                    stroke="${isFrontImageAreaSelected(tid, 'whole') ? '#111827' : 'none'}"
                    stroke-width="0.42"
                    rx="1.2"
                    onclick="selectArea('${tid}','whole','front')"
                    style="cursor:pointer">
                <title>${crownLabel} — Crown only</title>
              </rect>

              <!-- Root is blocked for Crown tools -->
              <rect x="0.5"
                    y="${rootY}"
                    width="10"
                    height="${splitY}"
                    fill="transparent"
                    pointer-events="all"
                    stroke="none"
                    rx="1.2"
                    onclick="rejectCrownOnRoot('${crownLabel}')"
                    style="cursor:not-allowed">
                <title>${crownLabel} is not allowed on Root</title>
              </rect>`;

        const applianceLabel = selectedToolId && getTool(selectedToolId)
            ? getTool(selectedToolId).label
            : "Bridge / Space Maintainer";

        const applianceHitAreas = `
              <!-- Tooth/crown half accepts Bridge or Space Maintainer -->
              <rect x="0.5"
                    y="${toothY}"
                    width="10"
                    height="${splitY}"
                    fill="transparent"
                    pointer-events="all"
                    stroke="${isFrontImageAreaSelected(tid, 'whole') ? '#111827' : 'none'}"
                    stroke-width="0.42"
                    rx="1.2"
                    onclick="selectArea('${tid}','whole','front')"
                    style="cursor:pointer">
                <title>${applianceLabel} — Tooth only</title>
              </rect>

              <!-- Root is always blocked for these appliances -->
              <rect x="0.5"
                    y="${rootY}"
                    width="10"
                    height="${splitY}"
                    fill="transparent"
                    pointer-events="all"
                    stroke="none"
                    rx="1.2"
                    onclick="rejectToothApplianceOnRoot('${applianceLabel}')"
                    style="cursor:not-allowed">
                <title>${applianceLabel} is not allowed on Root</title>
              </rect>`;

        const remainingRootHitAreas = `
              <!-- Anatomical root half accepts Remaining Root -->
              <rect x="0.5"
                    y="${rootY}"
                    width="10"
                    height="${splitY}"
                    fill="transparent"
                    pointer-events="all"
                    stroke="${isFrontImageAreaSelected(tid, 'root') ? '#111827' : 'none'}"
                    stroke-width="0.42"
                    rx="1.2"
                    onclick="selectArea('${tid}','root','front')"
                    style="cursor:pointer">
                <title>Remaining Root — Root only</title>
              </rect>

              <!-- Tooth/crown half is blocked -->
              <rect x="0.5"
                    y="${toothY}"
                    width="10"
                    height="${splitY}"
                    fill="transparent"
                    pointer-events="all"
                    stroke="none"
                    rx="1.2"
                    onclick="rejectRemainingRootOutsideRoot()"
                    style="cursor:not-allowed">
                <title>Remaining Root is allowed on Root only</title>
              </rect>`;

        const extractedHitArea = `
              <rect x="0"
                    y="0"
                    width="11"
                    height="21"
                    fill="transparent"
                    pointer-events="all"
                    stroke="none"
                    onclick="rejectExtractedToothAction('${tid}')"
                    style="cursor:not-allowed">
                <title>This tooth is extracted</title>
              </rect>`;

        return `
            <svg class="tooth-svg"
                 viewBox="0 0 11 21"
                 xmlns="http://www.w3.org/2000/svg"
                 xmlns:xlink="http://www.w3.org/1999/xlink">

              <!--
                  Bridge / Space Maintainer connectors keep their normal row
                  alignment even when the selected tooth is deciduous.
              -->
              ${frontToothConnectorOverlay(tid, arch)}

              <!--
                  The tooth image and all tooth-bound overlays shrink together
                  when Teeth Transposition marks it as deciduous.
              -->
              <g class="tooth-visual ${shouldShrinkDeciduous ? 'deciduous-tooth' : 'permanent-tooth'}"
                 ${toothVisualTransform ? `transform="${toothVisualTransform}"` : ""}>

                <image href="${imgSrc}"
                       x="0"
                       y="0"
                       width="11"
                       height="21"
                       ${imgTransform}/>

                ${extractedMode
                      ? extractedToothOverlay(tid)
                      : `
                          ${wholeToothDiseaseFrontOverlay(tid, arch)}
                          ${crownTreatmentOverlay(tid, arch, splitY)}
                          ${toothApplianceOverlay(tid, arch)}
                          ${remainingRootHideOtherHalfOverlay(tid, arch, splitY)}
                          ${remainingRootOverlay(tid, arch)}
                        `}
              </g>

              ${extractedMode
                    ? extractedHitArea
                    : (
                        remainingRootMode
                            ? remainingRootHitAreas
                            : (
                                crownMode
                                    ? crownHitAreas
                                    : (
                                        applianceMode
                                            ? applianceHitAreas
                                            : normalHitAreas
                                      )
                              )
                      )}
            </svg>`;
    }

    function frontToothSvg(tid, arch) {
        return buildFrontToothSvg(tid, arch, false);
    }

    function frontToothSvgFlipped(tid, arch) {
        return buildFrontToothSvg(tid, arch, true);
    }

    function renderToothFront(tid, arch) {
        // Use the real tooth identity after a Teeth Change swap, not only
        // the chart position, so teeth 2 1 1 2 keep their correct orientation.
        const sourceId   = getSourceToothId(tid);
        const toothIndex = parseInt(sourceId.slice(1), 10);
        const isFlipped  = [6, 7, 8, 9].includes(toothIndex);

        return isFlipped
            ? frontToothSvgFlipped(tid, arch)
            : frontToothSvg(tid, arch);
    }

        function occlusalToothSvg(tid, arch) {
        const insideName = arch === "upper" ? "palatal" : "lingual";

        /*
            Bridge / Space Maintainer follows the tooth/crown direction:
            upper jaw = lower segment, lower jaw = upper segment.
        */
        const applianceVisualArea = getApplianceVisualArea(
            arch,
            insideName
        );

        const remainingRootVisualArea = getRemainingRootVisualArea(
            arch,
            insideName
        );

        const cx = 32, cy = 26, rx = 26, ry = 20, irx = 13, iry = 10;

        const extractedColor = getExtractedColor(tid, "occlusal");   // Surface diagram keeps its normal patterns

        function ptOuter(a) { const r=a*Math.PI/180; return {x:cx+rx*Math.cos(r),y:cy+ry*Math.sin(r)}; }
        function ptInner(a) { const r=a*Math.PI/180; return {x:cx+irx*Math.cos(r),y:cy+iry*Math.sin(r)}; }
        function segmentPath(sa, ea) {
            const t=a=>a*Math.PI/180;
            const x1o=cx+rx*Math.cos(t(sa)),y1o=cy+ry*Math.sin(t(sa));
            const x2o=cx+rx*Math.cos(t(ea)),y2o=cy+ry*Math.sin(t(ea));
            const x1i=cx+irx*Math.cos(t(ea)),y1i=cy+iry*Math.sin(t(ea));
            const x2i=cx+irx*Math.cos(t(sa)),y2i=cy+iry*Math.sin(t(sa));
            const la=Math.abs(ea-sa)>180?1:0;
            return `M ${x1o} ${y1o} A ${rx} ${ry} 0 ${la} 1 ${x2o} ${y2o} L ${x1i} ${y1i} A ${irx} ${iry} 0 ${la} 0 ${x2i} ${y2i} Z`;
        }
        const xAngles = [45, 135, 225, 315];
        const segments = [
            { key:"distal",    startAngle:-45,  endAngle:45  },
            { key:"buccal",    startAngle:45,   endAngle:135 },
            { key:"mesial",    startAngle:135,  endAngle:225 },
            { key:insideName,  startAngle:225,  endAngle:315 }
        ];
        const badgeSpots = {
            buccal:[{x:28,y:40},{x:36,y:40}], palatal:[{x:28,y:10},{x:36,y:10}],
            lingual:[{x:28,y:10},{x:36,y:10}], mesial:[{x:6,y:22},{x:6,y:30}],
            distal:[{x:52,y:22},{x:52,y:30}],  occlusal:[{x:28,y:22},{x:36,y:22}]
        };
        const allKeys = [...segments.map(s=>s.key), "occlusal"];

        const defsContent = extractedColor ? "" : allKeys.map(key => {
            const marks = getOcclusalAreaMarks(
                tid,
                key,
                applianceVisualArea,
                remainingRootVisualArea
            );

            if (!marks.length) return "";

            /*
                Use the exact glyph pattern of the first visible tool.

                For Crown treatments this means every Crown type keeps its
                own distinctive pattern across all five Surface sections,
                including the middle Occlusal section.
            */
            return glyphPattern(
                `occ_${tid}_${key}`,
                marks[0].tool.glyph,
                GROUP_COLORS[marks[0].group]
            );
        }).join("");

        const segmentsSvg = segments.map(s => {
            const marks = extractedColor
                ? []
                : getOcclusalAreaMarks(
                    tid,
                    s.key,
                    applianceVisualArea,
                    remainingRootVisualArea
                );

            const crownMark = marks.find(mark =>
                mark.tool &&
                isCrownTool(mark.tool.id)
            );

            const crownColor = crownMark
                ? GROUP_COLORS[crownMark.group]
                : null;

            const fill = marks.length
                ? `url(#occ_${tid}_${s.key})`
                : "transparent";

            const selected = isOcclusalAreaSelected(
                tid,
                s.key,
                applianceVisualArea,
                remainingRootVisualArea
            );

            const stroke = crownMark
                ? crownColor
                : (
                    selected
                        ? "#111827"
                        : "#c4ccd7"
                  );

            const sw = crownMark
                ? 1.28
                : (
                    selected
                        ? 2.0
                        : 0.9
                  );

            return `<path d="${segmentPath(s.startAngle, s.endAngle)}"
                          fill="${fill}"
                          stroke="${stroke}"
                          stroke-width="${sw}"
                          onclick="selectArea('${tid}','${s.key}','surface')"
                          style="cursor:pointer"/>`;
        }).join("");

        const occlusalMarks = extractedColor
            ? []
            : getOcclusalAreaMarks(
                tid,
                "occlusal",
                applianceVisualArea,
                remainingRootVisualArea
            );

        const occlusalCrownMark =
            occlusalMarks.find(mark =>
                mark.tool &&
                isCrownTool(mark.tool.id)
            );

        const occlusalCrownColor =
            occlusalCrownMark
                ? GROUP_COLORS[
                    occlusalCrownMark.group
                  ]
                : null;

        const occlusalFill =
            occlusalMarks.length
                ? `url(#occ_${tid}_occlusal)`
                : "transparent";

        const xLines = xAngles.map(a => {
            const o=ptOuter(a), i=ptInner(a);
            return `<line x1="${i.x.toFixed(2)}" y1="${i.y.toFixed(2)}" x2="${o.x.toFixed(2)}" y2="${o.y.toFixed(2)}" stroke="#1f2937" stroke-width="0.9"/>`;
        }).join("");

        // ⬇️ جديد: X كبيرة عبر السن كامل بالـ occlusal view
        const extractedBigX = extractedColor ? `
            <line x1="${cx-rx*0.85}" y1="${cy-ry*0.85}" x2="${cx+rx*0.85}" y2="${cy+ry*0.85}"
                  stroke="${extractedColor}" stroke-width="2.6" stroke-linecap="round"/>
            <line x1="${cx+rx*0.85}" y1="${cy-ry*0.85}" x2="${cx-rx*0.85}" y2="${cy+ry*0.85}"
                  stroke="${extractedColor}" stroke-width="2.6" stroke-linecap="round"/>
        ` : "";

        return `
            <svg class="tooth-svg lingual-palatal-surface-svg"
                 data-surface-chart="true"
                 viewBox="0 0 64 52"
                 xmlns="http://www.w3.org/2000/svg">
              <defs>${defsContent}</defs>
              <ellipse cx="${cx}" cy="${cy}" rx="${rx}" ry="${ry}" fill="#fafafa" stroke="#d0d6df" stroke-width="1.4"/>
              ${segmentsSvg}
              ${xLines}
              <ellipse cx="${cx}" cy="${cy}" rx="${irx}" ry="${iry}"
                       fill="${occlusalFill}"
                       stroke="${occlusalCrownMark
                           ? occlusalCrownColor
                           : (
                               isOcclusalAreaSelected(
                                   tid,
                                   'occlusal',
                                   applianceVisualArea,
                                   remainingRootVisualArea
                               )
                                   ? '#111827'
                                   : '#c4ccd7'
                             )}"
                       stroke-width="${occlusalCrownMark
                           ? 1.28
                           : (
                               isOcclusalAreaSelected(
                                   tid,
                                   'occlusal',
                                   applianceVisualArea,
                                   remainingRootVisualArea
                               )
                                   ? 2.0
                                   : 0.9
                             )}"
                       onclick="selectArea('${tid}','occlusal','surface')"
                       style="cursor:pointer"/>
              <ellipse cx="${cx}" cy="${cy}" rx="${rx}" ry="${ry}" fill="none" stroke="#c4ccd7" stroke-width="1.3"/>
              <!--
                  Extracted Tooth:
                  Show exactly one large X only.
                  Do not render the whole-tooth overlay or the small badges,
                  because they create the duplicated X and the small extra icon.
              -->
              ${extractedColor ? "" : wholeToothOverlayOcclusal(tid)}
              ${extractedColor ? "" : wholeToothDiseaseOcclusalOverlay(tid)}
              ${extractedColor ? "" : segments.map(s=>areaBadges(tid,s.key,badgeSpots[s.key]||badgeSpots.occlusal)).join("")}
              ${extractedColor ? "" : areaBadges(tid,'occlusal',badgeSpots.occlusal,false)}
              ${extractedBigX}
            </svg>`;
    }
    function toggleToothVariant(tid) {
        const tooth = chartData[tid];
        if (!tooth) return;

        setToothDeciduousState(
            tid,
            tooth.isDeciduous !== true
        );
    }
    // ════════════════════════════════════════════════════════════════
    //  INTERACTIONS
    // ════════════════════════════════════════════════════════════════

    /*
        Only the special tools whose behavior was already implemented are
        allowed to run from the front tooth image.

        All normal Surface tools must be applied from the Lingual / Palatal
        Surface diagram only.
    */
    function canToolApplyFromFrontImage(tool) {
        if (!tool) {
            return true;
        }

        return (
            isTeethTranspositionTool(tool.id) ||
            isPermanentDeciduousTool(tool.id) ||
            isExtractedTool(tool.id) ||
            isRemainingRootTool(tool.id) ||
            isWholeToothDiseaseTool(tool.id) ||
            isCrownTool(tool.id) ||
            isToothApplianceTool(tool.id)
        );
    }

    function rejectToolOnFrontImage(tool) {
        showToast(
            `${tool.label} تُطبّق على منطقة Surface التي تختارها فقط، ولا تُطبّق من صورة السن.`,
            "warning"
        );
    }

              function selectArea(tid, area, source = "surface") {
        const currentTool = selectedToolId ? getTool(selectedToolId) : null;

        /*
            Front image rule:

            A normal Surface icon must not be placed from the tooth image.
            It will be applied only when the user clicks the exact Surface
            section.

            The special tools listed in canToolApplyFromFrontImage() retain
            their original behavior.
        */
        if (
            source === "front" &&
            currentTool &&
            !canToolApplyFromFrontImage(currentTool)
        ) {
            rejectToolOnFrontImage(currentTool);
            return;
        }

        /*
            A new click starts a new visual selection.
            "surface" means the Lingual / Palatal five-part diagram.
        */
        lastSelectionSource = source;
        hideSurfaceSelectionHighlight = false;

        /*
            Once a tooth is marked as Extracted Tooth, no chart action is
            allowed on it until the extraction mark is cleared.
        */
        if (isToothExtracted(tid)) {
            rejectExtractedToothAction(tid);
            return;
        }

        /*
            Teeth Change Permanent/Deciduous rules:
            1. It is applied by clicking the front tooth image only.
            2. It is allowed only for tooth positions 1 through 5.
            3. The tooth becomes deciduous / temporary.
            4. The same tooth image is shown slightly smaller.
            5. Teeth 6, 7, and 8 always remain permanent.
            6. It is stored once on the whole tooth for saving/reporting.
        */
        if (
            currentTool &&
            isPermanentDeciduousTool(currentTool.id)
        ) {
            if (source !== "front") {
                showToast(
                    "Teeth Change Permanent/Deciduous يعمل من صورة السن فقط، وليس من Surface.",
                    "warning"
                );
                return;
            }

            if (!canBeDeciduousTooth(tid)) {
                const toothNumber = getToothPositionNumber(tid);

                showToast(
                    `Teeth Change Permanent/Deciduous مسموح فقط للأسنان من 1 إلى 5. السن رقم ${toothNumber} يبقى دائمًا.`,
                    "warning"
                );
                return;
            }

            const applied = setToothDeciduousState(
                tid,
                true
            );

            if (applied) {
                selectedTarget = {
                    toothId: tid,
                    area: "whole"
                };

                showToast(
                    `تم تحويل السن ${tid} إلى سن لبني وتصغير حجمه.`,
                    "success"
                );
            }

            renderAll();
            return;
        }

        /*
            Extracted Tooth rules:
            1. It can be applied by clicking anywhere on the front tooth image.
            2. It can also be applied from Lingual / Palatal.
            3. It is stored once on the whole tooth.
            4. After that, the tooth is locked against further actions.
        */
        if (currentTool && currentTool.glyph === "extracted") {
            const allowedFromFront = source === "front";

            /*
                The complete lower SVG represents the Lingual / Palatal view.
                Therefore, while Extracted Tooth is selected, clicking any
                section of that diagram must mark the entire tooth as extracted.

                This includes:
                Lingual / Palatal, Buccal, Mesial, Distal, and Occlusal.
            */
            const allowedFromLingualPalatalDiagram = source === "surface";

            if (!allowedFromFront && !allowedFromLingualPalatalDiagram) {
                showToast(
                    "Extracted Tooth مسموح من صورة السن أو من مخطط Lingual / Palatal فقط.",
                    "warning"
                );
                return;
            }

            const applied = applyExtractedToWholeTooth(tid, currentTool);

            if (applied) {
                /*
                    Keep the clicked section selected for the side information,
                    but the Extracted Tooth state itself is saved once on the
                    whole tooth. This immediately updates both:
                    1. The front tooth image.
                    2. The Lingual / Palatal diagram.
                */
                selectedTarget = {
                    toothId: tid,
                    area: area
                };

                showToast(`تم تحديد السن ${tid} كمخلوع.`, "success");
            }

            renderAll();
            return;
        }

        /*
            Image-only Remaining Root rules:

            1. It works only from the anatomical Root half of the front image.
            2. It does not apply from Lingual / Palatal Surface.
            3. It does not display any Surface icon, pattern, or highlight.
            4. The opposite broken part of the tooth remains hidden as before.
            5. The value is stored in Root for reporting and database saving.
        */
        if (
            currentTool &&
            isRemainingRootTool(currentTool.id)
        ) {
            const allowedFromFrontRoot =
                source === "front" &&
                area === "root";

            if (!allowedFromFrontRoot) {
                showToast(
                    "Remaining Root يعمل من جذر صورة السن فقط، وليس من Surface.",
                    "warning"
                );
                return;
            }

            selectedTarget = {
                toothId: tid,
                area: "root"
            };

            applyToolToSelectedTarget();

            showToast(
                `Remaining Root تم وضعه على جذر صورة السن ${tid}.`,
                "success"
            );

            renderAll();
            return;
        }

        /*
            Image-only whole-tooth Disease rules:

            These tools work only from the front tooth image:
            - Periapical Lesion
            - Crack Tooth
            - Tooth Mobility

            Clicking Lingual / Palatal Surface does not apply the tool and
            does not create any Surface shading or selection.
        */
        if (
            currentTool &&
            isWholeToothDiseaseTool(currentTool.id)
        ) {
            if (source !== "front") {
                showToast(
                    `${currentTool.label} يعمل من صورة السن فقط، وليس من Surface.`,
                    "warning"
                );
                return;
            }

            const applied = applyWholeToothDisease(
                tid,
                currentTool
            );

            if (applied) {
                selectedTarget = {
                    toothId: tid,
                    area: "whole"
                };

                showToast(
                    `${currentTool.label} تم تطبيقه على صورة السن.`,
                    "success"
                );
            }

            renderAll();
            return;
        }

        /*
            Crown rules — Previous Treatment and In-Hospital:

            1. All 6 Crown icons in each group use this behavior.
            2. Apply by clicking the Crown half of the front tooth image.
            3. Root is blocked.
            4. The Crown is stored in all five Surface areas.
            5. ReportJson groups them into one report containing five areas.
            6. DentalToothData can save five separate area rows.
            7. All five Surface sections receive the exact pattern of the selected Crown icon.
            8. The Crown half on the image gets only a smaller outline box without shading.
        */
        if (
            currentTool &&
            isCrownTool(currentTool.id)
        ) {
            const allowedFromFrontCrown =
                source === "front" &&
                area === "whole";

            if (!allowedFromFrontCrown) {
                showToast(
                    `${currentTool.label} يعمل من تاج صورة السن فقط، وليس من الجذر أو Surface.`,
                    "warning"
                );
                return;
            }

            const applied = applyCrownToTooth(
                tid,
                currentTool
            );

            if (applied) {
                selectedTarget = {
                    toothId: tid,
                    area: "whole"
                };

                showToast(
                    `${currentTool.label} تم وضعه على تاج السن ${tid}.`,
                    "success"
                );
            }

            renderAll();
            return;
        }

        /*
            Bridge / Space Maintainer rules:
            1. Apply from the crown/tooth half of the front image.
            2. Or apply from the upper Lingual / Palatal segment.
            3. Root is forbidden.
            4. Only one appliance is retained on each tooth.
        */
        if (currentTool && isToothApplianceTool(currentTool.id)) {
            const arch = tid.startsWith("U")
                ? "upper"
                : "lower";

            const insideArea = arch === "upper"
                ? "palatal"
                : "lingual";

            /*
                Match the front image tooth/crown direction:
                upper jaw -> lower Buccal segment
                lower jaw -> upper Lingual segment
            */
            const applianceArea = getApplianceVisualArea(
                arch,
                insideArea
            );

            const allowedFromFrontTooth =
                source === "front" &&
                area === "whole";

            const allowedFromLingualPalatalToothPart =
                source === "surface" &&
                area === applianceArea;

            if (
                !allowedFromFrontTooth &&
                !allowedFromLingualPalatalToothPart
            ) {
                showToast(
                    `${currentTool.label} مسموح فقط على جسم السن، وليس على الجذر.`,
                    "warning"
                );
                return;
            }

            const applied = applyToothAppliance(tid, currentTool);

            if (applied) {
                selectedTarget = {
                    toothId: tid,
                    area: "whole"
                };

                showToast(
                    `${currentTool.label} تم وضعه على السن ${tid}.`,
                    "success"
                );
            }

            renderAll();
            return;
        }

        selectedTarget = { toothId: tid, area };

        if (selectedToolId === "others_text") {
            openOthersTextModal(tid, area);
            return;
        }

        if (
            currentTool &&
            isTeethTranspositionTool(currentTool.id)
        ) {
            if (source !== "front") {
                showToast(
                    "Teeth Transposition يعمل من صورة السن فقط، وليس من مخطط Surface.",
                    "warning"
                );
                return;
            }

            // First click: remember the first tooth position.
            if (!pendingSwapToothId) {
                pendingSwapToothId = tid;
                showToast(
                    `🔁 تم اختيار ${tid} — اختر السن الثاني`,
                    "info"
                );
                renderAll();
                return;
            }

            // Clicking the same tooth cancels the pending operation.
            if (pendingSwapToothId === tid) {
                pendingSwapToothId = null;
                showToast(
                    "❌ تم إلغاء تبديل الأسنان",
                    "info"
                );
                renderAll();
                return;
            }

            const firstId = pendingSwapToothId;
            const secondId = tid;
            const changed = swapTeeth(
                firstId,
                secondId
            );

            pendingSwapToothId = null;
            selectedTarget = {
                toothId: secondId,
                area
            };

            if (changed) {
                showToast(
                    `✅ تم تبديل مكان ${firstId} مع ${secondId}`,
                    "success"
                );
            } else {
                showToast(
                    "❌ لم يتم تبديل الأسنان",
                    "error"
                );
            }

            renderAll();
            return;
        }

        /*
            Reaching this point means this is a normal Surface-scoped tool.

            Because front-image clicks were blocked above, the value is saved
            only in the exact Surface area that the user clicked.
        */
        if (selectedToolId) {
            applyToolToSelectedTarget();
        }

        renderAll();
    }

    function applyToolToSelectedTarget() {
        if (!selectedToolId || !selectedTarget) return;

        const tool = getTool(selectedToolId);
        const toothId = selectedTarget.toothId;
        const tooth = chartData[toothId];

        if (!tool) return;

        const storageArea = getToolStorageArea(
            tool,
            selectedTarget.area
        );

        if (
            !canApplyLockedToolToArea(
                toothId,
                storageArea,
                tool
            )
        ) {
            return;
        }

        if (tool.scope === "whole") {
            if (!Array.isArray(tooth.whole[tool.group])) tooth.whole[tool.group] = [];
            if (!tooth.whole[tool.group].includes(tool.id)) tooth.whole[tool.group].push(tool.id);
        } else if (tool.scope === "root") {
            const arr = tooth.areas.root[tool.group];
            if (!arr.includes(tool.id)) arr.push(tool.id);
            selectedTarget.area = "root";
        } else {
            const arr = tooth.areas[selectedTarget.area][tool.group];
            if (!arr.includes(tool.id)) arr.push(tool.id);
        }
    }

    function clearSelectedTarget() {
        if (!selectedTarget) return;

        const tid = selectedTarget.toothId;

        /*
            Extracted Tooth is a whole-tooth state. Clearing the selected
            target removes that state and unlocks the tooth.
        */
        if (isToothExtracted(tid)) {
            removeExtractedFromTooth(tid);
            showToast(`تم إلغاء Extracted Tooth عن السن ${tid}.`, "success");
            renderAll();
            return;
        }

        /*
            Crown is stored in five Surface areas but selected as one action
            from the crown image. Clear Area therefore removes the complete
            Crown from all five areas.
        */
        if (
            selectedToolId &&
            isCrownTool(selectedToolId) &&
            getCrownMark(tid)
        ) {
            removeAllCrownMarks(tid);

            showToast(
                `تم حذف Crown من المناطق الخمس للسن ${tid}.`,
                "success"
            );

            renderAll();
            return;
        }

        if (selectedTarget.area === "whole") {
            chartData[tid].whole = makeSlot();
            chartData[tid].isDeciduous = false;
        } else {
            chartData[tid].areas[selectedTarget.area] = makeSlot();
        }

        renderAll();
    }

    function clearSelectedTooth() {
        if (!selectedTarget) return;

        const id = selectedTarget.toothId;
        const currentTooth = chartData[id];
        const sourceId = currentTooth?.sourceId || id;
        chartData[id] = makeTooth(id);

        // Clear treatments/notes and permanent/deciduous status without
        // undoing a Teeth Change position swap.
        chartData[id].sourceId = sourceId;
        chartData[id].isDeciduous = false;

        renderAll();
    }

    function clearAllChart() {
        [...UPPER_IDS, ...LOWER_IDS].forEach(id => { chartData[id] = makeTooth(id); });

        lastSelectionSource = null;
        hideSurfaceSelectionHighlight = false;

        renderAll();
    }

    function saveNote() {
        if (!selectedTarget) return;

        const tid = selectedTarget.toothId;

        if (isToothExtracted(tid)) {
            rejectExtractedToothAction(tid);
            return;
        }

        const text = document.getElementById("noteBox").value.trim();

        if (selectedTarget.area === "whole") {
            chartData[tid].whole.note = text;
        } else {
            chartData[tid].areas[selectedTarget.area].note = text;
        }

        renderAll();
    }

    function removeGroupFromArea(group, toolId) {
        if (!selectedTarget) return;
        const arr = chartData[selectedTarget.toothId].areas[selectedTarget.area][group];
        const idx = arr.indexOf(toolId);
        if (idx > -1) arr.splice(idx, 1);
        renderAll();
    }

    function removeWholeGroup(tid, group, toolId) {
        const arr = chartData[tid].whole[group];

        if (Array.isArray(arr)) {
            const idx = arr.indexOf(toolId);
            if (idx > -1) arr.splice(idx, 1);
        }

        if (isPermanentDeciduousTool(toolId)) {
            setToothDeciduousState(tid, false);
        }

        renderAll();
    }

    function removeFromArea(toothId, areaKey, group, toolId) {
        const arr = chartData[toothId].areas[areaKey][group];
        const idx = arr.indexOf(toolId);
        if (idx > -1) arr.splice(idx, 1);
        renderAll();
    }

    function clearAreaNote() {
        if (!selectedTarget) return;
        chartData[selectedTarget.toothId].areas[selectedTarget.area].note = "";
        renderAll();
    }

    function clearAreaNoteFor(toothId, areaKey) {
        const tooth = chartData[toothId];

        if (!tooth) {
            return;
        }

        if (areaKey === "whole") {
            tooth.whole.note = "";
        } else if (tooth.areas?.[areaKey]) {
            tooth.areas[areaKey].note = "";
        }

        renderAll();
    }

    // ════════════════════════════════════════════════════════════════
    //  DESELECT ON BACKGROUND CLICK
    // ════════════════════════════════════════════════════════════════
    document.addEventListener("click", function(e) {
        const isOnTooth    = e.target.closest("svg.tooth-svg");
        const isOnBtn      = e.target.closest("button");
        const isOnTextarea = e.target.closest("textarea");
        const isOnMiniItem = e.target.closest(".mini-item");
        const isOnToolbar  = e.target.closest("#toolbar");
        const isOnModal    = e.target.closest(".modal-box");
        const isOnReport   = e.target.closest("#reportPanel");
        if (!isOnTooth && !isOnBtn && !isOnTextarea && !isOnMiniItem && !isOnToolbar && !isOnModal && !isOnReport) {
            if (selectedToolId) {
                selectedToolId = null;
                pendingSwapToothId = null;
                renderAll();
            }
        }
    });

    // ════════════════════════════════════════════════════════════════
    //  REPORT
    // ════════════════════════════════════════════════════════════════
    const REPORT_AREA_ORDER = [
        "whole",
        "buccal",
        "lingual",
        "palatal",
        "mesial",
        "distal",
        "occlusal",
        "root"
    ];

    function sortReportAreas(areas) {
        return [...new Set(areas)].sort((a, b) => {
            const aIndex = REPORT_AREA_ORDER.indexOf(a);
            const bIndex = REPORT_AREA_ORDER.indexOf(b);

            return (
                (aIndex < 0 ? 999 : aIndex) -
                (bIndex < 0 ? 999 : bIndex)
            );
        });
    }

    function getReportAreaLabel(area) {
        return area === "whole"
            ? "whole tooth"
            : area;
    }

    function getReportAreasText(areas) {
        return sortReportAreas(areas)
            .map(getReportAreaLabel)
            .join(", ");
    }

    /*
        Report grouping rule:

        The same tool applied to several areas of the same tooth is shown as
        ONE report item.

        Example:
        Partial Restoration + U3 +
        buccal, mesial, distal, palatal, occlusal
    */
    function buildToolReport() {
        const groupedReport = {};
        const allAreas = [
            "buccal",
            "lingual",
            "palatal",
            "mesial",
            "distal",
            "occlusal",
            "root"
        ];
        const groups = [
            "disease",
            "previous",
            "inside",
            "others"
        ];

        function addUsage(toolId, toothId, area, group) {
            if (!groupedReport[toolId]) {
                groupedReport[toolId] = {};
            }

            /*
                Tool IDs already identify Previous/In-Hospital variants,
                but the group remains part of the key for safe old-session
                compatibility.
            */
            const usageKey = `${toothId}|${group}`;

            if (!groupedReport[toolId][usageKey]) {
                groupedReport[toolId][usageKey] = {
                    toolId,
                    toothId,
                    group,
                    areas: []
                };
            }

            if (
                !groupedReport[toolId][usageKey].areas.includes(area)
            ) {
                groupedReport[toolId][usageKey].areas.push(area);
            }
        }

        [...UPPER_IDS, ...LOWER_IDS].forEach(toothId => {
            const tooth = chartData[toothId];

            if (!tooth) {
                return;
            }

            groups.forEach(group => {
                (tooth.whole?.[group] || []).forEach(toolId => {
                    addUsage(
                        toolId,
                        toothId,
                        "whole",
                        group
                    );
                });
            });

            allAreas.forEach(area => {
                const slot = tooth.areas?.[area];

                if (!slot) {
                    return;
                }

                groups.forEach(group => {
                    (slot[group] || []).forEach(toolId => {
                        addUsage(
                            toolId,
                            toothId,
                            area,
                            group
                        );
                    });
                });
            });
        });

        const report = {};

        Object.keys(groupedReport).forEach(toolId => {
            report[toolId] = Object
                .values(groupedReport[toolId])
                .map(usage => ({
                    ...usage,
                    areas: sortReportAreas(usage.areas)
                }))
                .sort((a, b) => {
                    const allToothIds = [
                        ...UPPER_IDS,
                        ...LOWER_IDS
                    ];

                    return (
                        allToothIds.indexOf(a.toothId) -
                        allToothIds.indexOf(b.toothId)
                    );
                });
        });

        return report;
    }

    /*
        JSON saved in DentalChartSession.ReportJson.

        DentalToothData remains stored per area, while ReportJson stores
        a grouped, readable report.
    */
    function buildGroupedReportJson() {
        const report = buildToolReport();
        const items = [];

        Object.keys(report).forEach(toolId => {
            const tool = getTool(toolId);

            if (!tool) {
                return;
            }

            report[toolId].forEach(usage => {
                items.push({
                    selectedTool: tool.label,
                    toolId: tool.id,
                    group: usage.group,
                    selectedTooth: usage.toothId,
                    selectedAreas: usage.areas.map(
                        getReportAreaLabel
                    )
                });
            });
        });

        return JSON.stringify({
            generatedAt: new Date().toISOString(),
            totalItems: items.length,
            items
        });
    }

    function selectReportTool(toolId) {
        reportToolId =
            reportToolId === toolId
                ? null
                : toolId;

        renderSideInfo();
    }

    function selectGroupedReportUsage(
        toolId,
        toothId,
        encodedAreas
    ) {
        let areas = [];

        try {
            areas = JSON.parse(
                decodeURIComponent(encodedAreas)
            );
        } catch {
            areas = [];
        }

        selectedToolId = toolId;
        selectedTarget = {
            toothId,
            area: areas[0] || "whole"
        };
        reportToolId = null;

        renderAll();
    }

    /*
        Remove one grouped action from every area where that same tool was
        applied on the selected tooth.
    */
    function removeGroupedToolUsage(
        toothId,
        toolId,
        group,
        encodedAreas
    ) {
        let areas = [];

        try {
            areas = JSON.parse(
                decodeURIComponent(encodedAreas)
            );
        } catch {
            areas = [];
        }

        const tooth = chartData[toothId];

        if (!tooth) {
            return;
        }

        areas.forEach(area => {
            const slot = area === "whole"
                ? tooth.whole
                : tooth.areas?.[area];

            if (!slot || !Array.isArray(slot[group])) {
                return;
            }

            slot[group] = slot[group]
                .filter(id => id !== toolId);
        });

        if (isPermanentDeciduousTool(toolId)) {
            setToothDeciduousState(
                toothId,
                false
            );
        }

        if (isExtractedTool(toolId)) {
            removeExtractedFromTooth(toothId);
        }

        renderAll();
    }

    function getSelectedToothActionRows(toothId) {
        const report = buildToolReport();
        const rows = [];

        Object.keys(report).forEach(toolId => {
            const tool = getTool(toolId);

            if (!tool) {
                return;
            }

            report[toolId]
                .filter(usage =>
                    usage.toothId === toothId
                )
                .forEach(usage => {
                    rows.push({
                        type: "tool",
                        tool,
                        toolId,
                        group: usage.group,
                        toothId,
                        areas: usage.areas
                    });
                });
        });

        /*
            Teeth Transposition swaps the actual tooth image/position and
            therefore does not live in a normal surface slot.

            Add it as a derived action whenever the current position contains
            a different source tooth.
        */
        const sourceToothId =
            getSourceToothId(toothId);

        if (
            sourceToothId &&
            sourceToothId !== toothId
        ) {
            const transpositionTool =
                getTool(TEETH_TRANSPOSITION_TOOL_ID);

            if (transpositionTool) {
                rows.push({
                    type: "swap",
                    tool: transpositionTool,
                    toolId: transpositionTool.id,
                    group: "others",
                    toothId,
                    sourceToothId,
                    areas: ["whole"]
                });
            }
        }

        const tooth = chartData[toothId];
        const noteAreas = [
            "whole",
            "buccal",
            "lingual",
            "palatal",
            "mesial",
            "distal",
            "occlusal",
            "root"
        ];

        noteAreas.forEach(area => {
            const slot = area === "whole"
                ? tooth?.whole
                : tooth?.areas?.[area];

            if (slot?.note) {
                rows.push({
                    type: "note",
                    toothId,
                    area,
                    note: slot.note
                });
            }
        });

        return rows.sort((a, b) => {
            const aTool = a.tool?.label || "Note";
            const bTool = b.tool?.label || "Note";

            return aTool.localeCompare(bTool);
        });
    }

    function renderSelectedToothActions(toothId) {
