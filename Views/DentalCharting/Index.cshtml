                12:25,13:26,14:27,15:28
            },
            L:{
                0:48,1:47,2:46,3:45,
                4:44,5:43,6:42,7:41,
                8:31,9:32,10:33,11:34,
                12:35,13:36,14:37,15:38
            }
        };

        const grouped = {};
        const noteRows = [];

        function addToolRow(
            fdi,
            toothId,
            area,
            group,
            toolId
        ) {
            const tool = getTool(toolId);

            if (!tool) {
                return;
            }

            const key =
                `${toothId}|${group}|${toolId}`;

            if (!grouped[key]) {
                grouped[key] = {
                    fdi,
                    tid: toothId,
                    group,
                    toolId,
                    label: tool.label,
                    glyph: tool.glyph,
                    areas: []
                };
            }

            if (!grouped[key].areas.includes(area)) {
                grouped[key].areas.push(area);
            }
        }

        Object.keys(data).forEach(toothId => {
            const tooth = data[toothId];

            if (!tooth) {
                return;
            }

            const arch = toothId[0];
            const index = parseInt(
                toothId.slice(1),
                10
            );
            const fdi =
                FDI_MAP[arch]?.[index] ??
                toothId;

            groups.forEach(group => {
                (tooth.whole?.[group] || [])
                    .forEach(toolId => {
                        addToolRow(
                            fdi,
                            toothId,
                            "whole",
                            group,
                            toolId
                        );
                    });
            });

            allAreas.forEach(area => {
                const slot = tooth.areas?.[area];

                if (!slot) {
                    return;
                }

                groups.forEach(group => {
                    (slot[group] || [])
                        .forEach(toolId => {
                            addToolRow(
                                fdi,
                                toothId,
                                area,
                                group,
                                toolId
                            );
                        });
                });

                if (slot.note) {
                    noteRows.push({
                        fdi,
                        tid: toothId,
                        areas: [area],
                        group: "note",
                        label: slot.note,
                        glyph: "note",
                        isNote: true
                    });
                }
            });
        });

        const toolRows = Object
            .values(grouped)
            .map(row => ({
                ...row,
                areas: sortReportAreas(row.areas)
            }));

        return [
            ...toolRows,
            ...noteRows
        ].sort((a, b) => {
            if (a.fdi !== b.fdi) {
                return a.fdi - b.fdi;
            }

            return String(a.label)
                .localeCompare(String(b.label));
        });
    }

    function buildSummaryTable(rows) {
        if (!rows.length) return `<p style="color:var(--muted)">No treatments recorded in this session.</p>`;
        const GROUP_BADGE_COLORS = {
            disease:  { bg:"#fde8eb", color:"#9b1d2e" },
            previous: { bg:"#dbeafe", color:"#1a3d7a" },
            inside:   { bg:"#dcfce7", color:"#155d27" },
            others:   { bg:"#fef3c7", color:"#7c4a00" },
            note:     { bg:"#f1f5f9", color:"#374151" }
        };
        const badge = (group) => {
            const c = GROUP_BADGE_COLORS[group] || GROUP_BADGE_COLORS.note;
            const label = GROUP_LABELS[group] || group;
            return `<span style="background:${c.bg};color:${c.color};font-size:11px;font-weight:bold;
                                 padding:2px 8px;border-radius:20px;white-space:nowrap;">${label}</span>`;
        };
        // group by FDI tooth number
        const byTooth = {};
        rows.forEach(r => {
            if (!byTooth[r.fdi]) byTooth[r.fdi] = { fdi:r.fdi, tid:r.tid, items:[] };
            byTooth[r.fdi].items.push(r);
        });
        const toothBlocks = Object.values(byTooth).map(tooth => {
            const itemRows = tooth.items.map(r => `
                <tr>
                    <td style="padding:5px 8px;font-size:13px;color:#374151;white-space:nowrap;">
                        ${iconSvg(r.glyph, GROUP_COLORS[r.group] || "#6b7280", 18)}
                    </td>
                    <td style="padding:5px 8px;font-size:13px;color:#374151;
                               text-transform:capitalize;">${escapeHtml(
                                   getReportAreasText(r.areas || [])
                               )}</td>
                    <td style="padding:5px 8px;">${badge(r.group)}</td>
                    <td style="padding:5px 8px;font-size:13px;color:#111827;">${escapeHtml(r.label)}</td>
                </tr>`).join("");
            return `
                <div style="margin-bottom:10px;border:1px solid var(--line);
                            border-radius:12px;overflow:hidden;">
                    <div style="background:#f1f5f9;padding:7px 12px;font-weight:bold;
                                font-size:14px;border-bottom:1px solid var(--line);">
                        🦷 Tooth <span style="color:#2563eb">${tooth.fdi}</span>
                        <span style="font-weight:normal;color:var(--muted);
                                     font-size:12px;margin-left:6px;">(${tooth.tid})</span>
                    </div>
                    <table style="width:100%;border-collapse:collapse;">
                        <thead>
                            <tr style="background:#fafafa;">
                                <th style="padding:4px 8px;font-size:11px;color:var(--muted);
                                           text-align:left;font-weight:normal;width:28px;"></th>
                                <th style="padding:4px 8px;font-size:11px;color:var(--muted);
                                           text-align:left;font-weight:normal;">Area</th>
                                <th style="padding:4px 8px;font-size:11px;color:var(--muted);
                                           text-align:left;font-weight:normal;">Group</th>
                                <th style="padding:4px 8px;font-size:11px;color:var(--muted);
                                           text-align:left;font-weight:normal;">Treatment</th>
                            </tr>
                        </thead>
                        <tbody>${itemRows}</tbody>
                    </table>
                </div>`;
        });
        return toothBlocks.join("");
    }

    function closeSummary() {
        document.getElementById("summaryModal").classList.remove("open");
        _pendingSessionId = null;
    }

    async function previewSessionById(id) {
        // أغلق هيستوري وافتح السمري مودال
        closeHistory();
        _pendingSessionId = id;
        document.getElementById("summaryModal").classList.add("open");
        document.getElementById("summaryTable").innerHTML = "<p style='color:var(--muted)'>Loading...</p>";
        document.getElementById("summaryMeta").textContent = "";
        document.getElementById("summaryOpenBtn").onclick = () => confirmOpenSession(id);

        try {
            const res = await fetch(`${API_BASE}/single/${id}`);
            if (!res.ok) {
                document.getElementById("summaryTable").innerHTML = `<p style='color:red'>Failed to load (HTTP ${res.status})</p>`;
                return;
            }
            const result = await res.json();
            const jsonStr = pick(result, "chartDataJson", "ChartDataJson");
            const note    = pick(result, "sessionNote",   "SessionNote") || "—";
            const upd     = pick(result, "updatedAt",     "UpdatedAt");
            const loaded = JSON.parse(jsonStr);
            const rows   = buildSummaryFromData(loaded);

            document.getElementById("summaryMeta").innerHTML =
                `<b>Session #${id}</b> &nbsp;|&nbsp; ${new Date(upd).toLocaleString("en-GB")}
                 &nbsp;|&nbsp; Note: <i>${escapeHtml(note)}</i>
                 &nbsp;|&nbsp; <b>${rows.length}</b> recorded item(s)`;

            document.getElementById("summaryTable").innerHTML = buildSummaryTable(rows);
            document.getElementById("summaryOpenBtn").onclick = () => confirmOpenSession(id, result);
        } catch(err) {
            document.getElementById("summaryTable").innerHTML = `<p style='color:red'>${escapeHtml(err.message)}</p>`;
        }
    }

           async function confirmOpenSession(id, preloadedResult = null) {
        document.getElementById("summaryModal").classList.remove("open");
        _pendingSessionId = null;

        try {
            // استخدم الـ result المحفوظ إذا موجود، وإلا اعمل fetch جديد
            const result = preloadedResult || await (await fetch(`${API_BASE}/single/${id}`)).json();

            [...UPPER_IDS, ...LOWER_IDS].forEach(tid => { chartData[tid] = makeTooth(tid); });
            applyLoadedSession(result);

            setTimeout(() => {
                renderAll();
                setDbStatus(`✅ Session #${id} loaded`);
                showToast(`✅ Session #${id} loaded`, "success");
            }, 50);

        } catch (err) {
            showToast("❌ " + err.message, "error");
        }
    }
    // ════════════════════════════════════════════════════════════════
    //  DATABASE API
    // ════════════════════════════════════════════════════════════════
    function setDbStatus(msg) {
        document.getElementById("dbStatus").textContent = msg;
    }

    function resetPage() {
        currentSessionId = null;
        reportToolId     = null;   // ← reset صح كـ global
        selectedToolId   = null;
        selectedTarget   = null;
        [...UPPER_IDS, ...LOWER_IDS].forEach(id => { chartData[id] = makeTooth(id); });
        document.getElementById("sessionNoteGlobal").value = "";
        document.getElementById("noteBox").value = "";
        renderAll();
    }

    function applyLoadedSession(result) {
        const jsonStr = pick(result, "chartDataJson", "ChartDataJson");
        if (!jsonStr) throw new Error("chartDataJson missing in response");
        const loaded = JSON.parse(jsonStr);
        Object.keys(chartData).forEach(k => {
            if (loaded[k]) chartData[k] = loaded[k];
        });
        const note = pick(result, "sessionNote", "SessionNote") || "";
        document.getElementById("sessionNoteGlobal").value = note;
        currentSessionId = pick(result, "id", "Id");
        normalizeChartData();
    }

    function normalizeChartData() {
        const groups = ["disease", "previous", "inside", "others"];
        const areas  = ["buccal", "lingual", "palatal", "mesial", "distal", "occlusal", "root"];

        [...UPPER_IDS, ...LOWER_IDS].forEach(tid => {
            if (!chartData[tid]) {
                chartData[tid] = makeTooth(tid);
                return;
            }

            const tooth = chartData[tid];

            // Old saved sessions did not contain sourceId.
            if (!tooth.sourceId) tooth.sourceId = tid;

            // id always reflects the current chart position.
            tooth.id = tid;

            if (typeof tooth.isDeciduous !== "boolean") {
                tooth.isDeciduous = false;
            }

            if (!tooth.whole) tooth.whole = makeSlot();

            groups.forEach(g => {
                if (!Array.isArray(tooth.whole[g])) {
                    tooth.whole[g] = tooth.whole[g] ? [tooth.whole[g]] : [];
                }
            });

            if (!tooth.areas) tooth.areas = {};

            areas.forEach(area => {
                if (!tooth.areas[area]) tooth.areas[area] = makeSlot();

                groups.forEach(g => {
                    if (!Array.isArray(tooth.areas[area][g])) {
                        tooth.areas[area][g] = tooth.areas[area][g]
                            ? [tooth.areas[area][g]]
                            : [];
                    }
                });

                if (typeof tooth.areas[area].note !== "string") {
                    tooth.areas[area].note = "";
                }
            });

            // Upgrade old Root/Surface Bridge and Space Maintainer records.
            normalizeToothAppliance(tid);

            // Expand old Crown records into the five correct Surface areas.
            normalizeCrownMark(tid);

            // Upgrade old surface records for the three whole-tooth diseases.
            normalizeWholeToothDisease(tid);

            // Keep one icon per area from Disease / Previous / In-Hospital.
            normalizeSingleToothLockedMark(tid);

            // Keep Teeth Change and the deciduous-size state synchronized.
            normalizePermanentDeciduousState(tid);
        });
    }

    async function saveChartToDb() {
        if (!PATIENT_ID) { showToast("❌ Patient ID is not set!", "error"); return; }
        if (!currentSessionId) {
            showToast("⚠️ No active session — creating one automatically...", "info");
            await saveNewSession();
            return;
        }
        setDbStatus("⏳ Saving...");
        const payload = {
            patientId: PATIENT_ID,
            chartDataJson: JSON.stringify(chartData),
            sessionNote:
                document
                    .getElementById(
                        "sessionNoteGlobal"
                    )
                    .value
                    .trim(),
            reportJson: buildGroupedReportJson()
        };
        try {
            const res    = await fetch(`${API_BASE}/update/${currentSessionId}`, {
                method: "PUT", headers: {"Content-Type":"application/json"}, body: JSON.stringify(payload)
            });
            const result = await res.json();
            if (res.ok) {
                setDbStatus(`✅ Session #${currentSessionId} saved at ` + new Date().toLocaleTimeString());
                showToast(`✅ Session #${currentSessionId} saved!`, "success");
            } else {
                setDbStatus("❌ Save failed");
                showToast("❌ " + (result.message || result.Message || "Save failed"), "error");
            }
        } catch (err) {
            setDbStatus("❌ Connection error");
            showToast("❌ Server connection error", "error");
        }
    }

    async function loadChartFromDb() { openHistory(); }

    async function saveNewSession() {
        if (!PATIENT_ID) { showToast("❌ Patient ID is not set!", "error"); return; }
        const note = document.getElementById("sessionNoteGlobal").value.trim()
                   || prompt("Session note (optional):") || "";
        const payload = {
            patientId: PATIENT_ID,
            chartDataJson: JSON.stringify(chartData),
            sessionNote: note,
            reportJson: buildGroupedReportJson()
        };
        try {
            const res    = await fetch(`${API_BASE}/save-session`, {
                method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify(payload)
            });
            const result = await res.json();
            if (res.ok) {
                const newId = pick(result, "id", "Id");
                showToast(`✅ Session #${newId} saved — starting fresh`, "success");
                setDbStatus(`✅ Session #${newId} saved`);
                resetPage();
            } else {
                showToast("❌ " + (result.message || result.Message || "Save failed"), "error");
            }
        } catch (err) {
            showToast("❌ Server connection error", "error");
        }
    }

    async function openHistory() {
        document.getElementById("historyModal").classList.add("open");
        document.getElementById("historyList").innerHTML = "<p style='color:var(--muted)'>Loading...</p>";
        try {
            const res = await fetch(`${API_BASE}/history/${PATIENT_ID}`);
            if (!res.ok) {
                document.getElementById("historyList").innerHTML = `<p style='color:red'>Server error: ${res.status}</p>`;
                return;
            }
            const charts = await res.json();
            if (!Array.isArray(charts) || !charts.length) {
                document.getElementById("historyList").innerHTML = "<p style='color:var(--muted)'>No history found.</p>";
                return;
            }
            document.getElementById("historyList").innerHTML = charts.map(c => {
                const id        = pick(c, "id",          "Id");
                const updatedAt = pick(c, "updatedAt",   "UpdatedAt");
                const noteText  = pick(c, "sessionNote", "SessionNote") || "—";
                return `
                  <div class="history-item">
                    <div>
                      <div class="hi-meta">${new Date(updatedAt).toLocaleString("en-GB")} &bull; ID: ${id}</div>
                      <div class="hi-note">${escapeHtml(noteText)}</div>
                    </div>
    <button class="btn btn-primary" onclick="previewSessionById(${id})">📊 Preview</button>
    </div>`;
            }).join("");
        } catch (err) {
            document.getElementById("historyList").innerHTML = "<p style='color:red'>Failed to load history.</p>";
        }
    }

    function closeHistory() {
        document.getElementById("historyModal").classList.remove("open");
    }

    async function loadSessionById(id) {
        if (!id || id === "undefined") { showToast("❌ Invalid session ID", "error"); return; }
        try {
            const res = await fetch(`${API_BASE}/single/${id}`);
            if (!res.ok) { showToast(`❌ Failed to load session (HTTP ${res.status})`, "error"); return; }
            const result = await res.json();
            applyLoadedSession(result);
            renderAll();
            closeHistory();
            setDbStatus(`✅ Session #${id} loaded`);
            showToast(`✅ Session #${id} loaded`, "success");
        } catch (err) {
            showToast("❌ " + err.message, "error");
        }
    }

    async function loadLatestSession() {
        try {
            const res = await fetch(`${API_BASE}/${PATIENT_ID}`);
            if (!res.ok) return;
            const result = await res.json();
            applyLoadedSession(result);
            renderAll();
            setDbStatus(`✅ Session #${currentSessionId} loaded`);
        } catch (err) {
            console.error("loadLatestSession:", err);
        }
    }

    // ════════════════════════════════════════════════════════════════
    //  TOAST
    // ════════════════════════════════════════════════════════════════
    function showToast(msg, type = "info") {
        const colors = { success:"#16a34a", error:"#dc2626", info:"#2563eb", warning:"#f59e0b" };
        const el = document.createElement("div");
        el.className = "toast";
        el.style.background = colors[type] || "#374151";
        el.textContent = msg;
        document.getElementById("toastContainer").appendChild(el);
        setTimeout(() => { el.style.opacity = "0"; }, 2800);
        setTimeout(() => el.remove(), 3200);
    }

    // ════════════════════════════════════════════════════════════════
    //  SURFACE OUTSIDE-CLICK BEHAVIOR
    // ════════════════════════════════════════════════════════════════
    document.addEventListener("click", function (event) {
        /*
            Apply this behavior only when the most recent tooth click came
            from the Lingual / Palatal Surface diagram.
        */
        if (
            lastSelectionSource !== "surface" ||
            hideSurfaceSelectionHighlight
        ) {
            return;
        }

        const clickedInsideSurface =
            event.target.closest(
                ".lingual-palatal-surface-svg"
            );

        if (clickedInsideSurface) {
            return;
        }

        /*
            Hide the selected dark border only.
            Do not clear:
            - selectedTarget
            - selectedToolId
            - treatments
            - notes
            - reports
            - database data
        */
        hideSurfaceSelectionHighlight = true;

        /*
            Only the chart needs to be redrawn. Selected Details and the
            selected labels remain available on the right side.
        */
        renderChart();
    });

    // ════════════════════════════════════════════════════════════════
    //  INIT
    // ════════════════════════════════════════════════════════════════
    renderAll();
    if (PATIENT_ID > 0) {
        loadLatestSession();
    }
</script>