            case 21: return `<pattern id="${patId}" patternUnits="userSpaceOnUse" width="7" height="7"${transform}><line x1="2" y1="0" x2="2" y2="7" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><line x1="5" y1="0" x2="5" y2="7" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/></pattern>`;
            case 22: return `<pattern id="${patId}" patternUnits="userSpaceOnUse" width="7" height="7"${transform}><line x1="0" y1="2" x2="7" y2="2" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/><line x1="0" y1="5" x2="7" y2="5" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/></pattern>`;
