        const safeColor = String(color).replace(/[^a-zA-Z0-9]/g, "");
        const safeGroup = String(group || "").replace(/[^a-zA-Z0-9]/g, "");
        const uid = `pat_${glyph}_${safeColor}_${safeGroup}_${iconSvg._uid}`;

        const PATTERNS = {
            caries:{p:1},secondary:{p:2},periapical:{p:3},crack:{p:4},mobility:{p:5},
            remainingRoot:{p:6},surfaceLoss:{p:7},resto1:{p:8},resto2:{p:9},resto3:{p:10},
            resto4:{p:11},resto5:{p:12},crown1:{p:13},crown2:{p:14},crown3:{p:15},
            crown4:{p:27},crown5:{p:17},crown6:{p:18},crown:{p:19},bridge:{p:20},
            rct:{p:21},vpt:{p:22},post:{p:23},splint:{p:24},denture:{p:25},
            spaceMaintainer:{p:26},impacted:{p:1,rotate:25},softImpacted:{p:2,rotate:-25},
            partiallyErupted:{p:3},transposition:{p:4},teethChange:{p:5},
            extracted:{p:6},restoration:{p:7},note:{p:8},
            pulpotomy:{p:28},pulpectomy:{p:29},ccDenture:{p:30},
