        }

        return rows.map(row => {
            if (row.type === "note") {
                const areaLabel =
                    getReportAreaLabel(row.area);

                return `
                    <div class="mini-item"
                         style="margin-bottom:7px;align-items:flex-start;
                                border-left:3px solid #6b7280;">
                        <div class="mini-icon">
                            ${iconSvg(
                                "note",
                                "#6b7280",
                                22
                            )}
                        </div>

                        <div class="mini-text">
                            <div class="key">
                                Action
                            </div>
                            <div class="value"
                                 style="margin-bottom:6px;">
                                Area Note
                            </div>

                            <div class="key">
                                Selected Tooth
                            </div>
                            <div class="value"
                                 style="margin-bottom:6px;">
                                ${escapeHtml(row.toothId)}
                            </div>

                            <div class="key">
                                Selected Area
                            </div>
                            <div class="value"
                                 style="margin-bottom:6px;">
                                ${escapeHtml(areaLabel)}
                            </div>

                            <div class="key">
                                Note
                            </div>
                            <div class="value">
                                ${escapeHtml(row.note)}
                            </div>
                        </div>

                        <button type="button"
                                title="Delete note"
                                onclick="clearAreaNoteFor(
                                    '${row.toothId}',
                                    '${row.area}'
                                )">
                            ✕
                        </button>
                    </div>`;
            }

            const tool = row.tool;
            const color =
                GROUP_COLORS[row.group] ||
                GROUP_COLORS.others;

            const areasText =
                getReportAreasText(
                    row.areas || []
                );

            if (row.type === "swap") {
                return `
                    <div class="mini-item"
                         style="margin-bottom:7px;align-items:flex-start;
                                border-left:3px solid ${color};">
                        <div class="mini-icon">
                            ${iconSvg(
                                tool.glyph,
                                color,
                                22,
                                row.group
                            )}
                        </div>

                        <div class="mini-text">
                            <div class="key">
                                Selected Tool
                            </div>
                            <div class="value"
                                 style="color:${color};margin-bottom:6px;">
                                ${escapeHtml(tool.label)}
                            </div>

                            <div class="key">
                                Selected Tooth
                            </div>
                            <div class="value"
                                 style="margin-bottom:6px;">
                                ${escapeHtml(row.toothId)}
                            </div>

                            <div class="key">
                                Selected Area
                            </div>
                            <div class="value"
                                 style="margin-bottom:6px;">
                                Whole Tooth
                            </div>

                            <div class="key">
                                Current Source Tooth
                            </div>
                            <div class="value">
                                ${escapeHtml(row.sourceToothId)}
                            </div>
                        </div>
                    </div>`;
            }

            const encodedAreas =
                encodeURIComponent(
                    JSON.stringify(row.areas)
                );

            return `
                <div class="mini-item"
                     style="margin-bottom:7px;align-items:flex-start;
                            border-left:3px solid ${color};">
                    <div class="mini-icon">
                        ${iconSvg(
                            tool.glyph,
                            color,
                            22,
                            row.group
                        )}
                    </div>

                    <div class="mini-text">
                        <div class="key">
                            Selected Tool
                        </div>
                        <div class="value"
                             style="color:${color};margin-bottom:6px;">
                            ${escapeHtml(tool.label)}
                        </div>

                        <div class="key">
                            Group
                        </div>
                        <div class="value"
                             style="margin-bottom:6px;">
                            ${escapeHtml(
                                GROUP_LABELS[row.group] ||
                                row.group
                            )}
                        </div>

                        <div class="key">
                            Selected Tooth
                        </div>
                        <div class="value"
                             style="margin-bottom:6px;">
                            ${escapeHtml(row.toothId)}
                        </div>

                        <div class="key">
                            Selected Area
                        </div>
                        <div class="value">
                            ${escapeHtml(areasText)}
                        </div>
                    </div>

                    <button type="button"
                            title="Delete this action"
                            onclick="removeGroupedToolUsage(
                                '${row.toothId}',
                                '${row.toolId}',
                                '${row.group}',
                                '${encodedAreas}'
                            )">
                        ✕
                    </button>
                </div>`;
        }).join("");
    }

    // ════════════════════════════════════════════════════════════════
    //  RENDER
    // ════════════════════════════════════════════════════════════════
    function renderSideInfo() {
        const AREA_NAMES = ["buccal","lingual","palatal","mesial","distal","occlusal","root"];
        const GRPS       = ["disease","previous","inside","others"];

        const selectedTool = selectedToolId
            ? getTool(selectedToolId)
            : null;

        document.getElementById(
            "selectedToolLabel"
        ).textContent = selectedTool
            ? selectedTool.label
            : "—";

        document.getElementById(
            "selectedToothLabel"
        ).textContent = selectedTarget
            ? selectedTarget.toothId
            : "—";

        let selectedAreasText = "—";

        if (selectedTarget) {
            selectedAreasText = getReportAreaLabel(
                selectedTarget.area
            );

            if (selectedToolId) {
                const selectedToolReport =
                    buildToolReport()[selectedToolId] || [];

                const groupedUsage =
                    selectedToolReport.find(usage =>
                        usage.toothId ===
                        selectedTarget.toothId
                    );

                if (
                    groupedUsage &&
                    groupedUsage.areas.length
                ) {
                    selectedAreasText =
                        getReportAreasText(
                            groupedUsage.areas
                        );
                }
            }
        }

        document.getElementById(
            "selectedAreaLabel"
        ).textContent = selectedAreasText;

        // ── Report Panel ──
        const report      = buildToolReport();
        const reportKeys  = Object.keys(report);
        const reportPanel = document.getElementById("reportPanel");
        if (reportPanel) {
            if (!reportKeys.length) {
                reportPanel.innerHTML = `<div style="color:var(--muted);font-size:13px;padding:6px 0;">No tools applied yet.</div>`;
            } else {
                reportPanel.innerHTML = reportKeys.map(toolId => {
                    const tool     = getTool(toolId);
                    if (!tool) return "";
                    const color = GROUP_COLORS[tool.group];
                    const usages = report[toolId];
                    const groupedAreaCount = usages.reduce(
                        (total, usage) =>
                            total + usage.areas.length,
                        0
                    );
                    const isActive =
                        reportToolId === toolId;

                    return `
                    <div onclick="selectReportTool('${toolId}')"
                         style="display:flex;align-items:center;gap:8px;padding:8px 10px;
                                border-radius:10px;cursor:pointer;margin-bottom:5px;
                                border:2px solid ${isActive ? color : 'var(--line)'};
                                background:${isActive ? hexToRgba(color,.07) : '#fafafa'};
                                transition:.15s;">
                        <div style="flex:0 0 auto;">${iconSvg(tool.glyph, color, 28)}</div>
                        <div style="flex:1;min-width:0;">
                            <div style="font-size:12px;font-weight:bold;color:${color};
                                        white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                ${escapeHtml(tool.label)}
                            </div>
                            <div style="font-size:11px;color:var(--muted);">
                                ${GROUP_LABELS[tool.group]} ·
                                ${usages.length} report${usages.length !== 1 ? 's' : ''} ·
                                ${groupedAreaCount} area${groupedAreaCount !== 1 ? 's' : ''}
                            </div>
                        </div>
                        <div style="font-size:16px;font-weight:bold;color:${color};flex:0 0 auto;
                                    background:${hexToRgba(color,.12)};border-radius:8px;padding:2px 8px;">
                            ${usages.length}
                        </div>
                    </div>`;
                }).join("");
            }
        }

        // ── Detail List ──
        const detailList = document.getElementById("detailList");

        if (reportToolId) {
            const tool   = getTool(reportToolId);
            const usages = report[reportToolId] || [];
            const color  = tool ? GROUP_COLORS[tool.group] : "#6b7280";
            if (!tool || !usages.length) {
                detailList.innerHTML = `<div style="color:var(--muted);font-size:13px;">Nothing found.</div>`;
                return;
            }
            detailList.innerHTML = `
                <div style="font-size:12px;font-weight:bold;color:${color};
                            margin-bottom:8px;display:flex;align-items:center;gap:6px;">
                    ${iconSvg(tool.glyph, color, 18)}
                    ${escapeHtml(tool.label)}

                    <span style="margin-left:auto;background:${hexToRgba(color,.12)};
                                 color:${color};border-radius:6px;padding:1px 8px;font-size:11px;">
                        ${usages.length} report${usages.length !== 1 ? 's' : ''}
                    </span>
                </div>

                ${usages.map(usage => {
                    const encodedAreas =
                        encodeURIComponent(
                            JSON.stringify(usage.areas)
                        );

                    const areasText =
                        getReportAreasText(
                            usage.areas
                        );

                    return `
                        <div class="mini-item"
                             style="margin-bottom:7px;
                                    cursor:pointer;
                                    align-items:flex-start;
                                    border-left:3px solid ${GROUP_COLORS[usage.group]};"
                             onclick="selectGroupedReportUsage(
                                '${tool.id}',
                                '${usage.toothId}',
                                '${encodedAreas}'
                             )">

                            <div class="mini-icon">
                                ${iconSvg(
                                    tool.glyph,
                                    GROUP_COLORS[usage.group],
                                    22,
                                    usage.group
                                )}
                            </div>

                            <div class="mini-text">
                                <div class="key">
                                    Selected Tool
                                </div>
                                <div class="value"
                                     style="color:${GROUP_COLORS[usage.group]};margin-bottom:6px;">
                                    ${escapeHtml(tool.label)}
                                </div>

                                <div class="key">
                                    Selected Tooth
                                </div>
                                <div class="value"
                                     style="margin-bottom:6px;">
                                    ${escapeHtml(usage.toothId)}
                                </div>

                                <div class="key">
                                    Selected Area
                                </div>
                                <div class="value">
                                    ${escapeHtml(areasText)}
                                </div>
                            </div>
                        </div>`;
                }).join("")}`;
            return;
        }

        if (!selectedTarget) {
            detailList.innerHTML = `
                <div style="color:#6b7280;font-size:13px;">
                    Nothing selected.
                </div>`;

            document.getElementById(
                "noteBox"
            ).value = "";

            return;
        }

        const {
            toothId,
            area
        } = selectedTarget;

        const tooth =
            chartData[toothId];

        const selectedSlot =
            area === "whole"
                ? tooth?.whole
                : tooth?.areas?.[area];

        /*
            This fixes whole-tooth actions such as:
            Bridge, Tooth Mobility, Periapical Lesion, Crack Tooth,
            Extracted Tooth and Teeth Transposition.
        */
        document.getElementById(
            "noteBox"
        ).value = selectedSlot?.note || "";

        /*
            Selected Details now always includes every action applied to the
            selected tooth, regardless of whether it is stored on:
            - Whole Tooth
            - Root
            - Any surface area
            - Others / transformation actions
            - Notes
        */
        detailList.innerHTML =
            renderSelectedToothActions(
                toothId
            );
    }
        function openOthersTextModal(tid, area) {
        const existing = chartData[tid].areas[area].note || "";
        const modal = document.getElementById("othersTextModal");
        document.getElementById("othersTextInput").value = existing;
        document.getElementById("othersTextTitle").textContent = `📝 Tooth ${tid} — ${area}`;
        modal.classList.add("open");
        modal.dataset.tid  = tid;
        modal.dataset.area = area;
        setTimeout(() => document.getElementById("othersTextInput").focus(), 100);
    }

    function saveOthersText() {
        const modal = document.getElementById("othersTextModal");
        const tid   = modal.dataset.tid;
        const area  = modal.dataset.area;
        const text  = document.getElementById("othersTextInput").value.trim();
        if (text) {
            // أضف الأداة others_text على المنطقة
            const arr = chartData[tid].areas[area]["others"];
            if (!arr.includes("others_text")) arr.push("others_text");
            // احفظ النص كـ note
            chartData[tid].areas[area].note = text;
        }
        modal.classList.remove("open");
        renderAll();
    }

    function closeOthersTextModal() {
        document.getElementById("othersTextModal").classList.remove("open");
    }
