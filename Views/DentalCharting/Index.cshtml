            case 3:  return `<pattern id="${patId}" patternUnits="userSpaceOnUse" width="${sp}" height="${sp}"${transform}><line x1="${sp/2}" y1="0" x2="${sp/2}" y2="${sp}" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/></pattern>`;
            case 4:  return `<pattern id="${patId}" patternUnits="userSpaceOnUse" width="${sp}" height="${sp}"${transform}><line x1="0" y1="${sp/2}" x2="${sp}" y2="${sp/2}" stroke="${color}" stroke-width="${sw}" stroke-opacity="${op}"/></pattern>`;
