            crown6:`<path d="M8 22 L10 10 L14 16 L16 8 L18 16 L22 10 L24 22 Q22 27 16 27 Q10 27 8 22 Z" ${H}/>`
        };

        return `<svg width="${size}" height="${size}" viewBox="4 4 24 24" xmlns="http://www.w3.org/2000/svg">
                    <defs>${patternDef}</defs>
                    ${map[glyph] || map.note}
                </svg>`;
    }

