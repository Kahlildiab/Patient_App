@* ─────────────────────────────────────────────────────────────────────────
   Views/DentalCharting/Index.cshtml
───────────────────────────────────────────────────────────────────────── *@
@{
    ViewData["Title"] = "Dental Chart";
    var patientId = ViewBag.PatientId ?? 0;
}

<style>
    * {
        box-sizing: border-box;
    }

    :root {
        --bg: #f4f6fb;
        --panel: #ffffff;
        --line: #d7dde6;
        --soft: #eef2f7;
        --text: #1f2937;
        --muted: #6b7280;
        --disease: #d9485f;
        --previous: #2463b3;
        --inside: #2f9e44;
        --others: #f08c00;
        --neutral: #8a93a3;
    }

    body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: var(--bg);
        color: var(--text);
    }

    .app {
        width: 111%;
        margin: 0 auto;
        padding: 12px;
    }

    .topbar {
        position: sticky;
        top: 0;
        z-index: 30;
        background: rgba(244,246,251,.96);
        backdrop-filter: blur(4px);
        padding-bottom: 12px;
    }

    .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 10px;
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 12px 16px;
    }

        .header h1 {
            margin: 0;
            font-size: 28px;
        }

        .header small {
            color: var(--muted);
            display: block;
            margin-top: 4px;
            font-size: 13px;
        }

    .db-bar {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
    }

        .db-bar .db-status {
            font-size: 13px;
            color: var(--muted);
            margin-left: auto;
        }

    .toolbar {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 10px;
    }

    .toolbar-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
    }

    .tool-strip {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        justify-content: space-evenly;
    }

    .group-block {
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 8px;
        background: #fff;
        min-width: max-content;
    }

    .group-title {
        font-size: 12px;
        font-weight: bold;
        color: #111827;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
    }

    .group-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
    }

    .tool-strip {
        display: flex;
        gap: 6px;
        flex-wrap: nowrap;
    }

    .tool-btn {
        flex: 1;
        max-width: 60px;
        width: 54px;
        height: 44px;
        border: 0px solid var(--line);
        background: #fff;
        border-radius: 10px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: .15s;
        position: relative;
        flex: 0 0 auto;
    }

        .tool-btn:hover {
            transform: translateY(-1px);
    background: #f0f4ff;
        }

        .tool-btn.active {
            background: #e8f0ff;
    box-shadow: 0 0 0 3px rgba(17,24,39,.12);
    border-radius: 12px;
        }

        .tool-btn .tip {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            bottom: -34px;
            background: #111827;
            color: #fff;
            font-size: 11px;
            padding: 4px 7px;
            border-radius: 8px;
            white-space: nowrap;
            opacity: 0;
            pointer-events: none;
            transition: .15s;
            z-index: 99;
        }

        .tool-btn:hover .tip {
            opacity: 1;
        }

    .main {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 12px;
        margin-top: 12px;
        align-items: start;
    }

    .chart-panel,
    .side-panel {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 14px;
    }

    .side-panel {
        position: sticky;
        top: 160px;
    }

    .status-box {
        background: #f8fafc;
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 12px;
        margin-bottom: 12px;
        font-size: 14px;
        line-height: 1.6;
    }

        .status-box b {
            color: #111827;
        }

    .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 10px;
    }

    .btn {
        border: none;
        border-radius: 10px;
        padding: 10px 12px;
        cursor: pointer;
        font-weight: bold;
        font-size: 13px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: opacity .15s, transform .1s;
    }

        .btn:hover {
            opacity: .88;
            transform: translateY(-1px);
        }

        .btn:active {
            transform: translateY(0);
        }

    .btn-secondary {
        background: #e5e7eb;
        color: #111827;
    }

    .btn-danger {
        background: #dc2626;
        color: #fff;
    }

    .btn-primary {
        background: #2563eb;
        color: #fff;
    }

    .btn-warning {
        background: #f59e0b;
        color: #fff;
    }

    .btn-green {
        background: #16a34a;
        color: #fff;
    }

    textarea {
        width: 100%;
        min-height: 90px;
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 10px;
        resize: vertical;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 14px;
        margin-top: 8px;
    }

    .legend {
        margin-top: 12px;
        font-size: 13px;
        color: #4b5563;
        line-height: 1.6;
        background: #fafafa;
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 10px;
    }

    .chart-title {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        gap: 12px;
        flex-wrap: wrap;
    }

        .chart-title h2 {
            margin: 0;
            font-size: 22px;
        }

        .chart-title .hint {
            color: var(--muted);
            font-size: 13px;
        }

    .chart-grid {
        display: grid;
        grid-template-columns: 52px repeat(16, minmax(56px, 1fr));
        gap: 6px;
        align-items: center;
    }

    .side-label {
        writing-mode: vertical-rl;
        transform: rotate(180deg);
        text-align: center;
        color: #4b5563;
        font-style: italic;
        font-size: 14px;
        padding: 8px 0;
        justify-self: center;
        align-self: stretch;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .number-cell {
        text-align: center;
        font-size: 18px;
        font-weight: bold;
        color: #111827;
        padding: 2px 0 6px;
    }

    .tooth-cell {
        text-align: center;
        padding: 2px;
    }

    .tooth-svg {
        width: 135%;
        height: auto;
        display: block;
        cursor: pointer;
    }

    .mid-rl {
        grid-column: 2 / span 16;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: #4b5563;
        font-size: 22px;
        font-weight: bold;
        padding: 2px 8px 6px;
        border-top: 1px solid #e5e7eb;
        border-bottom: 1px solid #e5e7eb;
        margin: 4px 0;
    }

    .mini-list {
        display: grid;
        gap: 8px;
        margin-top: 12px;
    }

    .mini-item {
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 8px;
        display: flex;
        gap: 8px;
        align-items: center;
        background: #fff;
    }

    .mini-icon {
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--line);
        border-radius: 8px;
        flex: 0 0 auto;
    }

    .mini-text {
        font-size: 13px;
        line-height: 1.4;
        min-width: 0;
        flex: 1;
    }

        .mini-text .key {
            font-size: 11px;
            color: var(--muted);
            text-transform: uppercase;
        }

        .mini-text .value {
            font-weight: bold;
            word-break: break-word;
        }

    .mini-item button {
        width: 28px;
        height: 28px;
        border: none;
        border-radius: 8px;
        background: #ef4444;
        color: #fff;
        font-weight: bold;
        cursor: pointer;
        flex: 0 0 auto;
    }

    .session-note-wrap {
        margin-top: 10px;
    }

        .session-note-wrap label {
            font-size: 13px;
            font-weight: bold;
            display: block;
            margin-bottom: 4px;
        }

        .session-note-wrap textarea {
            min-height: 56px;
        }

    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.45);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }

        .modal-overlay.open {
            display: flex;
        }

    .modal-box {
        background: #fff;
        border-radius: 18px;
        padding: 20px;
        width: 90%;
        max-width: 600px;
        max-height: 80vh;
        overflow-y: auto;
        box-shadow: 0 20px 60px rgba(0,0,0,.25);
    }

        .modal-box h3 {
            margin: 0 0 14px;
            font-size: 20px;
        }

    .history-item {
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 12px;
        margin-bottom: 8px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
    }

        .history-item .hi-meta {
            font-size: 13px;
            color: var(--muted);
        }

        .history-item .hi-note {
            font-weight: bold;
            font-size: 14px;
            margin-top: 2px;
        }

    #toastContainer {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .toast {
        padding: 12px 20px;
        border-radius: 12px;
        color: #fff;
        font-size: 14px;
        font-weight: bold;
        box-shadow: 0 4px 20px rgba(0,0,0,.25);
        animation: slideIn .25s ease;
        transition: opacity .4s;
    }

    @@keyframes slideIn {
        from {
            transform: translateX(40px);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @@media (max-width: 1280px) {
        .main {
            grid-template-columns: 1fr;
        }

        .side-panel {
            position: static;
        }
    }

    @@media (max-width: 920px) {
        .chart-grid {
            grid-template-columns: 42px repeat(16, minmax(48px, 1fr));
        }

        .number-cell {
            font-size: 15px;
        }
    }
</style>

<div id="toastContainer"></div>

<!-- History Modal -->
<div class="modal-overlay" id="historyModal">
    <div class="modal-box">
        <h3>📋 Previous Sessions History</h3>
        <div id="historyList"><p style="color:var(--muted)">Loading...</p></div>
        <div style="margin-top:14px;text-align:right;">
            <button class="btn btn-secondary" onclick="closeHistory()">✕ Close</button>
        </div>
    </div>
</div>
<div class="modal-overlay" id="summaryModal">
    <div class="modal-box" style="max-width:700px">
        <h3>📊 Session Summary</h3>
        <div id="summaryMeta" style="font-size:13px;color:var(--muted);margin-bottom:12px;"></div>
        <div id="summaryTable"></div>
        <div style="margin-top:14px;display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap;">
            <button class="btn btn-secondary" onclick="closeSummary()">✕ Close</button>
            <button class="btn btn-primary" id="summaryOpenBtn">📂 Open in Chart</button>
        </div>
    </div>
</div>
<div class="modal-overlay" id="othersTextModal">
    <div class="modal-box" style="max-width:460px;">
        <h3 id="othersTextTitle">📝 Add Note</h3>
        <textarea id="othersTextInput"
                  placeholder="اكتب ملاحظتك هنا / Write your note here..."
                  style="min-height:120px;margin-top:0;font-size:15px;"></textarea>
        <div style="margin-top:14px;display:flex;gap:8px;justify-content:flex-end;">
            <button class="btn btn-secondary" onclick="closeOthersTextModal()">✕ Cancel</button>
            <button class="btn btn-primary" onclick="saveOthersText()">💾 Save Note</button>
        </div>
    </div>
</div>
<div class="app">
    <div class="topbar">
        <div class="header">
            <div>
                <h1>🦷 Dental Chart</h1>
                <small>Patient ID: <strong>@patientId</strong> — SVG Interactive Chart</small>
            </div>
            <div class="db-bar">
                <button class="btn btn-primary" onclick="loadChartFromDb()">📥 Load</button>
                <button class="btn btn-green" onclick="saveChartToDb()">💾 Save</button>
                <button class="btn btn-warning" onclick="saveNewSession()">🗂️ New Session</button>
                <button class="btn btn-secondary" onclick="openHistory()">🕐 History</button>
                <span class="db-status" id="dbStatus">—</span>
            </div>
        </div>

        <div class="toolbar" id="toolbar"></div>
    </div>

    <div class="main">
        <div class="chart-panel">
            <div class="chart-title">
                <h2>Interactive Dental Chart</h2>
                <div class="hint">Select a tool from the toolbar, then click on a tooth area.</div>
            </div>
            <div id="chartHost"></div>
        </div>

        <div class="side-panel">
            
            <div class="status-box">
                <div><b>Selected Tool:</b>  <span id="selectedToolLabel">—</span></div>
                <div><b>Selected Tooth:</b> <span id="selectedToothLabel">—</span></div>
                <div><b>Selected Area:</b>  <span id="selectedAreaLabel">—</span></div>

                <div class="actions">
                    <button class="btn btn-secondary" onclick="clearSelectedTarget()">Clear Area</button>
                    <button class="btn btn-danger" onclick="clearSelectedTooth()">Clear Tooth</button>
                    <button class="btn btn-warning" onclick="clearAllChart()">Clear All</button>
                </div>

                <div style="margin-top:10px;"><b>Area Note</b></div>
                <textarea id="noteBox" placeholder="Write a note for the selected area..."></textarea>
                <div class="actions">
                    <button class="btn btn-primary" onclick="saveNote()">💾 Save Note</button>
                </div>

                <div class="session-note-wrap">
                    <label>General Session Note</label>
                    <textarea id="sessionNoteGlobal" placeholder="General note for this session..."></textarea>
                </div>
            </div>

            <div class="legend">
                <b>Colors:</b><br>
                <span style="color:#d9485f">■</span> Disease &nbsp;
                <span style="color:#2463b3">■</span> Previous Treatment &nbsp;
                <span style="color:#2f9e44">■</span> In-Hospital &nbsp;
                <span style="color:#f08c00">■</span> Others
                <br><br>
                <b>Scope:</b><br>
                Surface = Selected area only<br>
                Root = Root only<br>
                Whole = Entire tooth in all views
            </div>

            <div style="margin-top:12px;font-weight:bold;">Selected Details</div>
            <div class="mini-list" id="detailList">
                <div style="margin-top:12px;font-weight:bold;">Tool Report</div>
                <div id="reportPanel" style="margin-top:8px;"></div>

                <div style="margin-top:12px;font-weight:bold;">Selected Details</div>
                <div class="mini-list" id="detailList">
                    <div style="color:#6b7280;font-size:13px;">Nothing selected.</div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
       // ════════════════════════════════════════════════════════════════
    //  CONFIG
    // ════════════════════════════════════════════════════════════════
    const PATIENT_ID = @patientId;
    const API_BASE = "/DentalChart/api";

    // ════════════════════════════════════════════════════════════════
    //  CONSTANTS
    // ════════════════════════════════════════════════════════════════
    const GROUP_COLORS = {
        disease:  getComputedStyle(document.documentElement).getPropertyValue('--disease').trim(),
        previous: getComputedStyle(document.documentElement).getPropertyValue('--previous').trim(),
        inside:   getComputedStyle(document.documentElement).getPropertyValue('--inside').trim(),
        others:   getComputedStyle(document.documentElement).getPropertyValue('--others').trim()
    };

    const GROUP_LABELS = {
        disease:  "Disease",
        previous: "Previous Treatment",
        inside:   "In-Hospital",
        others:   "Others"
    };

    const TOOLS = [
        { id:"caries",                      label:"Caries",                             group:"disease",  glyph:"caries",           scope:"surface" },
        { id:"secondary_caries",            label:"Secondary Caries",                   group:"disease",  glyph:"secondary",        scope:"surface" },
        { id:"periapical_lesion",           label:"Periapical Lesion",                  group:"disease",  glyph:"periapical",       scope:"surface" },
        { id:"crack_tooth",                 label:"Crack Tooth",                        group:"disease",  glyph:"crack",            scope:"surface" },
        { id:"tooth_mobility",              label:"Tooth Mobility",                     group:"disease",  glyph:"mobility",         scope:"surface" },
        { id:"remaining_root",              label:"Remaining Root",                     group:"disease",  glyph:"remainingRoot",    scope:"surface" },
        { id:"surface_loss",                label:"Tooth Surface Loss",                 group:"disease",  glyph:"surfaceLoss",      scope:"surface" },

        { id:"amalgam_prev",                label:"Amalgam",                            group:"previous", glyph:"resto1",           scope:"surface" },
        { id:"composite_prev",              label:"Composite Restoration",              group:"previous", glyph:"resto2",           scope:"surface" },
        { id:"gic_prev",                    label:"GIC",                                group:"previous", glyph:"resto3",           scope:"surface" },
        { id:"temporary_restoration_prev",  label:"Temporary Restoration",              group:"previous", glyph:"resto4",           scope:"surface" },
        { id:"partial_restoration_prev",    label:"Partial Restoration",                group:"previous", glyph:"resto5",           scope:"surface" },
        { id:"metal_crown_prev",            label:"Metal Crown",                        group:"previous", glyph:"crown1",           scope:"surface" },
        { id:"zirconia_crown_prev",         label:"Zirconia Crown",                     group:"previous", glyph:"crown2",           scope:"surface" },
        { id:"emax_crown_prev",             label:"Emax Crown",                         group:"previous", glyph:"crown3",           scope:"surface" },
        { id:"pfm_crown_prev",              label:"PFM Crown",                          group:"previous", glyph:"crown4",           scope:"surface" },
        {id:"temporary_crown_prev",         label:"Temporary Crown",                    group:"previous", glyph:"tempCrown",        scope:"surface" },
        { id:"stainless_crown_prev",        label:"Stainless Steel Crown",              group:"previous", glyph:"crown6",           scope:"surface" },
        { id:"resin_bonded_bridge_prev",    label:"Resin Bonded Bridge",                group:"previous", glyph:"bridge",           scope:"surface" },
        { id:"root_canal_prev",             label:"Root Canal Treatment",               group:"previous", glyph:"rct",              scope:"surface" },
        { id:"vital_pulp_therapy_prev",     label:"Vital Pulp Therapy",                 group:"previous", glyph:"vpt",              scope:"surface" },
        { id:"post_prev",                   label:"Post",                               group:"previous", glyph:"post",             scope:"surface" },
        { id:"stabilization_splint_prev",   label:"Stabilization Splint",               group:"previous", glyph:"splint",           scope:"surface" },
        { id:"partial_acrylic_denture_prev",label:"Partial Acrylic Denture",            group:"previous", glyph:"denture",          scope:"surface" },
        { id:"cc_denture_prev",             label:"Cobalt Chromium Partial Denture",    group:"previous", glyph:"ccDenture",        scope:"surface" },
        { id:"complete_denture_prev",       label:"Complete Denture",                   group:"previous", glyph:"completeDenture",  scope:"surface" },
        { id:"space_maintainer_prev",       label:"Space Maintainer",                   group:"previous", glyph:"spaceMaintainer",  scope:"surface" },
        { id:"pulpotomy_prev",              label:"Pulpotomy",                          group:"previous", glyph:"pulpotomy",        scope:"surface" },
        { id:"pulpectomy_prev",             label:"Pulpectomy",                         group:"previous", glyph:"pulpectomy",       scope:"surface" },

        { id:"amalgam_in",                  label:"Amalgam",                            group:"inside",   glyph:"resto1",           scope:"surface" },
        { id:"composite_in",                label:"Composite Restoration",              group:"inside",   glyph:"resto2",           scope:"surface" },
        { id:"gic_in",                      label:"GIC",                                group:"inside",   glyph:"resto3",           scope:"surface" },
        { id:"temporary_restoration_in",    label:"Temporary Restoration",              group:"inside",   glyph:"resto4",           scope:"surface" },
        { id:"partial_restoration_in",      label:"Partial Restoration",                group:"inside",   glyph:"resto5",           scope:"surface" },
        { id:"metal_crown_in",              label:"Metal Crown",                        group:"inside",   glyph:"crown1",           scope:"surface" },
        { id:"ceramic_crown_in",            label:"Ceramic Crown",                      group:"inside",   glyph:"crown2",           scope:"surface" },
        { id:"emax_crown_in",               label:"Emax Crown",                         group:"inside",   glyph:"crown3",           scope:"surface" },
        { id:"pfm_crown_in",                label:"PFM Crown",                          group:"inside",   glyph:"crown4",           scope:"surface" },
        { id:"temporary_crown_in",          label:"Temporary Crown",                    group:"inside",   glyph:"tempCrown",        scope:"surface" },
        { id:"stainless_crown_in",          label:"Stainless Steel Crown",              group:"inside",   glyph:"crown6",           scope:"surface" },
        { id:"resin_bonded_bridge_in",      label:"Resin Bonded Bridge",                group:"inside",   glyph:"bridge",           scope:"surface" },
        { id:"root_canal_in",               label:"Root Canal Treatment",               group:"inside",   glyph:"rct",              scope:"surface" },
        { id:"vpt_in",                      label:"Vital Pulp Therapy",                 group:"inside",   glyph:"vpt",              scope:"surface" },
        { id:"post_in",                     label:"Post",                               group:"inside",   glyph:"post",             scope:"surface" },
        { id:"stabilization_splint_in",     label:"Stabilization Splint",               group:"inside",   glyph:"splint",           scope:"surface" },
        { id:"partial_denture_in",          label:"Partial Acrylic Denture",            group:"inside",   glyph:"denture",          scope:"surface" },
        { id:"cc_denture_in",               label:"Cobalt Chromium Partial Denture",    group:"inside",   glyph:"ccDenture",        scope:"surface" },
        { id:"complete_denture_in",         label:"Complete Denture",                   group:"inside",   glyph:"completeDenture",  scope:"surface" },
        { id:"space_maintainer_in",         label:"Space Maintainer",                   group:"inside",   glyph:"spaceMaintainer",  scope:"surface" },
        { id:"pulpotomy_in",                label:"Pulpotomy",                          group:"inside",   glyph:"pulpotomy",        scope:"surface" },
        { id:"pulpectomy_in",               label:"Pulpectomy",                         group:"inside",   glyph:"pulpectomy",       scope:"surface" },
        { id:"extracted_tooth_in",          label:"Extracted Tooth",                    group:"inside",   glyph:"extracted",        scope:"surface" },

        { id:"impacted_tooth",              label:"Impacted Tooth",                     group:"others",   glyph:"impacted",         scope:"surface" },
        { id:"soft_tissue_impacted",        label:"Soft Tissue Impacted Tooth",         group:"others",   glyph:"softImpacted",     scope:"surface" },
