        function makeTooth(id) {
        return {
            id,
            isDeciduous: false,   // ⬅️ جديد: false = دائم (Permanent) / true = لبني (Deciduous)
            whole: makeSlot(),
            areas: {
                buccal: makeSlot(), lingual: makeSlot(), palatal: makeSlot(),
                mesial: makeSlot(), distal:  makeSlot(), occlusal: makeSlot(), root: makeSlot()
            }
        };
    }

