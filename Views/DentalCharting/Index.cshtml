    /*
        Soft Tissue Impacted Tooth:
        In the toolbar only, show the tooth icon without the curved tissue line.
        Applied chart marks keep their existing Soft Tissue appearance.
    */
    function toolbarToolIconSvg(tool, color) {
        const toolbarGlyph = tool.id === "soft_tissue_impacted"
            ? "impacted"
            : tool.glyph;

        return iconSvg(toolbarGlyph, color, 36, tool.group);
    }

    function renderToolbar() {
        const order = ["previous", "inside", "disease", "others"];
        const fullWidth = ["previous", "inside"];
        const grouped = {
            disease:  TOOLS.filter(t=>t.group==="disease"),
            previous: TOOLS.filter(t=>t.group==="previous"),
            inside:   TOOLS.filter(t=>t.group==="inside"),
            others:   TOOLS.filter(t=>t.group==="others")
        };
        document.getElementById("toolbar").innerHTML = `
            <div class="toolbar-row">
              ${order.map(group => `
                <div class="group-block" ${fullWidth.includes(group) ? 'style="grid-column: span 2;"' : ''}>
                  <div class="group-title">
                    <span class="group-dot" style="background:${GROUP_COLORS[group]}"></span>
                    ${GROUP_LABELS[group]}
                  </div>
                  <div class="tool-strip">
                    ${grouped[group].map(tool => `
                      <button class="tool-btn ${selectedToolId===tool.id?'active':''}"
                              onclick="selectTool('${tool.id}')" title="${escapeHtml(tool.label)}">
                        ${toolbarToolIconSvg(tool, GROUP_COLORS[group])}
                        <span class="tip">${escapeHtml(tool.label)}</span>
                      </button>
                    `).join("")}
                  </div>
                </div>
              `).join("")}
            </div>`;
    }

    function selectTool(toolId) {
        selectedToolId = toolId;
        pendingSwapToothId = null;

        if (toolId === TEETH_TRANSPOSITION_TOOL_ID) {
            showToast(
                "🔁 اختر السن الأول ثم اختر السن الثاني لتبديل مكانهما.",
                "info"
            );
        }

        if (toolId === PERMANENT_DECIDUOUS_TOOL_ID) {
            showToast(
                "🦷 اختر صورة السن لتحويله إلى سن لبني أصغر حجماً.",
                "info"
            );
        }

        renderAll();
    }

    function swapTeeth(tid1, tid2) {
        if (!tid1 || !tid2 || tid1 === tid2) return false;
        if (!chartData[tid1] || !chartData[tid2]) return false;

        const firstTooth  = chartData[tid1];
        const secondTooth = chartData[tid2];

        // Swap the complete tooth objects so the image identity, surfaces,
        // treatments, notes, and permanent/deciduous status move together.
        chartData[tid1] = secondTooth;
        chartData[tid2] = firstTooth;

        // id always represents the current chart position.
        chartData[tid1].id = tid1;
        chartData[tid2].id = tid2;

        // Backward compatibility for sessions created before sourceId existed.
        if (!chartData[tid1].sourceId) chartData[tid1].sourceId = tid2;
        if (!chartData[tid2].sourceId) chartData[tid2].sourceId = tid1;

        return true;
    }
