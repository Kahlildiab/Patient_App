    function renderToolbar() {
        const order = ["previous", "inside", "disease", "others"];
        const fullWidth = ["previous", "inside"];
        const grouped = {
            disease:  TOOLS.filter(t=>t.group==="disease"),
            previous: TOOLS.filter(t=>t.group==="previous"),
            inside:   TOOLS.filter(t=>t.group==="inside"),
            others:   TOOLS.filter(t=>t.group==="others")
        };
        document.getElementById("toolbar").innerHTML = `
            <div class="toolbar-row">
              ${order.map(group => `
                <div class="group-block" ${fullWidth.includes(group) ? 'style="grid-column: span 2;"' : ''}>
                  <div class="group-title">
                    <span class="group-dot" style="background:${GROUP_COLORS[group]}"></span>
                    ${GROUP_LABELS[group]}
                  </div>
                  <div class="tool-strip">
                    ${grouped[group].map(tool => `
                      <button class="tool-btn ${selectedToolId===tool.id?'active':''}"
                              onclick="selectTool('${tool.id}')" title="${escapeHtml(tool.label)}">
                        ${iconSvg(tool.glyph, GROUP_COLORS[group], 36)}
                        <span class="tip">${escapeHtml(tool.label)}</span>
                      </button>
                    `).join("")}
                  </div>
                </div>
              `).join("")}
            </div>`;
    }

    function selectTool(toolId) {
        selectedToolId = toolId;
        pendingSwapToothId = null;   // ⬅️ جديد
        renderAll();
    }
        function swapTeeth(tid1, tid2) {
        const temp = chartData[tid1];
        chartData[tid1] = chartData[tid2];
        chartData[tid2] = temp;
        // حافظ على الـ id الصحيح بعد التبديل لأن كل كائن كان عنده id القديم بداخله
        chartData[tid1].id = tid1;
        chartData[tid2].id = tid2;
    }
